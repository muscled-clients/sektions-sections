          "settings": {
            "icon": "shopify://shop_images/014-feather.svg",
            "tab_label": "Soft as a cloud",
            "subheading": "Soft as a cloud",
            "text": "<p>The BENI BED is a pillowy, roll-up bed that you can take anywhere. Sun-drenched beach days, starlit camping trips, picnics in the park, or movie nights at home.</p>",
