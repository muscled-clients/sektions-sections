          "settings": {
            "icon": "shopify://shop_images/019-Cotton.svg",
            "tab_label": "Optimal Support",
            "subheading": "Optimal Support",
            "text": "<p>The BENI BED measures 190cm x 90cm and weighs 6.5kg. Once rolled, it fits in a large boot of a car.</p>",
            "image": "shopify://shop_images/Untitled_design_29.webp"
          }
        },
