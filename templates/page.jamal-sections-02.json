      "blocks": {
        "cdaf02fb": {
          "type": "faq",
          "settings": {
            "question": "How do I connect my headphone to my device?",
            "answer": "<p>1. Open the charging case, then press and hold the button. Wait for a blue light to pulse.<br>2. Select your headphones from your device's Bluetooth list.<br>3. On your device, download the Bluetooth app, and follow the in-app instructions to complete the set-up.</p>"
          }
        },
        "c917849b": {
          "type": "faq",
          "settings": {
            "question": "How many devices can be paired at the same time?",
            "answer": "<p>You can connect two devices at once to these headphones.</p>"
          }
        },
        "fc2bb1b1": {
          "type": "faq",
          "settings": {
            "question": "What is active noise cancelling?",
            "answer": "<p>Active Noise Cancellation is the technology that drowns out unwanted sounds when you are listening to your music. These headphones utilise four microphones to constantly measure the surrounding noise and automatically adjust the level of noise cancellation you need to focus.</p>"
          }
        },
        "301298b2": {
          "type": "faq",
          "settings": {
            "question": "What is transparency mode?",
            "answer": "<p>Transparency mode allows you to be more aware of the outside world, meaning if you\u2019re having a conversation or are walking along busy roads, you\u2019ll be able to keep track.</p>"
          }
        },
