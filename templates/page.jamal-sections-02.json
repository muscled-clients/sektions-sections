          "settings": {
            "question": "How do I use Afterpay?",
            "answer": "<p>Simply shop unitedbyblue.com and check out as usual. At checkout, choose Afterpay as your payment method. If it’s your first time using Afterpay, you’ll need to sign up and provide your payment details (Mastercard or Visa).</p>"
          }
        },
