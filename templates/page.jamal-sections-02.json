        "7b23961b": {
          "type": "faq",
          "settings": {
            "question": "Description",
            "answer": "<p>Our blankets offer comfort and warmth wherever it\u2019s needed - draped over your bed, tossed on the couch, wrapped around you, or taken along for outdoor adventures.</p>"
          }
