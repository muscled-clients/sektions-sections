        "0f348184": {
          "type": "faq",
          "settings": {
            "question": "Care guide",
            "answer": "<p>Machine wash on cold mode. If this function is not available to you - it's best to hand wash them.</p>"
          }
        },
        "20a5c49c": {
          "type": "faq",
          "settings": {
            "question": "Shipping & returns",
            "answer": "<p>Free shipping on all orders. Delivery times will be calculated at checkout. We accept returns for a full refund within 30 days of delivery, so long as your order is in new, unused condition. We cover the cost of shipping for eligible blankets returned to NTL.</p>"
