    "product_info_01": {
      "type": "product-info-01",
      "settings": {},
      "blocks": {
        "157a366c": {
          "type": "feature",
          "settings": {
            "title": "ORGANIC GRASS-FED WHOLE MILK",
            "text": "<p>The natural fat in whole milk contains fatty acids akin to those in breast milk, lessening the need for plant-based oils.</p>",
            "position": "left",
            "dot_x": 20,
            "dot_y": 20
          }
        },
        "366e5dc6": {
          "type": "feature",
          "settings": {
            "title": "WHEY PROTEIN",
            "text": "<p>Our protein blend features a 60:40 whey-to-casein ratio (just like breast milk) to support easy, comfortable digestion.</p>",
            "position": "left",
            "dot_x": 15,
            "dot_y": 60
          }
        },
        "7df5db0c": {
          "type": "feature",
          "settings": {
            "title": "ORGANIC FAT BLEND",
            "text": "<p>Our plant-based oils are expeller-pressed, delivering essential fatty acids without GMOs, pesticides, or chemical solvents.</p>",
            "position": "right",
            "dot_x": 40,
            "dot_y": 25
          }
        },
        "e071aec5": {
          "type": "feature",
          "settings": {
            "title": "MFGM",
            "text": "<p>Naturally-occurring milk fat globule membrane (MFGM) from whole milk to support brain development.</p>",
            "position": "right",
            "dot_x": 45,
            "dot_y": 65
          }
        }
      },
      "block_order": [
        "157a366c",
        "366e5dc6",
        "7df5db0c",
        "e071aec5"
      ]
    },
    "product_info_02": {
      "type": "product-info-02",
      "settings": {},
      "blocks": {
        "3e2c4aff": {
          "type": "feature",
          "settings": {
