            "position": "left",
            "dot_x": 17,
            "dot_y": 55
          }
        },
        "612620cd": {
          "type": "feature",
          "settings": {
            "title": "Waterproof",
            "text": "<p>It's now also waterproof, ready for workouts, swimming, and everyday splashes. Enjoy the freedom to wear your smartwatch anywhere, anytime.</p>",
            "position": "right",
            "dot_x": 40,
            "dot_y": 25
          }
        },
        "034cdb79": {
          "type": "feature",
          "settings": {
            "title": "Adjustable",
