<style>

/* ===============================
   TRIGGER BUTTON
================================ */

.icp-trigger{
position:fixed;
z-index:999;
padding:14px 26px;
border-radius:40px;
cursor:pointer;
box-shadow:0 10px 30px rgba(0,0,0,0.15);
font-size:16px;
background:{{ section.settings.trigger_bg }};
color:{{ section.settings.trigger_text_color }};
display:flex;
align-items:center;
gap:8px;
}

/* VERTICAL POSITION */

{% if section.settings.vertical_position == "top" %}
.icp-trigger{
top:20px;
}
{% else %}
.icp-trigger{
bottom:20px;
}
{% endif %}

/* HORIZONTAL POSITION */

{% case section.settings.horizontal_position %}

{% when 'left' %}
.icp-trigger{
left:20px;
}

{% when 'center' %}
.icp-trigger{
left:50%;
transform:translateX(-50%);
}

{% when 'right' %}
.icp-trigger{
right:20px;
}

{% endcase %}


/* ===============================
   POPUP BACKGROUND
================================ */

.icp-popup{
position:fixed;
top:0;
left:0;
width:100%;
height:100vh;
display:none;
align-items:center;
justify-content:center;
background:{{ section.settings.background_color }};
z-index:9999;
}

{% if section.settings.enable_gradient %}
.icp-popup{
background:linear-gradient(
135deg,
{{ section.settings.gradient_color_1 }},
{{ section.settings.gradient_color_2 }}
);
}
{% endif %}


/* ===============================
   CONTAINER
================================ */

.icp-wrapper{
display:flex;
align-items:center;
justify-content:space-between;
width:90%;
max-width:1200px;
}


/* ===============================
   LEFT CONTENT
================================ */

.icp-left{
width:50%;
text-align:center;
color:{{ section.settings.text_color }};
padding:40px;
}

.icp-heading{
font-size:38px;
font-weight:700;
margin-bottom:16px;
color:{{ section.settings.heading_color }};
}

.icp-text{
font-size:16px;
margin-bottom:30px;
line-height:1.6;
}


/* ===============================
   INPUT
================================ */

.icp-input{
width:100%;
max-width:420px;
padding:18px 22px;
border-radius:40px;
border:none;
background:#f2f2f2;
margin-bottom:20px;
font-size:15px;
}


/* ===============================
   POPUP BUTTON
================================ */

.icp-btn{
padding:12px 28px;
border-radius:40px;
border:none;
background:{{ section.settings.popup_button_bg }};
color:{{ section.settings.popup_button_text }};
font-size:14px;
cursor:pointer;
}


/* ===============================
   IMAGE
================================ */

.icp-right{
width:50%;
display:flex;
justify-content:center;
}

.icp-image{
width:100%;
max-width:460px;
}


/* ===============================
   CLOSE BUTTON
================================ */

.icp-close{
position:absolute;
top:20px;
left:20px;
border:none;
background:none;
cursor:pointer;
}

.icp-close svg{
fill:{{ section.settings.text_color }};
}


/* ===============================
   MOBILE
================================ */

@media(max-width:900px){

.icp-wrapper{
flex-direction:column;
text-align:center;
}

.icp-left{
width:100%;
padding:20px;
}

.icp-right{
width:100%;
margin-top:30px;
}

.icp-image{
max-width:300px;
}

}

</style>



<!-- TRIGGER BUTTON -->

<div class="icp-trigger" id="icpTrigger">

{{ section.settings.trigger_text }}
<div class="trigger-close" onclick="this.closest('.icp-trigger').style.display='none';" style="display:flex;">
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
    <path fill-rule="evenodd" clip-rule="evenodd" d="M12.0002 10.586L4.70718 3.29297L3.29297 4.70718L10.586 12.0002L3.29297 19.2933L4.70718 20.7075L12.0002 13.4145L19.2933 20.7075L20.7075 19.2933L13.4145 12.0002L20.7075 4.70723L19.2933 3.29302L12.0002 10.586Z" fill="currentColor"></path>
  </svg>
</div>

</div>



<!-- POPUP -->

<div class="icp-popup color-{{ section.settings.color_scheme }}" id="icpPopup">

<button class="icp-close" id="icpClose">

<svg width="24" height="24" viewBox="0 0 24 24">
<path fill-rule="evenodd" clip-rule="evenodd"
d="M12.0002 10.586L4.70718 3.29297L3.29297 4.70718L10.586 12.0002L3.29297 19.2933L4.70718 20.7075L12.0002 13.4145L19.2933 20.7075L20.7075 19.2933L13.4145 12.0002L20.7075 4.70723L19.2933 3.29302L12.0002 10.586Z"/>
</svg>

</button>



<div class="icp-wrapper">

<div class="icp-left">

<h2 class="icp-heading">
{{ section.settings.heading }}
</h2>

<p class="icp-text">
{{ section.settings.description }}
</p>


<form method="post" action="/contact#contact_form">

<input type="hidden" name="form_type" value="customer">
<input type="hidden" name="contact[tags]" value="newsletter">

<input
class="icp-input"
type="email"
name="contact[email]"
placeholder="{{ section.settings.placeholder }}"
required
>

<button type="submit" class="icp-btn">
{{ section.settings.button_text }}
</button>

</form>

</div>



<div class="icp-right">

{% if section.settings.popup_image != blank %}

<img
class="icp-image"
src="{{ section.settings.popup_image | image_url: width:1200 }}"
alt="popup image"
>

{% endif %}

</div>

</div>

</div>



<script>

document.getElementById("icpTrigger").onclick=function(e){
if(!e.target.closest('.trigger-close')){
document.getElementById("icpPopup").style.display="flex";
}
}

document.getElementById("icpClose").onclick=function(){
document.getElementById("icpPopup").style.display="none";
}

</script>



{% schema %}
{
"name":"Inner Circle Popup",
"settings":[

{
"type":"text",
"id":"trigger_text",
"label":"Trigger Button Text",
"default":"Sign Up for Updates"
},

{
"type":"select",
"id":"vertical_position",
"label":"Vertical Position",
"default":"top",
"options":[
{"value":"top","label":"Top"},
{"value":"bottom","label":"Bottom"}
]
},

{
"type":"select",
"id":"horizontal_position",
"label":"Horizontal Position",
"default":"center",
"options":[
{"value":"left","label":"Left"},
{"value":"center","label":"Center"},
{"value":"right","label":"Right"}
]
},

{
"type":"color",
"id":"trigger_bg",
"label":"Trigger Button Background",
"default":"#ffffff"
},

{
"type":"color",
"id":"trigger_text_color",
"label":"Trigger Button Text Color",
"default":"#000000"
},

{
"type":"text",
"id":"heading",
"label":"Heading",
"default":"JOIN THE INNER CIRCLE"
},

{
"type":"color",
"id":"heading_color",
"label":"Heading Color",
"default":"#ffffff"
},

{
"type":"textarea",
"id":"description",
"label":"Description",
"default":"Get 2026 early-access drops and member-only pricing delivered to your inbox."
},

{
"type":"text",
"id":"placeholder",
"label":"Email Placeholder",
"default":"Enter email"
},

{
"type":"text",
"id":"button_text",
"label":"Popup Button Text",
"default":"GET ACCESS"
},

{
"type":"color",
"id":"popup_button_bg",
"label":"Popup Button Background",
"default":"#ffffff"
},

{
"type":"color",
"id":"popup_button_text",
"label":"Popup Button Text Color",
"default":"#000000"
},

{
"type":"image_picker",
"id":"popup_image",
"label":"Popup Image"
},

{
"type":"color",
"id":"background_color",
"label":"Background Color",
"default":"#1a1b26"
},

{
"type":"checkbox",
"id":"enable_gradient",
"label":"Enable Gradient Background",
"default":true
},

{
"type":"color",
"id":"gradient_color_1",
"label":"Gradient Color 1",
"default":"#272838"
},

{
"type":"color",
"id":"gradient_color_2",
"label":"Gradient Color 2",
"default":"#1a1b26"
},

{
"type":"color",
"id":"text_color",
"label":"Text Color",
"default":"#ffffff"
},

{
"type":"color_scheme",
"id":"color_scheme",
"label":"Color Scheme",
"default":"scheme-1"
}

],
"presets":[
{
"name":"Inner Circle Popup"
}
]
}
{% endschema %}