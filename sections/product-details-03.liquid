{{ 'https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@400;700&family=Josefin+Sans:wght@400&display=swap' | stylesheet_tag }}

<style data-shopify="">
  {%- assign section_id = '#shopify-section-' | append: section.id -%}
  
  @font-face {
    font-family: "Bricolage Grotesque";
    font-weight: 700;
    font-style: normal;
    font-display: swap;
    src: url("//section.store/cdn/fonts/bricolage_grotesque/bricolagegrotesque_n7.de5675dd7a8e145fdc4cb2cfe67a16cb085528d0.woff2") format("woff2"),
         url("//section.store/cdn/fonts/bricolage_grotesque/bricolagegrotesque_n7.d701b766b46c76aceb10c78473f491dff9b09e5e.woff") format("woff");
  }

  @font-face {
    font-family: "Bricolage Grotesque";
    font-weight: 400;
    font-style: normal;
    font-display: swap;
    src: url("//section.store/cdn/fonts/bricolage_grotesque/bricolagegrotesque_n4.3c051773a9f927cd8737c10568a7e4175690f7d9.woff2") format("woff2"),
         url("//section.store/cdn/fonts/bricolage_grotesque/bricolagegrotesque_n4.58698d726495f44d45631b33dcda62f474c467fc.woff") format("woff");
  }

  @font-face {
    font-family: "Josefin Sans";
    font-weight: 400;
    font-style: normal;
    font-display: swap;
    src: url("//section.store/cdn/fonts/josefin_sans/josefinsans_n4.70f7efd699799949e6d9f99bc20843a2c86a2e0f.woff2") format("woff2"),
         url("//section.store/cdn/fonts/josefin_sans/josefinsans_n4.35d308a1bdf56e5556bc2ac79702c721e4e2e983.woff") format("woff");
  }
  
  .section-{{ section.id }} {
    border-top: solid {{ section.settings.border_color }} {{ section.settings.border_width }}px;
    border-bottom: solid {{ section.settings.border_color }} {{ section.settings.border_width }}px;
    border-left: solid {{ section.settings.border_color }} {{ section.settings.border_width }}px;
    border-right: solid {{ section.settings.border_color }} {{ section.settings.border_width }}px;
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
    margin-left: {{ section.settings.margin_left_mobile }}rem;
    margin-right: {{ section.settings.margin_right_mobile }}rem;
    border-radius: {{ section.settings.border_radius_mobile }}px;
    overflow: hidden; 
    position: relative;
  }

  .section-{{ section.id }}-settings {
    margin: 0 auto;
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    max-width: {{ section.settings.max_width }}px;
    overflow: hidden;
  }

  .details-body-{{ section.id }} {
    display: grid;
    grid-template-areas: {{ section.settings.grid_areas_mobile }};
    grid-template-columns: 1fr;
    gap: {{ section.settings.grid_gap_mobile }}px;
  }

  .details-items-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.faq_gap_mobile }}px;
    grid-area: faq;
  }
  
  .details-item-{{ section.id }} {
    padding: {{ section.settings.faq_padding_vertical_mobile }}px {{ section.settings.faq_padding_horizontal_mobile }}px;
    width: 100%;
    position: relative;
    {% if section.settings.faq_bg_color != 'rgba(0,0,0,0)' %}
      background-color: {{ section.settings.faq_bg_color }};
    {% endif %}
    border: {{ section.settings.faq_border_width }}px solid {{ section.settings.faq_border_color }};
    border-radius: {{ section.settings.faq_border_radius }}px;    
    transition: all 0.25s ease 0s;
  }

  .details-toggle-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    gap: 12px;
  }

  .details-question-{{ section.id }} {
    margin: 0px;
    font-size: {{ section.settings.faq_question_size_mobile }}px;  
    color: {{ section.settings.faq_question_color }};
    line-height: 150%;
    text-transform: unset;
    transition: all 0.25s ease 0s;
    font-weight: {{ section.settings.faq_question_weight }};
    font-family: {{ section.settings.faq_question_font }};
  }

  .details-toggle-{{ section.id }}.active .details-question-{{ section.id }} {
    color: {{ section.settings.faq_question_active_color }};
    transition: all 0.25s ease 0s;
  }

  .details-icon-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    transition: all 0.25s ease 0s;
  }

  .details-icon-{{ section.id }} svg {
    width: 100%;
    height: 100%;
    transition: all 0.25s ease 0s;
  }

  .details-icon-{{ section.id }} svg path {
    stroke: {{ section.settings.icon_color }};
  }

  .details-icon-{{ section.id }}.active svg {
    transform: rotate(180deg);
    transition: all 0.25s ease 0s;
  }

  .details-answer-{{ section.id }} {
    transition: all 0.2s ease-in-out;
    overflow: hidden;
  }

  .details-answer-{{ section.id }} * {
    margin: 0px;
    font-size: {{ section.settings.faq_answer_size_mobile }}px; 
    color: {{ section.settings.faq_answer_color }};
    line-height: 150%;
    text-transform: unset;
    font-family: {{ section.settings.faq_answer_font }};
    font-weight: {{ section.settings.faq_answer_weight }};
  }

  .details-height-cal-{{ section.id }} {
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    top: 0;
    left: 0;
    width: calc(100% - {{ section.settings.faq_padding_horizontal_mobile | times: 2 }}px);
    padding-top: {{ section.settings.faq_answer_margin_top }}px;
  }

  .details-height-cal-{{ section.id }} * {
    margin: 0px;
    font-size: {{ section.settings.faq_answer_size_mobile }}px;
    color: {{ section.settings.faq_answer_color }};
    line-height: 150%;
    text-transform: unset;
    font-family: {{ section.settings.faq_answer_font }};
    font-weight: {{ section.settings.faq_answer_weight }};
  }

  .details-content-{{ section.id }} {
    grid-area: content;
    flex: 1 1 0;
  }

  .details-features-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: {{ section.settings.features_gap }}px;
    flex-wrap: wrap;
    margin-bottom: {{ section.settings.features_margin_bottom }}px;
  }

  .details-feature-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: {{ section.settings.feature_padding_vertical }}px {{ section.settings.feature_padding_horizontal }}px;
    {% if section.settings.feature_bg_color != 'rgba(0,0,0,0)' %}
      background-color: {{ section.settings.feature_bg_color }};
    {% endif %}
    border: {{ section.settings.feature_border_width }}px solid {{ section.settings.feature_border_color }};
    border-radius: {{ section.settings.feature_border_radius }}px;      
    transition: all 0.25s ease 0s;
  }

  .details-feature-icon-{{ section.id }} {
    overflow: hidden;
    flex-shrink: 0;
  }

  .details-feature-icon-{{ section.id }} img,
  .details-feature-icon-{{ section.id }} svg {
    display: block;
    width: {{ section.settings.feature_icon_size }}px;
    height: {{ section.settings.feature_icon_size }}px;
    object-fit: cover;
  }
  
  .details-feature-icon-{{ section.id }} svg path {
    fill: {{ section.settings.feature_icon_color }};
  }

  .details-feature-icon-{{ section.id }} svg circle {
    fill: {{ section.settings.feature_icon_color }};
  }
  
  .details-feature-icon-{{ section.id }} .refresh-{{ section.id }} path,
  .details-feature-icon-{{ section.id }} .refresh-{{ section.id }} polyline {
    fill: none;
    stroke: {{ section.settings.feature_icon_color }};
  }
    
  .details-heading-{{ section.id }} {
    text-align: {{ section.settings.heading_alignment_mobile }};
    margin-bottom: {{ section.settings.heading_margin_bottom }}px;
  }

  .details-heading-{{ section.id }} * {
    margin: 0;  
    font-size: {{ section.settings.heading_size_mobile }}px;
    color: {{ section.settings.heading_color }};
    line-height: 150%;
    text-transform: unset;
    text-decoration: none;
    word-break: break-word;
    font-family: {{ section.settings.heading_font }};
    font-weight: {{ section.settings.heading_weight }};
  }    

  .details-products-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.products_gap }}px;
  }

  .details-product-{{ section.id }} {
    display: flex;
    align-items: center;
    box-sizing: border-box !important;
    gap: 10px;
    text-decoration: none;
    padding: {{ section.settings.product_padding_vertical }}px {{ section.settings.product_padding_horizontal }}px;
    border-radius: {{ section.settings.product_border_radius }}px;
    overflow: hidden;
    {% if section.settings.product_bg_color != 'rgba(0,0,0,0)' %}
      background-color: {{ section.settings.product_bg_color }};
    {% endif %}
    border: {{ section.settings.product_border_width }}px solid {{ section.settings.product_border_color }};
  }

  .details-product-{{ section.id }}:not(:last-child) {
    margin-bottom: {{ section.settings.products_gap }}px;
  }

  .details-product-{{ section.id }} svg {
    display: block;
    width: 15px;
    height: 15px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .details-product-{{ section.id }} svg rect {
    fill: {{ section.settings.product_arrow_color }};
  }

  .details-product-content-{{ section.id }} {
    flex: 1;
  }

  .details-product-title-{{ section.id }} {
    margin: 0;   
    text-align: left;
    font-size: {{ section.settings.product_title_size_mobile }}px;
    color: {{ section.settings.product_title_color }};
    line-height: 150%;
    text-transform: unset;
    word-break: break-word;
    transition: all 0.25s ease 0s;
    font-family: {{ section.settings.product_title_font }};
    font-weight: {{ section.settings.product_title_weight }};
  }   

   .details-feature-title-{{ section.id }} {
    margin: 0;   
    font-size: {{ section.settings.feature_title_size_mobile }}px;
    color: {{ section.settings.feature_title_color }};
    line-height: 130%;
    text-transform: unset;
    word-break: break-word;
    transition: all 0.25s ease 0s;
    font-family: {{ section.settings.feature_title_font }};
    font-weight: {{ section.settings.feature_title_weight }};
  }   

  .details-product-image-{{ section.id }} {
    width: {{ section.settings.product_image_width }}px;
    flex-shrink: 0;
    margin-bottom: auto;
    border: {{ section.settings.product_image_border_width }}px solid {{ section.settings.product_image_border_color }};
    border-radius: {{ section.settings.product_image_border_radius }}px;
    overflow: hidden;
    aspect-ratio: {{ section.settings.product_image_aspect_ratio }};
  }

  .details-product-image-{{ section.id }} img,
  .details-product-image-{{ section.id }} svg {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .details-product-image-{{ section.id }} svg {
    background-color: #AFAFAF;
  }
  
  .details-text-{{ section.id }} {
    text-align: left;
    margin-top: {{ section.settings.text_margin_top }}px;    
  }

  .details-text-{{ section.id }} * {
    margin: 0;    
    font-size: {{ section.settings.text_size_mobile }}px;
    line-height: 150%;
    color: {{ section.settings.text_color }};  
    text-transform: unset;  
    word-break: break-word;
    font-family: {{ section.settings.text_font }};
    font-weight: {{ section.settings.text_weight }};
  }

  .details-price-{{ section.id }} {
    margin-top: {{ section.settings.price_margin_top }}px;  
    width: 100%;
    display: flex;
    align-items: center;
    gap: 5px;
    justify-content: {{ section.settings.price_alignment_mobile }};
  }

  .details-price-{{ section.id }} * {
    margin: 0;        
    text-align: {{ section.settings.price_alignment_mobile }};
    font-size: {{ section.settings.price_size_mobile }}px;
    color: {{ section.settings.price_color }};  
    line-height: 130%;
    text-transform: unset;
    word-break: break-word;
    transition: all 0.25s ease 0s;
    font-family: {{ section.settings.price_font }};
    font-weight: {{ section.settings.price_weight }};
  }   

  .details-compare-price-{{ section.id }} {
    text-decoration: line-through;
    color: {{ section.settings.compare_price_color }};  
  }

  @media(min-width: 1024px) {
    .section-{{ section.id }} {
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
      margin-left: {{ section.settings.margin_left_desktop }}rem;
      margin-right: {{ section.settings.margin_right_desktop }}rem;
      border-radius: {{ section.settings.border_radius_desktop }}px;
      border-left: solid {{ section.settings.border_color }} {{ section.settings.border_width }}px;
      border-right: solid {{ section.settings.border_color }} {{ section.settings.border_width }}px;
    }

    .section-{{ section.id }}-settings {
      padding: 0 5rem;
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      padding-left: {{ section.settings.padding_left_desktop }}rem;
      padding-right: {{ section.settings.padding_right_desktop }}rem;
    }  
    
    .details-body-{{ section.id }} {
      display: grid;      
      gap: {{ section.settings.grid_gap_desktop }}px;
      grid-template-areas: {{ section.settings.grid_areas_desktop }};
      grid-template-columns: {{ section.settings.grid_columns_desktop }};  
    }

    .details-item-{{ section.id }} {
      padding: {{ section.settings.faq_padding_vertical_desktop }}px {{ section.settings.faq_padding_horizontal_desktop }}px;
    }
    
    .details-question-{{ section.id }} {
      font-size: {{ section.settings.faq_question_size_desktop }}px;
    }

    .details-items-{{ section.id }} {
      gap: {{ section.settings.faq_gap_desktop }}px;
    }
    
    .details-icon-{{ section.id }} {
      flex: 0 0 {{ section.settings.icon_size_desktop }}px;
      height: {{ section.settings.icon_size_desktop }}px;
    }
    
    .details-answer-{{ section.id }} * {
      font-size: {{ section.settings.faq_answer_size_desktop }}px;
    }

    .details-height-cal-{{ section.id }} {
      width: calc(100% - {{ section.settings.faq_padding_horizontal_desktop | times: 2 }}px);
    }

    .details-height-cal-{{ section.id }} * {
      font-size: {{ section.settings.faq_answer_size_desktop }}px;
    }

    .details-features-{{ section.id }} {
      gap: {{ section.settings.features_gap_desktop }}px;
      margin-bottom: {{ section.settings.features_margin_bottom_desktop }}px;
    }

    .details-feature-{{ section.id }} {
      padding: {{ section.settings.feature_padding_vertical_desktop }}px {{ section.settings.feature_padding_horizontal_desktop }}px;
    }
    
    .details-feature-icon-{{ section.id }} img,
    .details-feature-icon-{{ section.id }} svg {
      width: {{ section.settings.feature_icon_size_desktop }}px;
      height: {{ section.settings.feature_icon_size_desktop }}px;
    }

    .details-heading-{{ section.id }} {
      text-align: {{ section.settings.heading_alignment_desktop }};
      margin-bottom: {{ section.settings.heading_margin_bottom_desktop }}px;
    }

    .details-heading-{{ section.id }} * {
      font-size: {{ section.settings.heading_size_desktop }}px;
    }  
    
    .details-products-{{ section.id }} {
      gap: {{ section.settings.products_gap_desktop }}px;
    }

    .details-product-{{ section.id }} {
      padding: {{ section.settings.product_padding_vertical_desktop }}px {{ section.settings.product_padding_horizontal_desktop }}px;
    }

    .details-feature-title-{{ section.id }} {
      font-size: {{ section.settings.feature_title_size_desktop }}px;   
    }

    .details-product-title-{{ section.id }} {
      text-align: left;
      font-size: {{ section.settings.product_title_size_desktop }}px;    
    }   
    
    .details-text-{{ section.id }} {
      text-align: left;
      margin-top: {{ section.settings.text_margin_top_desktop }}px;    
    }

    .details-text-{{ section.id }} * {    
      font-size: {{ section.settings.text_size_desktop }}px;
    }

    .details-price-{{ section.id }} {    
      margin-top: {{ section.settings.price_margin_top_desktop }}px;       
      justify-content: {{ section.settings.price_alignment_desktop }};
    }

    .details-price-{{ section.id }} * {        
      text-align: {{ section.settings.price_alignment_desktop }};
      font-size: {{ section.settings.price_size_desktop }}px;    
    }   
  }
</style>

<div class="section-{{ section.id }} details-{{ section.id }}" style="background-color:{{ section.settings.background_color }};">
  <div class="section-{{ section.id }}-settings">
    <div class="details-body-{{ section.id }}">
      
      {% comment %} FAQ Items Column {% endcomment %}
      <div class="details-items-{{ section.id }}">
        {% for block in section.blocks %}
          {% if block.type == 'faq' %}
            <div class="details-item-{{ section.id }}" id="faq-{{ block.id }}" {{ block.shopify_attributes }}>        
              <div class="details-toggle-{{ section.id }}" id="faq-{{ block.id }}">                  
                <p class="details-question-{{ section.id }}">{{ block.settings.question }}</p>              
                <div class="details-icon-{{ section.id }}">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M11 5.5L7 9.5L3 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>               
                </div>
              </div>
              <div class="details-answer-{{ section.id }}" style="display: none; height: 0px; padding-top: 0px; padding-bottom: 0px;">
                {{ block.settings.answer }}
              </div>
              <div class="details-height-cal-{{ section.id }}">
                {{ block.settings.answer }}
              </div>                      
            </div>  
          {% endif %}
        {% endfor %}
      </div>
      
      {% comment %} Content Column (Features + Products) {% endcomment %}
      <div class="details-content-{{ section.id }}">
        
        {% if section.settings.features_heading != blank %}
          <div class="details-heading-{{ section.id }}">{{ section.settings.features_heading }}</div>
        {% endif %}
        
        <div class="details-features-{{ section.id }}">
          {% for block in section.blocks %}
            {% if block.type == 'feature' %}
              <div class="details-feature-{{ section.id }}" {{ block.shopify_attributes }}>        
                {% if block.settings.icon_svg != blank %}
                  <div class="details-feature-icon-{{ section.id }}">
                    {{ block.settings.icon_svg }}
                  </div>
                {% endif %}
                
                {% if block.settings.title != blank %}
                  <p class="details-feature-title-{{ section.id }}">{{ block.settings.title }}</p>
                {% endif %}
              </div> 
            {% endif %}
          {% endfor %}
        </div>
        
        {% if section.settings.products_heading != blank %}
          <div class="details-heading-{{ section.id }}">{{ section.settings.products_heading }}</div>
        {% endif %}
        
        <div class="details-products-{{ section.id }}">
          {% for block in section.blocks %}
            {% if block.type == 'product' %}
              {% assign product = block.settings.product %}
              {% if product != blank %}
                <a href="{{ product.url }}" class="details-product-{{ section.id }}" {{ block.shopify_attributes }}>
                  <div class="details-product-image-{{ section.id }}">
                    <div class="details-image-{{ section.id }}">
                      {% if product.featured_image != blank %}
                        <img src="{{ product.featured_image | img_url: '300x' }}" alt="{{ product.title }}" loading="lazy" width="300" height="300">
                      {% else %}
                        {{ 'product-1' | placeholder_svg_tag }}
                      {% endif %}
                    </div>
                  </div>
                  <div class="details-product-content-{{ section.id }}">
                    <div class="details-content-wrapper-{{ section.id }}">
                      {% if block.settings.custom_title != blank %}
                        <h3 class="details-product-title-{{ section.id }}">{{ block.settings.custom_title }}</h3>
                      {% else %}
                        <h3 class="details-product-title-{{ section.id }}">{{ product.title }}</h3>
                      {% endif %}
                      
                      {% if block.settings.custom_text != blank %}
                        <div class="details-text-{{ section.id }}">{{ block.settings.custom_text }}</div>
                      {% endif %}
                      
                      <div class="details-price-{{ section.id }}">
                        {% if product.compare_at_price > product.price %}
                          <p class="details-compare-price-{{ section.id }}">{{ product.compare_at_price | money }}</p>
                        {% endif %}
                        <p class="details-regular-price-{{ section.id }}">
                          {{ product.price | money }}
                        </p>
                      </div>
                    </div>
                  </div>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 12 10" height="10" width="12">
                    <rect fill="{{ section.settings.product_arrow_color }}" transform="rotate(-90 5.49011 9.73779)" height="1.04079" width="9.55389" y="9.73779" x="5.49011"></rect>
                    <rect fill="{{ section.settings.product_arrow_color }}" transform="rotate(-90 0.808472 5.43848)" height="10.4079" width="0.955389" y="5.43848" x="0.808472"></rect>
                  </svg>
                </a>
              {% endif %}
            {% endif %}
          {% endfor %}
        </div>
        
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    function initProductDetails() {
      const sectionId = '{{ section.id }}';
      const answerPaddingTop = 20;
      const answerPaddingBottom = 0;

      const buttons = document.querySelectorAll(`.details-toggle-${sectionId}`);
      const answers = document.querySelectorAll(`.details-answer-${sectionId}`);
      const answersHeightCalElements = document.querySelectorAll(`.details-height-cal-${sectionId}`);
      const faqIcons = document.querySelectorAll(`.details-icon-${sectionId}`);

      let activeIndex = -1;

      function openAnswer(index) {
        const height = answersHeightCalElements[index].offsetHeight;

        answers[index].style.display = 'block';
        setTimeout(() => {
          answers[index].style.paddingTop = `${answerPaddingTop}px`;
          answers[index].style.paddingBottom = `${answerPaddingBottom}px`;
          answers[index].style.height = `${height}px`;
        });

        faqIcons[index].classList.add('active');
        buttons[index].classList.add('active');
      }

      function closeAnswer(index) {
        answers[index].style.paddingTop = 0;
        answers[index].style.paddingBottom = 0;
        answers[index].style.height = 0;

        setTimeout(() => {
          answers[index].style.display = 'none';
        }, 300);

        faqIcons[index].classList.remove('active');
        buttons[index].classList.remove('active');
      }

      function toggleAnswer(index) {
        if (answers[index].style.display === 'none') {
          openAnswer(index);
          activeIndex = index;
        } else {
          closeAnswer(index);
          activeIndex = -1;
        }
      }

      function closeAllAnswersBut(index) {
        answers.forEach((answer, i) => {
          if (i !== index) {
            closeAnswer(i);
          }
        });
      }

      buttons.forEach((button, index) => {
        button.addEventListener('click', () => {
          toggleAnswer(index);
          closeAllAnswersBut(index);
        });
      });

      let resizeTimer;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => {
          if (activeIndex !== -1) {
            const height = answersHeightCalElements[activeIndex].offsetHeight;
            answers[activeIndex].style.height = `${height}px`;
          }
        }, 250);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initProductDetails);
    } else {
      initProductDetails();
    }

    {% if request.design_mode %}
      document.addEventListener('shopify:section:load', function(event) {
        if (event.detail.sectionId === '{{ section.id }}') {
          setTimeout(initProductDetails, 100);
        }
      });
    {% endif %}
  })();
</script>

