    transition: all 0.3s ease 0s;
}

.bs3-card{
background:white;
position:relative;
text-align:center;
padding:0px;
overflow:hidden;
aspect-ratio: 9.6 / 13;
margin:0px;
width:100%;
}

/* Product Gallery Styles */
.bs3-product-gallery{
position:relative;
width:100%;
height:100%;
overflow:hidden;
}

.bs3-product-gallery .swiper-slide{
width:100%;
height:100%;
background-color: #f1f0ed !important;
}

.bs3-product-gallery .swiper-slide img{
width:100%;
height:100%;
object-fit:cover;
display:block;
}

