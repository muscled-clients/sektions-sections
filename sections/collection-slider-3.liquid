    color: #1b1916;
    line-height: 100%;
    text-align: center;
    text-transform: uppercase;
    text-decoration: none;
    word-break: break-word;
    padding: 16px 32px;
    border-radius: 0px;
    transition: all 0.3s ease 0s;
    background-color: transparent;
    border: 0px;
    cursor: pointer;
    position: relative;
    z-index: 1;
