{% comment %}
Collection Slider 2 - With Hover Popup and Product Image Galleries
{% endcomment %}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

<style>

#best-sellers-{{ section.id }}{
padding:60px 0;
background:#fff;
width:100%;
}

.bs2-container{
max-width:100%;
margin:auto;
padding:0 0px;
position:relative;
width:100%;
}

.bs2-header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:30px;
    padding: 0px 5rem;
}

.bs2-title{
font-size:42px;
font-weight:700;
font-family: Caprasimo, sans-serif;
margin:0;
}

.bs2-button{
padding: 0px;
    -webkit-box-shadow: none;
    -moz-box-shadow: none;
    box-shadow: none;
    text-decoration: underline!important;
    text-underline-offset: 4px;
        font-family: "Bricolage Grotesque", sans-serif;
    font-weight: 400;
    font-style: normal;
            padding: 16px 32px;
            display: flex;
    align-items: center;
    justify-content: center;
    max-width: fit-content;
    gap: 10px;
    width: 100%;
    margin: 0;
    font-size: 18px;
    color: #1b1916;
    line-height: 100%;
    text-align: center;
    text-transform: uppercase;
    text-decoration: none;
    word-break: break-word;
    padding: 16px 32px;
    border-radius: 0px;
    transition: all 0.3s ease 0s;
    background-color: transparent;
    border: 0px;
    cursor: pointer;
    position: relative;
    z-index: 1;
}

.bs2-button:hover{
    transition: all 0.3s ease 0s;
}

.bs2-card{
background:white;
position:relative;
text-align:center;
padding:0px;
overflow:hidden;
aspect-ratio: 9.6 / 13;
margin:0px;
width:100%;
}

/* Product Gallery Styles */
.bs2-product-gallery{
position:relative;
width:100%;
height:100%;
overflow:hidden;
}

.bs2-product-gallery .swiper-slide{
width:100%;
height:100%;
}

.bs2-product-gallery .swiper-slide img{
width:100%;
height:100%;
object-fit:cover;
display:block;
}

/* Gallery Navigation Buttons - UPDATED with currentColor */
.bs2-gallery-prev,
.bs2-gallery-next{
position:absolute;
top:50%;
transform:translateY(-50%);
width: 32px;
height: 32px;
background:#fff;
border-radius: 4px;
display:flex;
align-items:center;
justify-content:center;
cursor:pointer;
color: #000000; /* Black color for normal state */
border: 1px solid #1b1916 !important;
font-size: 22px;
line-height: 1;
padding: 0;
z-index:15;
opacity:0;
transition: opacity .3s ease, background .3s ease, color .3s ease;
box-shadow:0 2px 8px rgba(0,0,0,0.1);
}

.bs2-gallery-prev svg,
.bs2-gallery-next svg{
display:block;
width: 18px;
height: 18px;
}

.bs2-gallery-prev svg path,
.bs2-gallery-next svg path {
transition: stroke 0.3s ease;
}

.bs2-card:hover .bs2-gallery-prev.visible,
.bs2-card:hover .bs2-gallery-next.visible{
opacity:1;
}

.bs2-gallery-prev:hover,
.bs2-gallery-next:hover{
background:#000000;
color: #ffffff; /* White color on hover */
}

.bs2-gallery-prev{
left:25px;
}

.bs2-gallery-next{
right:25px;
}

.bs2-gallery-prev.swiper-button-disabled,
.bs2-gallery-next.swiper-button-disabled{
opacity:0 !important;
cursor:not-allowed;
pointer-events:none;
display:none !important;
}

.bs2-badge{
position:absolute;
top:10px;
left:10px;
background-color: #ffffff;
color: #1b1916;
    border: 0px solid #1b1916;
font-size: 11px;
padding: 6px 9px;
text-transform:lowercase;
z-index:20;
font-family: Montserrat, sans-serif;
font-weight: 500;
font-style: normal;
margin:0;
line-height: 11px;
}

/* Hover Popup Styles - FIXED */
.bs2-product-popup{
position:absolute;
bottom:12px;
left:12px;
right:12px;
background:#ffffff;
padding:10px 12px;
display:flex;
justify-content:space-between;
align-items:end;
gap:10px;
transform:translateY(calc(100% + 12px));
transition:transform .5s ease;
z-index:25;
border-radius:0px;
}

.bs2-card:hover .bs2-product-popup{
transform:translateY(0);
}

.bs2-popup-title{
margin:0;
font-size:16px;
font-weight:600;
color:#000000;
text-align:left;
line-height:1.3;
font-family: Caprasimo, sans-serif;
/* Add truncation for long titles */
white-space: nowrap;
overflow: hidden;
text-overflow: ellipsis;
max-width: 100%;
flex: 1;
}

.bs2-popup-price{
margin:0;
font-size:14px;
font-weight:400;
color:#070707;
white-space:nowrap;
flex-shrink: 0;
}

.bs2-navigation{
display:flex;
gap:10px;
justify-content:flex-end;
margin-top:10px;
padding: 0 5rem;
}

/* Main Slider Navigation Buttons - UPDATED with currentColor */
.bs2-prev,
.bs2-next{
width:32px;
height:32px;
background:#fff;
border-radius:4px;
border: 1px solid #1b1916!important;
display:flex;
align-items:center;
justify-content:center;
cursor:pointer;
color: #000; /* Black color for normal state */
transition: background .3s ease, color .3s ease;
border: none;
padding: 0;
}

.bs2-prev svg,
.bs2-next svg {
width: 18px;
height: 18px;
display: block;
}

.bs2-prev svg path,
.bs2-next svg path {
transition: stroke 0.3s ease;
}

.bs2-prev:hover,
.bs2-next:hover{
background:#000000;
color: #fff; /* White color on hover */
}

.bs2-prev.swiper-button-disabled,
.bs2-next.swiper-button-disabled{
opacity:0.5;
cursor:not-allowed;
background:#cccccc;
}

.swiper-slide{
height:auto;
margin:0px;
}

/* Placeholder SVG styling */
.bs2-card .placeholder-svg{
width:100%;
height:100%;
background:#f5f5f5;
display:block;
object-fit:cover;
}

@media(min-width:1200px){
.bs2-header{
    padding: 0px 5rem;
}
}

@media(max-width:1199px){
.bs2-header{
    padding: 0px 3rem;
}
}

@media(max-width:900px){
.bs2-title{
font-size:30px;
}
.bs2-header{
    padding: 0px 2rem;
}
.bs2-popup-title,
.bs2-popup-price{
font-size:14px;
}
}

@media(max-width:640px){
.bs2-card{
padding:0px;
}
.bs2-header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:30px;
    padding: 0px 1.5rem;
}

.bs2-navigation {
    display: flex;
    gap: 10px;
    justify-content: flex-end;
    margin-top: 10px;
    padding: 0 1.5rem;
}

.bs2-button {
    background: #ff7a00;
    color: white;
    padding: 16px 32px;
    text-decoration: none;
    font-weight: 400;
    transition: background .3s ease;
    line-height: 14px;
    font-size: 14px;
}

.bs2-product-popup{
padding:8px 10px;
}

.bs2-gallery-prev,
.bs2-gallery-next{
width:25px;
height:25px;
}

.bs2-gallery-prev svg,
.bs2-gallery-next svg {
width: 14px;
height: 14px;
}

.bs2-gallery-prev{
left:15px;
}

.bs2-gallery-next{
right:15px;
}

.bs2-prev,
.bs2-next{
width:40px;
height:40px;
}

.bs2-prev svg,
.bs2-next svg {
width: 20px;
height: 20px;
}
}

</style>

<section id="best-sellers-{{ section.id }}">

<div class="bs2-container">

<div class="bs2-header">

<h2 class="bs2-title">
{{ section.settings.heading }}
</h2>

{% if section.settings.button_link != blank %}
<a class="bs2-button" href="{{ section.settings.button_link }}">
{{ section.settings.button_label }}
</a>
{% endif %}

</div>

<div class="swiper bs2-swiper-{{ section.id }}">

<div class="swiper-wrapper">

{% if section.settings.collection != blank %}

{% for product in section.settings.collection.products limit: section.settings.products_to_show %}

<div class="swiper-slide">

<div class="bs2-card">

{% if product.available == false %}
<span class="bs2-badge">sold out</span>
{% elsif product.compare_at_price > product.price %}
<span class="bs2-badge">sale</span>
{% else %}
<span class="bs2-badge">selling fast</span>
{% endif %}

<a href="{{ product.url }}" class="bs2-product-link">

<!-- Product Gallery Swiper -->
<div class="bs2-product-gallery swiper product-gallery-{{ section.id }}-{{ forloop.index }}" data-product-gallery>
<div class="swiper-wrapper">
{% if product.images.size > 0 %}
{% for image in product.images %}
<div class="swiper-slide">
<img 
src="{{ image.src | image_url: width:600, height:600, crop: 'center' }}"
alt="{{ image.alt | escape }}"
loading="lazy"
width="600"
height="600"
>
</div>
{% endfor %}
{% else %}
<div class="swiper-slide">
<img 
src="{{ product.featured_image | image_url: width:600, height:600, crop: 'center' }}"
alt="{{ product.title }}"
loading="lazy"
width="600"
height="600"
>
</div>
{% endif %}
</div>

<!-- Gallery Navigation Buttons - Only show if more than one image -->
{% if product.images.size > 1 %}
<button class="bs2-gallery-prev gallery-prev-{{ section.id }}-{{ forloop.index }}" aria-label="Previous image">
<svg viewBox="0 0 24 24" width="18" height="18" fill="none">
<path d="M15 6L9 12L15 18"
stroke="currentColor"
stroke-width="4"
stroke-linecap="round"
stroke-linejoin="round"/>
</svg>
</button>

<button class="bs2-gallery-next gallery-next-{{ section.id }}-{{ forloop.index }}" aria-label="Next image">
<svg viewBox="0 0 24 24" width="18" height="18" fill="none">
<path d="M9 6L15 12L9 18"
stroke="currentColor"
stroke-width="4"
stroke-linecap="round"
stroke-linejoin="round"/>
</svg>
</button>
{% endif %}
</div>

<!-- Hover Popup with Title and Price -->
<div class="bs2-product-popup">
<h4 class="bs2-popup-title">{{ product.title }}</h4>
<span class="bs2-popup-price">{{ product.price | money }}</span>
</div>

</a>

</div>

</div>

{% endfor %}

{% else %}

{% for i in (1..10) %}

<div class="swiper-slide">

<div class="bs2-card">

<span class="bs2-badge">selling fast</span>

<a href="#" class="bs2-product-link">

<!-- Product Gallery Swiper for placeholder -->
<div class="bs2-product-gallery swiper product-gallery-{{ section.id }}-placeholder-{{ forloop.index }}" data-product-gallery>
<div class="swiper-wrapper">
<div class="swiper-slide">
{{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
</div>
<div class="swiper-slide">
{{ 'product-2' | placeholder_svg_tag: 'placeholder-svg' }}
</div>
<div class="swiper-slide">
{{ 'product-3' | placeholder_svg_tag: 'placeholder-svg' }}
</div>
</div>

<!-- Gallery Navigation Buttons for placeholder -->
<button class="bs2-gallery-prev gallery-prev-{{ section.id }}-placeholder-{{ forloop.index }}" aria-label="Previous image">
<svg viewBox="0 0 24 24" width="18" height="18" fill="none">
<path d="M15 6L9 12L15 18"
stroke="currentColor"
stroke-width="4"
stroke-linecap="round"
stroke-linejoin="round"/>
</svg>
</button>
<button class="bs2-gallery-next gallery-next-{{ section.id }}-placeholder-{{ forloop.index }}" aria-label="Next image">
<svg viewBox="0 0 24 24" width="18" height="18" fill="none">
<path d="M9 6L15 12L9 18"
stroke="currentColor"
stroke-width="4"
stroke-linecap="round"
stroke-linejoin="round"/>
</svg>
</button>
</div>

<!-- Hover Popup with Title and Price -->
<div class="bs2-product-popup">
<h4 class="bs2-popup-title">Sample Product</h4>
<span class="bs2-popup-price">$29.00</span>
</div>

</a>

</div>

</div>

{% endfor %}

{% endif %}

</div>

</div>

<div class="bs2-navigation">
  
<div class="bs2-prev prev-{{ section.id }}">
<svg viewBox="0 0 24 24" width="24" height="24" fill="none">
<path d="M15 6L9 12L15 18"
stroke="currentColor"
stroke-width="4"
stroke-linecap="round"
stroke-linejoin="round"/>
</svg>
</div>

<div class="bs2-next next-{{ section.id }}">
<svg viewBox="0 0 24 24" width="24" height="24" fill="none">
<path d="M9 6L15 12L9 18"
stroke="currentColor"
stroke-width="4"
stroke-linecap="round"
stroke-linejoin="round"/>
</svg>
</div>

</div>

</div>

</section>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
(function() {
  // Store section ID for this instance
  const sectionId = '{{ section.id }}';
  const swiperSelector = `.bs2-swiper-${sectionId}`;
  const prevSelector = `.prev-${sectionId}`;
  const nextSelector = `.next-${sectionId}`;
  
  function initSlider2() {
    const swiperElement = document.querySelector(swiperSelector);
    if (!swiperElement) return false;
    
    // Destroy existing Swiper instance if it exists
    if (swiperElement.swiper) {
      swiperElement.swiper.destroy(true, true);
    }
    
    // Get window width to determine slides per view
    const windowWidth = window.innerWidth;
    let slidesPerView = 5; // Default for desktop - max 5 cards
    
    if (windowWidth < 480) {
      slidesPerView = 2; // Mobile - exactly 2 cards
    } else if (windowWidth < 768) {
      slidesPerView = 2; // Small tablet - 2 cards
    } else if (windowWidth < 1024) {
      slidesPerView = 3; // Tablet - 3 cards
    } else if (windowWidth < 1200) {
      slidesPerView = 4; // Small desktop - 4 cards
    } else {
      slidesPerView = 5; // Large desktop - 5 cards max
    }
    
    // Initialize new Swiper
    const swiper = new Swiper(swiperSelector, {
      slidesPerView: slidesPerView,
      spaceBetween: 0,
      loop: true,
      navigation: {
        nextEl: nextSelector,
        prevEl: prevSelector,
      },
      on: {
        init: function() {
          // Force update after initialization
          this.update();
        },
        resize: function() {
          // Update on window resize
          const width = window.innerWidth;
          let newSlidesPerView = 5;
          
          if (width < 480) {
            newSlidesPerView = 2;
          } else if (width < 768) {
            newSlidesPerView = 2;
          } else if (width < 1024) {
            newSlidesPerView = 3;
          } else if (width < 1200) {
            newSlidesPerView = 4;
          } else {
            newSlidesPerView = 5;
          }
          
          this.params.slidesPerView = newSlidesPerView;
          this.update();
        }
      }
    });
    
    return true;
  }

  // Function to update button visibility based on slide position
  function updateGalleryButtons(swiper, prevButton, nextButton) {
    if (!swiper || !prevButton || !nextButton) return;
    
    const isBeginning = swiper.isBeginning;
    const isEnd = swiper.isEnd;
    
    // Remove visible class from both buttons first
    prevButton.classList.remove('visible');
    nextButton.classList.remove('visible');
    
    // Show appropriate buttons based on position
    if (!isBeginning) {
      prevButton.classList.add('visible');
    }
    
    if (!isEnd) {
      nextButton.classList.add('visible');
    }
  }

  // Initialize product galleries (specific to this section)
  function initProductGalleries2() {
    {% if section.settings.collection != blank %}
      {% for product in section.settings.collection.products limit: section.settings.products_to_show %}
        {% if product.images.size > 1 %}
          (function() {
            const prevButton = document.querySelector('.gallery-prev-{{ section.id }}-{{ forloop.index }}');
            const nextButton = document.querySelector('.gallery-next-{{ section.id }}-{{ forloop.index }}');
            
            if (!prevButton || !nextButton) return;
            
            const gallerySwiper = new Swiper(".product-gallery-{{ section.id }}-{{ forloop.index }}", {
              slidesPerView: 1,
              spaceBetween: 0,
              loop: false,
              navigation: {
                nextEl: ".gallery-next-{{ section.id }}-{{ forloop.index }}",
                prevEl: ".gallery-prev-{{ section.id }}-{{ forloop.index }}",
              },
              autoplay: false,
              speed: 500,
              on: {
                init: function() {
                  updateGalleryButtons(this, prevButton, nextButton);
                },
                slideChange: function() {
                  updateGalleryButtons(this, prevButton, nextButton);
                },
                reachBeginning: function() {
                  updateGalleryButtons(this, prevButton, nextButton);
                },
                reachEnd: function() {
                  updateGalleryButtons(this, prevButton, nextButton);
                }
              }
            });
            
            if (prevButton) prevButton.swiper = gallerySwiper;
            if (nextButton) nextButton.swiper = gallerySwiper;
          })();
        {% endif %}
      {% endfor %}
    {% else %}
      // Initialize placeholder galleries
      {% for i in (1..10) %}
        (function() {
          const prevButton = document.querySelector('.gallery-prev-{{ section.id }}-placeholder-{{ forloop.index }}');
          const nextButton = document.querySelector('.gallery-next-{{ section.id }}-placeholder-{{ forloop.index }}');
          
          if (!prevButton || !nextButton) return;
          
          const gallerySwiper = new Swiper(".product-gallery-{{ section.id }}-placeholder-{{ forloop.index }}", {
            slidesPerView: 1,
            spaceBetween: 0,
            loop: false,
            navigation: {
              nextEl: ".gallery-next-{{ section.id }}-placeholder-{{ forloop.index }}",
              prevEl: ".gallery-prev-{{ section.id }}-placeholder-{{ forloop.index }}",
            },
            autoplay: false,
            speed: 500,
            on: {
              init: function() {
                updateGalleryButtons(this, prevButton, nextButton);
              },
              slideChange: function() {
                updateGalleryButtons(this, prevButton, nextButton);
              },
              reachBeginning: function() {
                updateGalleryButtons(this, prevButton, nextButton);
              },
              reachEnd: function() {
                updateGalleryButtons(this, prevButton, nextButton);
              }
            }
          });
          
          if (prevButton) prevButton.swiper = gallerySwiper;
          if (nextButton) nextButton.swiper = gallerySwiper;
        })();
      {% endfor %}
    {% endif %}
  }

  // Initialize main slider with multiple attempts
  function initWithRetry() {
    // Try multiple times to ensure it works
    setTimeout(initSlider2, 100);
    setTimeout(initSlider2, 300);
    setTimeout(initSlider2, 500);
    
    // Initialize product galleries after a delay
    setTimeout(initProductGalleries2, 200);
    setTimeout(initProductGalleries2, 400);
  }

  // Run on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initWithRetry);
  } else {
    initWithRetry();
  }

  // Re-initialize when Shopify theme editor makes changes
  document.addEventListener('shopify:section:load', function(e) {
    if (e.detail && e.detail.sectionId === sectionId) {
      setTimeout(initSlider2, 200);
      setTimeout(initSlider2, 400);
      setTimeout(initProductGalleries2, 300);
      setTimeout(initProductGalleries2, 500);
    }
  });

  document.addEventListener('shopify:section:select', function(e) {
    if (e.detail && e.detail.sectionId === sectionId) {
      setTimeout(initSlider2, 200);
      setTimeout(initSlider2, 400);
      setTimeout(initProductGalleries2, 300);
      setTimeout(initProductGalleries2, 500);
    }
  });

  // Listen for window resize
  window.addEventListener('resize', function() {
    setTimeout(initSlider2, 100);
  });

})();
</script>

{% schema %}
{
"name": "Collection Slider 3",
"settings": [
{
"type": "text",
"id": "heading",
"label": "Heading",
"default": "Best Sellers"
},
{
"type": "collection",
"id": "collection",
"label": "Collection"
},
{
"type": "range",
"id": "products_to_show",
"label": "Products to show",
"min": 4,
"max": 20,
"step": 1,
"default": 10
},
{
"type": "text",
"id": "button_label",
"label": "Button Label",
"default": "Shop all"
},
{
"type": "url",
"id": "button_link",
"label": "Button Link"
}
],
"presets": [
{
"name": "Collection Slider 3"
}
]
}
{% endschema %}