/* Badge Styles - Unified */
.bs3-badge{
    font-family: Roboto, sans-serif;
    font-weight: 400;
    font-style: normal;
    font-size: 10px;
    padding: 5px 8px;
    margin: 0;
    position: absolute;
    top: 10px;
    left: 10px;
    border-radius: 100px;
    color: #ffffff;
    line-height: 100%;
    background-color: #67645e;
    border: 0px solid #67645e;
    text-transform: none;
    word-break: break-word;
    z-index: 2;
}

/* Hover Popup Styles - FIXED */
.bs3-product-popup{
position:absolute;
bottom:12px;
left:12px;
right:12px;
background:#ffffff;
padding:10px 12px;
display:flex;
justify-content:space-between;
align-items:end;
gap:10px;
transform:translateY(calc(100% + 12px));
transition:transform .5s ease;
z-index:25;
border-radius:0px;
}

.bs3-card:hover .bs3-product-popup{
transform:translateY(0);
}

.bs3-popup-title{
margin:0;
font-size:16px;
font-weight:600;
color:#000000;
text-align:left;
line-height:1.3;
font-family: Caprasimo, sans-serif;
/* Add truncation for long titles */
white-space: nowrap;
overflow: hidden;
text-overflow: ellipsis;
max-width: 100%;
flex: 1;
}

.bs3-popup-price{
margin:0;
font-size:14px;
font-weight:400;
color:#070707;
white-space:nowrap;
flex-shrink: 0;
}

.bs3-navigation{
display:flex;
gap:10px;
justify-content:center;
margin-top:10px;
padding: 0 5rem;
}

/* Main Slider Navigation Buttons - UPDATED with currentColor */
.bs3-prev,
.bs3-next{
width:50px;
height:50px;
background: #67645e;
border-radius:50%;
border: 0px solid #67645e!important;
display:flex;
align-items:center;
justify-content:center;
cursor:pointer;
color: #fff; /* Black color for normal state */
transition: background .3s ease, color .3s ease;
border: none;
padding: 0;
}

.bs3-prev svg,
.bs3-next svg {
width: 18px;
height: 18px;
display: block;
}

.bs3-prev svg path,
.bs3-next svg path {
transition: stroke 0.3s ease;
}

.bs3-prev:hover,
.bs3-next:hover{
transform:scale(0.9);
}

.bs3-prev.swiper-button-disabled,
.bs3-next.swiper-button-disabled{
opacity:0.5;
cursor:not-allowed;
background:#cccccc;
}

.swiper-slide{
height:auto;
margin:0px;
}

/* Placeholder SVG styling */
.bs3-card .placeholder-svg{
width:100%;
height:100%;
background:#f5f5f5;
display:block;
object-fit:cover;
}

@media(min-width:1200px){
.bs3-header{
    padding: 0px 5rem;
}
}

@media(max-width:1199px){
.bs3-header{
    padding: 0px 3rem;
}
}

@media(max-width:900px){
.bs3-title{
font-size:30px;
}
.bs3-header{
    padding: 0px 2rem;
}
.bs3-popup-title,
.bs3-popup-price{
font-size:14px;
}
}

@media(max-width:640px){
.bs3-container{
    margin-left: 1.5rem;
    margin-right: 1.5rem;
}
.bs3-card{
padding:0px;
}
.bs3-header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:30px;
    padding: 0px 1.5rem;
}

.bs3-navigation {
    display: flex;
    gap: 10px;
    justify-content: flex-end;
    margin-top: 10px;
    padding: 0 1.5rem;
}

.bs3-button {
    background: #ff7a00;
    color: white;
    padding: 16px 32px;
    text-decoration: none;
    font-weight: 400;
    transition: background .3s ease;
    line-height: 14px;
    font-size: 14px;
}

.bs3-product-popup{
padding:8px 10px;
}

.bs3-gallery-prev,
.bs3-gallery-next{
width:25px;
height:25px;
}

.bs3-gallery-prev svg,
.bs3-gallery-next svg {
width: 14px;
height: 14px;
}

.bs3-gallery-prev{
left:15px;
}

.bs3-gallery-next{
right:15px;
}

.bs3-prev,
.bs3-next{
width:50px;
height:50px;
}

.bs3-prev svg,
.bs3-next svg {
width: 20px;
height: 20px;
}
}

</style>

<section id="best-sellers-{{ section.id }}">

<div class="bs3-container">

<div class="bs3-header">

<h2 class="bs3-title">
{{ section.settings.heading }}
</h2>

{% if section.settings.button_link != blank %}
<a class="bs3-button" href="{{ section.settings.button_link }}">
{{ section.settings.button_label }}
</a>
{% endif %}

</div>

<div class="swiper bs3-swiper-{{ section.id }}">

<div class="swiper-wrapper">

{% if section.settings.collection != blank %}

{% for product in section.settings.collection.products limit: section.settings.products_to_show %}

<div class="swiper-slide">

<div class="bs3-card">

<!-- Custom Badge Logic with Tags -->
{% if product.tags contains 'join-waitlist' %}
<span class="bs3-badge">Join the waitlist</span>

{% elsif product.tags contains 'trending' %}
<span class="bs3-badge">Trending</span>

{% elsif product.tags contains 'new-in' %}
<span class="bs3-badge">New In</span>

{% elsif product.tags contains 'selling-fast' %}
<span class="bs3-badge">Selling Fast</span>

{% elsif product.tags contains 'top-selling' %}
<span class="bs3-badge">Top Selling</span>

{% elsif product.available == false %}
<span class="bs3-badge">Sold Out</span>

{% elsif product.compare_at_price > product.price %}
<span class="bs3-badge">Sale</span>

{% endif %}

<a href="{{ product.url }}" class="bs3-product-link">

<!-- Product Gallery Swiper -->
<div class="bs3-product-gallery swiper product-gallery-{{ section.id }}-{{ forloop.index }}" data-product-gallery>
<div class="swiper-wrapper">
{% if product.images.size > 0 %}
{% for image in product.images %}
<div class="swiper-slide">
<img 
src="{{ image.src | image_url: width:600, height:600, crop: 'center' }}"
alt="{{ image.alt | escape }}"
loading="lazy"
width="600"
height="600"
>
</div>
{% endfor %}
{% else %}
<div class="swiper-slide">
<img 
src="{{ product.featured_image | image_url: width:600, height:600, crop: 'center' }}"
alt="{{ product.title }}"
loading="lazy"
width="600"
height="600"
>
</div>
{% endif %}
</div>

<!-- Gallery Navigation Buttons - REMOVED -->
</div>

<!-- Hover Popup with Title and Price -->
<div class="bs3-product-popup">
<h4 class="bs3-popup-title">{{ product.title }}</h4>
<span class="bs3-popup-price">{{ product.price | money }}</span>
</div>

</a>

</div>

</div>

{% endfor %}

{% else %}

{% for i in (1..10) %}

<div class="swiper-slide">

<div class="bs3-card">

<!-- Sample badges for placeholder products -->
{% if i == 1 %}
<span class="bs3-badge">Join the waitlist</span>
{% elsif i == 2 %}
<span class="bs3-badge">Trending</span>
{% elsif i == 3 %}
<span class="bs3-badge">New In</span>
{% elsif i == 4 %}
<span class="bs3-badge">Selling Fast</span>
{% elsif i == 5 %}
<span class="bs3-badge">Top Selling</span>
{% elsif i == 6 %}
<span class="bs3-badge">Sold Out</span>
{% elsif i == 7 %}
<span class="bs3-badge">Sale</span>
{% else %}
<span class="bs3-badge">Selling Fast</span>
{% endif %}

<a href="#" class="bs3-product-link">

<!-- Product Gallery Swiper for placeholder -->
<div class="bs3-product-gallery swiper product-gallery-{{ section.id }}-placeholder-{{ forloop.index }}" data-product-gallery>
<div class="swiper-wrapper">
<div class="swiper-slide">
{{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
</div>
<div class="swiper-slide">
{{ 'product-2' | placeholder_svg_tag: 'placeholder-svg' }}
</div>
<div class="swiper-slide">
{{ 'product-3' | placeholder_svg_tag: 'placeholder-svg' }}
</div>
</div>

<!-- Gallery Navigation Buttons - REMOVED -->
</div>

<!-- Hover Popup with Title and Price -->
<div class="bs3-product-popup">
<h4 class="bs3-popup-title">Sample Product</h4>
<span class="bs3-popup-price">$29.00</span>
</div>

</a>

</div>

</div>

{% endfor %}

{% endif %}

</div>

</div>

<div class="bs3-navigation">
  
<div class="bs3-prev prev-{{ section.id }}">
<svg viewBox="0 0 24 24" width="24" height="24" fill="none">
<path d="M15 6L9 12L15 18"
stroke="currentColor"
stroke-width="4"
stroke-linecap="round"
stroke-linejoin="round"/>
</svg>
</div>

<div class="bs3-next next-{{ section.id }}">
<svg viewBox="0 0 24 24" width="24" height="24" fill="none">
<path d="M9 6L15 12L9 18"
stroke="currentColor"
stroke-width="4"
stroke-linecap="round"
stroke-linejoin="round"/>
</svg>
</div>

</div>

</div>

</section>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
(function() {
  // Store section ID for this instance
  const sectionId = '{{ section.id }}';
  const swiperSelector = `.bs3-swiper-${sectionId}`;
  const prevSelector = `.prev-${sectionId}`;
  const nextSelector = `.next-${sectionId}`;
  
  function initSlider3() {
    const swiperElement = document.querySelector(swiperSelector);
    if (!swiperElement) return false;
    
    // Destroy existing Swiper instance if it exists
    if (swiperElement.swiper) {
      swiperElement.swiper.destroy(true, true);
    }
    
    // Get window width to determine slides per view
    const windowWidth = window.innerWidth;
    let slidesPerView = 5; // Default for desktop - max 5 cards
    
    if (windowWidth < 480) {
      slidesPerView = 2; // Mobile - exactly 2 cards
    } else if (windowWidth < 768) {
      slidesPerView = 2; // Small tablet - 2 cards
    } else if (windowWidth < 1024) {
      slidesPerView = 3; // Tablet - 3 cards
    } else if (windowWidth < 1200) {
      slidesPerView = 4; // Small desktop - 4 cards
    } else {
      slidesPerView = 5; // Large desktop - 5 cards max
    }
    
    // Initialize new Swiper
    const swiper = new Swiper(swiperSelector, {
      slidesPerView: slidesPerView,
      spaceBetween: 0,
      loop: true,
      navigation: {
        nextEl: nextSelector,
        prevEl: prevSelector,
      },
      on: {
        init: function() {
          // Force update after initialization
          this.update();
        },
        resize: function() {
          // Update on window resize
          const width = window.innerWidth;
          let newSlidesPerView = 5;
          
          if (width < 480) {
            newSlidesPerView = 2;
          } else if (width < 768) {
            newSlidesPerView = 2;
          } else if (width < 1024) {
            newSlidesPerView = 3;
          } else if (width < 1200) {
            newSlidesPerView = 4;
          } else {
            newSlidesPerView = 5;
          }
          
          this.params.slidesPerView = newSlidesPerView;
          this.update();
        }
      }
    });
    
    return true;
  }

  // Initialize main slider with multiple attempts
  function initWithRetry() {
    // Try multiple times to ensure it works
    setTimeout(initSlider3, 100);
    setTimeout(initSlider3, 300);
    setTimeout(initSlider3, 500);
  }

  // Run on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initWithRetry);
  } else {
    initWithRetry();
  }

  // Re-initialize when Shopify theme editor makes changes
  document.addEventListener('shopify:section:load', function(e) {
    if (e.detail && e.detail.sectionId === sectionId) {
      setTimeout(initSlider3, 200);
      setTimeout(initSlider3, 400);
    }
  });

  document.addEventListener('shopify:section:select', function(e) {
    if (e.detail && e.detail.sectionId === sectionId) {
      setTimeout(initSlider3, 200);
      setTimeout(initSlider3, 400);
    }
  });

  // Listen for window resize
  window.addEventListener('resize', function() {
    setTimeout(initSlider3, 100);
  });

})();
</script>

{% schema %}
{
"name": "Collection Slider 3",
"settings": [
{
"type": "text",
"id": "heading",
"label": "Heading",
"default": "Best Sellers"
},
{
"type": "collection",
"id": "collection",
"label": "Collection"
},
{
"type": "range",
"id": "products_to_show",
"label": "Products to show",
"min": 4,
"max": 20,
"step": 1,
"default": 10
},
{
"type": "text",
"id": "button_label",
"label": "Button Label",
"default": "Shop all"
},
{
"type": "url",
"id": "button_link",
"label": "Button Link"
}
],
"presets": [
{
"name": "Collection Slider 3"
}
]
}
{% endschema %}