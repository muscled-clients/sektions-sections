<style>

/* TRIGGER BUTTON */

.dynamic-offer-trigger{
position:fixed;
z-index:999;
background:{{ section.settings.trigger_color }};
color:#fff;
border:none;
padding:12px 24px;
cursor:pointer;
}

/* vertical */

{% if section.settings.trigger_vertical == "top" %}
.dynamic-offer-trigger{ top:20px; }
{% else %}
.dynamic-offer-trigger{ bottom:20px; }
{% endif %}

/* horizontal */

{% case section.settings.trigger_horizontal %}
{% when "left" %}
.dynamic-offer-trigger{ left:20px; }

{% when "center" %}
.dynamic-offer-trigger{
left:50%;
transform:translateX(-50%);
}

{% when "right" %}
.dynamic-offer-trigger{ right:20px; }
{% endcase %}



/* POPUP */

.dynamic-popup{
position:fixed;
top:0;
left:0;
width:100%;
height:100vh;
display:none;
align-items:center;
justify-content:center;
background:linear-gradient(
180deg,
{{ section.settings.bg_color_1 }} 0%,
{{ section.settings.bg_color_2 }} 70%,
{{ section.settings.bg_color_3 }} 100%
);
z-index:9999;
padding:10px;
}


/* CLOSE */

.popup-close{
position:absolute;
top:30px;
left:30px;
font-size:26px;
cursor:pointer;
color:{{ section.settings.close_color }};
}


/* WRAPPER */

.popup-wrapper{
width:1200px;
max-width:95%;
display:flex;
align-items:center;
gap:60px;
}


/* LEFT */

.popup-left{
flex:1;

{% if section.settings.text_align == "center" %}
text-align:center;
{% else %}
text-align:left;
{% endif %}

}


/* TITLE */

.popup-title{
font-size:56px;
font-weight:700;
line-height:1.1;

background:linear-gradient(
90deg,
{{ section.settings.heading_color_1 }},
{{ section.settings.heading_color_2 }}
);

-webkit-background-clip:text;
-webkit-text-fill-color:transparent;

margin-bottom:20px;
}


/* DESCRIPTION */

.popup-desc{
font-size:16px;
color:{{ section.settings.text_color }};
margin-bottom:30px;
}


/* INPUT */

.popup-input{
width:420px;
max-width:100%;
padding:16px;
border:1px solid {{ section.settings.input_border }};
margin-bottom:20px;
font-size:15px;
}


/* BUTTON */

.popup-btn{
background:linear-gradient(
90deg,
{{ section.settings.button_color_1 }},
{{ section.settings.button_color_2 }}
);

border:none;
padding:14px 34px;
color:{{ section.settings.button_text_color }};
font-size:14px;
cursor:pointer;
}


/* IMAGE */

.popup-right{
flex:1;
}

.popup-right img{
width:100%;
height:auto;
}


/* MOBILE */

@media(max-width:900px){

.popup-wrapper{
flex-direction:column;
text-align:center;
}

.popup-title{
font-size:36px;
}

.popup-input{
width:100%;
}

}

</style>



<button class="dynamic-offer-trigger" onclick="openDynamicPopup()">
{{ section.settings.trigger_text }}
</button>



<div class="dynamic-popup" id="dynamicPopup">

<div class="popup-close" onclick="closeDynamicPopup()">✕</div>

<div class="popup-wrapper">


<div class="popup-left">

<h2 class="popup-title">
{{ section.settings.heading }}
</h2>

<p class="popup-desc">
{{ section.settings.description }}
</p>

<input
class="popup-input"
type="email"
placeholder="{{ section.settings.placeholder }}"
>

<br>

<button class="popup-btn">
{{ section.settings.button_text }}
</button>

</div>



<div class="popup-right">

{% if section.settings.popup_image != blank %}
<img src="{{ section.settings.popup_image | image_url: width:900 }}">
{% endif %}

</div>


</div>

</div>



<script>

function openDynamicPopup(){
document.getElementById("dynamicPopup").style.display="flex";
}

function closeDynamicPopup(){
document.getElementById("dynamicPopup").style.display="none";
document.querySelector(".dynamic-offer-trigger").style.display="none";
}

</script>



{% schema %}
{
"name":"Claim Offer Popup",
"settings":[

{
"type":"text",
"id":"trigger_text",
"label":"Trigger Button Text",
"default":"Claim offer ✕"
},

{
"type":"color",
"id":"trigger_color",
"label":"Trigger Button Color",
"default":"#ff00cc"
},

{
"type":"select",
"id":"trigger_vertical",
"label":"Trigger Vertical Position",
"default":"top",
"options":[
{"value":"top","label":"Top"},
{"value":"bottom","label":"Bottom"}
]
},

{
"type":"select",
"id":"trigger_horizontal",
"label":"Trigger Horizontal Position",
"default":"left",
"options":[
{"value":"left","label":"Left"},
{"value":"center","label":"Center"},
{"value":"right","label":"Right"}
]
},

{
"type":"select",
"id":"text_align",
"label":"Text Alignment",
"default":"center",
"options":[
{"value":"left","label":"Left"},
{"value":"center","label":"Center"}
]
},

{
"type":"text",
"id":"heading",
"label":"Heading",
"default":"Unlock your optimal state"
},

{
"type":"color",
"id":"heading_color_1",
"label":"Heading Gradient Color 1",
"default":"#ff2ea6"
},

{
"type":"color",
"id":"heading_color_2",
"label":"Heading Gradient Color 2",
"default":"#8a4cff"
},

{
"type":"textarea",
"id":"description",
"label":"Description",
"default":"Fuel your focus with the galaxy's most potent brand. Get 15% off your first journey."
},

{
"type":"text",
"id":"placeholder",
"label":"Input Placeholder",
"default":"Your email"
},

{
"type":"color",
"id":"input_border",
"label":"Input Border Color",
"default":"#dddddd"
},

{
"type":"text",
"id":"button_text",
"label":"Button Text",
"default":"GET LIFT OFF"
},

{
"type":"color",
"id":"button_color_1",
"label":"Button Gradient Color 1",
"default":"#ff00cc"
},

{
"type":"color",
"id":"button_color_2",
"label":"Button Gradient Color 2",
"default":"#ff2ebf"
},

{
"type":"color",
"id":"button_text_color",
"label":"Button Text Color",
"default":"#ffffff"
},

{
"type":"color",
"id":"bg_color_1",
"label":"Background Gradient 1",
"default":"#f5f1f7"
},

{
"type":"color",
"id":"bg_color_2",
"label":"Background Gradient 2",
"default":"#f5f1f7"
},

{
"type":"color",
"id":"bg_color_3",
"label":"Background Gradient 3",
"default":"#cfa3eb"
},

{
"type":"color",
"id":"text_color",
"label":"Description Text Color",
"default":"#666666"
},

{
"type":"color",
"id":"close_color",
"label":"Close Icon Color",
"default":"#ff00cc"
},

{
"type":"image_picker",
"id":"popup_image",
"label":"Popup Image"
}

],

"presets":[
{
"name":"Claim Offer Popup"
}
]
}
{% endschema %}