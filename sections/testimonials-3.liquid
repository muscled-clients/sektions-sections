<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

{%- style -%}
  @font-face {
    font-family: Playfair;
    font-weight: 400;
    font-style: italic;
    font-display: swap;
    src: url("//section.store/cdn/fonts/playfair/playfair_i4.0bcdf3dceafc622b1755846b2873d853bb8fbcda.woff2") format("woff2"),
         url("//section.store/cdn/fonts/playfair/playfair_i4.5d53824f4667b390c647a6b50639c9447f626884.woff") format("woff");
  }

  @font-face {
    font-family: Playfair;
    font-weight: 700;
    font-style: normal;
    font-display: swap;
    src: url("//section.store/cdn/fonts/playfair/playfair_n7.fd4c4220f2fc9c5c6a45138ba4af9253dd0cd81c.woff2") format("woff2"),
         url("//section.store/cdn/fonts/playfair/playfair_n7.20c07d574f5caf81c63628abda76abb05428ec3f.woff") format("woff");
  }

  @font-face {
    font-family: Playfair;
    font-weight: 400;
    font-style: normal;
    font-display: swap;
    src: url("//section.store/cdn/fonts/playfair/playfair_n4.13d3b411a6dc3a2e96e8bdc666266166a065c857.woff2") format("woff2"),
         url("//section.store/cdn/fonts/playfair/playfair_n4.eccd5edeb74430cf755be464a2af96a922b8b9e0.woff") format("woff");
  }

  @font-face {
    font-family: Montserrat;
    font-weight: 100;
    font-style: normal;
    font-display: swap;
    src: url("//section.store/cdn/fonts/montserrat/montserrat_n1.2f0714cbd41857ba00d5d4fafdce92c40aadb8e6.woff2") format("woff2"),
         url("//section.store/cdn/fonts/montserrat/montserrat_n1.7bec1bf4c4d0f77c37dc95cf9616413eceba9082.woff") format("woff");
  }

  @font-face {
    font-family: "Josefin Sans";
    font-weight: 400;
    font-style: normal;
    font-display: swap;
    src: url("//section.store/cdn/fonts/josefin_sans/josefinsans_n4.70f7efd699799949e6d9f99bc20843a2c86a2e0f.woff2") format("woff2"),
         url("//section.store/cdn/fonts/josefin_sans/josefinsans_n4.35d308a1bdf56e5556bc2ac79702c721e4e2e983.woff") format("woff");
  }

  .section-{{ section.id }} {
    border-top: solid {{ section.settings.border_color }} {{ section.settings.border_size }}px;
    border-bottom: solid {{ section.settings.border_color }} {{ section.settings.border_size }}px;
    margin-top: {{ section.settings.margin_top_mobile }}px;
    margin-bottom: {{ section.settings.margin_bottom_mobile }}px;
    margin-left: {{ section.settings.margin_left_mobile }}rem;
    margin-right: {{ section.settings.margin_right_mobile }}rem;    
    border-radius: {{ section.settings.border_radius_mobile }}px;
    overflow: hidden;    
  }
  
  .section-{{ section.id }}-settings {
    margin: 0 auto;
    border-radius: {{ section.settings.border_radius_mobile }}px; 
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    padding-left: {{ section.settings.padding_left_mobile }}rem;
    padding-right: {{ section.settings.padding_right_mobile }}rem;
    position: relative;
    max-width: {{ section.settings.section_max_width }}px;
  }

  .testimonials-body-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    gap: 30px;
  }

  .testimonials-content-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .testimonials-slider-body-{{ section.id }} {
    position: relative;
    display: grid;  
    grid-template-columns: 1fr; 
    gap: 20px;
  }

  @media(max-width: 1024px) {
    .testimonials-slider-body-{{ section.id }} {      
      margin-left: -{{ section.settings.padding_left_mobile }}rem !important;
      margin-right: -{{ section.settings.padding_right_mobile }}rem !important;
      padding-left: {{ section.settings.padding_left_mobile }}rem !important;
      padding-right: {{ section.settings.padding_right_mobile }}rem !important;
    }

    .testimonials-slider-{{ section.id }},
    .testimonials-slider-{{ section.id }} .swiper-wrapper {
      overflow: visible !important;
    }

    .testimonials-slider-{{ section.id }} .swiper-wrapper {
      align-items: stretch !important;
    }

    .testimonials-slide-{{ section.id }} {
      height: auto !important;
    }
  }

  .testimonials-slide-{{ section.id }} {
    opacity: {{ section.settings.inactive_opacity }} !important;
    transition: all 0.25s ease 0s !important;
  }

  .testimonials-slide-{{ section.id }}.swiper-slide-active {
    opacity: 1 !important;
    transition: all 0.25s ease 0s !important;
  }

  .testimonials-slider-wrapper-{{ section.id }} {
    min-width: 0; 
    display: grid;  
    width: 100%;
  }

  .testimonials-slider-{{ section.id }} {
    min-width: 0;
    width: 100%; 
    min-height: 0;
  }

  .testimonials-btn-prev-{{ section.id }},
  .testimonials-btn-next-{{ section.id }} {   
    display: flex;
    flex-shrink: 0;    
    z-index: 2;
    width: {{ section.settings.nav_size_mobile }}px;
    height: {{ section.settings.nav_size_mobile }}px;
    border: {{ section.settings.nav_border_size }}px solid {{ section.settings.nav_border_color }};
    border-radius: 100px;
    background: transparent;
    background: {{ section.settings.nav_bg_color }};
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease 0s;
    cursor: pointer;
    -webkit-appearance: none;
  }

  .testimonials-btn-prev-{{ section.id }} .animate-icon,
  .testimonials-btn-next-{{ section.id }} .animate-icon {
    pointer-events: none;
    place-items: center;
    display: grid;
  }

  .testimonials-btn-prev-{{ section.id }} .animate-icon:before,
  .testimonials-btn-next-{{ section.id }} .animate-icon:before {
    content: "";
    grid-area: 1 / -1;
    transition: all .2s ease;
    width: 8px;
    height: 8px;
    transform: rotate(calc(1 * 45deg));
    box-sizing: border-box;
    border-style: solid;
    border: 0px;
    border-right: 2px solid {{ section.settings.nav_arrow_color }};
    border-top: 2px solid {{ section.settings.nav_arrow_color }};
    position: relative;
    left: -1px;
  }

  .testimonials-btn-prev-{{ section.id }} .animate-icon:before {
    left: unset;
    right: -1px;
    border-right: 0px;
    border-top: 0px;
    border-bottom: 2px solid {{ section.settings.nav_arrow_color }};
    border-left: 2px solid {{ section.settings.nav_arrow_color }};
  }

  .testimonials-btn-prev-{{ section.id }} .animate-icon:after,
  .testimonials-btn-next-{{ section.id }} .animate-icon:after {
    content: "";
    grid-area: 1 / -1;
    transition: all .2s ease;
    width: 7.7px;
    height: 1.6px;
    transform-origin: center;
    opacity: 0;
    background: {{ section.settings.nav_arrow_color }};
    transform: scaleX(.5);
  }

  .testimonials-btn-prev-{{ section.id }} span,
  .testimonials-btn-next-{{ section.id }} span {
    color: {{ section.settings.nav_arrow_color }};
  }

  .testimonials-btn-prev-{{ section.id }}.swiper-button-disabled,
  .testimonials-btn-next-{{ section.id }}.swiper-button-disabled {
    opacity: 0.5;
  }

  .testimonials-btn-prev-{{ section.id }}.swiper-button-lock,
  .testimonials-btn-next-{{ section.id }}.swiper-button-lock {
    opacity: 0;
    pointer-events: none;
  }

  .testimonials-btn-prev-{{ section.id }}:hover,
  .testimonials-btn-next-{{ section.id }}:hover {
    transition: all 0.3s ease 0s;
    border: {{ section.settings.nav_hover_border_size }}px solid {{ section.settings.nav_hover_border_color }};
    background: {{ section.settings.nav_hover_bg_color }};
  }

.testimonials-btn-prev-{{ section.id }}:hover .animate-icon,
.testimonials-btn-next-{{ section.id }}:hover .animate-icon {
  color: {{ section.settings.nav_hover_arrow_color }};
}

.testimonials-btn-prev-{{ section.id }}:hover .animate-icon:before,
.testimonials-btn-next-{{ section.id }}:hover .animate-icon:before {
  border-right-color: {{ section.settings.nav_hover_arrow_color }};
  border-top-color: {{ section.settings.nav_hover_arrow_color }};
}

.testimonials-btn-prev-{{ section.id }}:hover .animate-icon:before {
  border-bottom-color: {{ section.settings.nav_hover_arrow_color }};
  border-left-color: {{ section.settings.nav_hover_arrow_color }};
  border-right-color: transparent;
  border-top-color: transparent;
}

.testimonials-btn-prev-{{ section.id }}:hover .animate-icon:after,
.testimonials-btn-next-{{ section.id }}:hover .animate-icon:after {
  background: {{ section.settings.nav_hover_arrow_color }};
}

  .testimonials-card-{{ section.id }} {   
    border: {{ section.settings.card_border_size }}px solid {{ section.settings.card_border_color }};
    border-radius: {{ section.settings.card_border_radius }}px;
    background-color: {{ section.settings.card_bg_color }};
    display: flex;
    justify-content: space-between;
    text-decoration: none;
    overflow: hidden;
    height: 100%;
  }

  .testimonials-card-{{ section.id }} .testimonials-card-content-{{ section.id }} {
    flex: 1 0;
    box-sizing: border-box;
    padding: {{ section.settings.card_padding_vertical_mobile }}px {{ section.settings.card_padding_horizontal_mobile }}px;
    display: flex;
    justify-content: space-between;
    flex-direction: column;
  }

  .testimonials-author-text-{{ section.id }} {    
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-size: {{ section.settings.author_size_mobile }}px;
    color: {{ section.settings.author_color }};
    line-height: 150%;
    text-transform: unset;
    word-wrap: break-word;
    text-align: center;
    font-weight: {{ section.settings.author_weight }};
    font-family: Playfair, serif;
    font-weight: 700;
    font-style: normal;
  }

  .testimonials-text-{{ section.id }} {
    margin-top: 0px;
    text-align: center;
    text-wrap: wrap;
  }

  .testimonials-text-{{ section.id }} * {
    margin: 0;
    font-size: {{ section.settings.text_size_mobile }}px;
    color: {{ section.settings.text_color }};
    line-height: {{ section.settings.text_line_height }}%;
    text-transform: unset;
    text-decoration: none;
    font-family: Playfair, serif;
    font-weight: 400;
    font-style: italic;
  }

  .testimonials-card-bottom-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 15px;
    justify-content: center;
    margin-top: {{ section.settings.bottom_margin_mobile }}px;
  }

  .testimonials-stars-{{ section.id }} {
    display: flex;
    align-items: end;
    justify-content: center;
    gap: 2px;
    margin-top: 8px;
  }

  .testimonials-stars-{{ section.id }} svg,
  .testimonials-stars-{{ section.id }} img {
    display: block;
    width: {{ section.settings.star_size_mobile }}px;
    height: {{ section.settings.star_size_mobile }}px;
    object-fit: cover;
  }

  .testimonials-author-image-{{ section.id }} {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    color: {{ section.settings.author_image_text_color }};
    background-color: {{ section.settings.author_image_bg }};
    border: {{ section.settings.author_border_size }}px solid {{ section.settings.author_border_color }};
    border-radius: {{ section.settings.author_border_radius }}px;
    overflow: hidden;
    aspect-ratio: 1/1;
    width: {{ section.settings.author_image_size_mobile }}px;
  }

  .testimonials-author-image-{{ section.id }} img,
  .testimonials-author-image-{{ section.id }} svg {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonials-author-image-{{ section.id }} svg {
    background-color: #AFAFAF;
  }
  
  .testimonials-navigation-{{ section.id }} {
    flex-direction: row;
    justify-content: center;
    gap: 8px;
    display: flex;
  }

  .testimonials-caption-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 12px;        
    overflow: hidden;
    justify-content: center;
    margin-top: {{ section.settings.caption_margin_mobile }}px;
    text-align: center;
    z-index: 2;        
  }

  .testimonials-caption-{{ section.id }} * {          
    margin: 0;            
    font-size: {{ section.settings.caption_size_mobile }}px;
    color: {{ section.settings.caption_color }};
    line-height: 130%;
    text-transform: unset;
    text-decoration: none;
    word-break: break-word;
  }          

  .testimonials-heading-{{ section.id }} {
    position: relative;
    text-align: center;
    margin-top: {{ section.settings.heading_margin_mobile }}px;
  }
      
  .testimonials-heading-{{ section.id }} * {
    margin: 0;
    font-size: {{ section.settings.heading_size_mobile }}px;
    color: {{ section.settings.heading_color }};
    line-height: 120%;
    text-transform: unset;
    word-break: break-word;
    font-weight: {{ section.settings.heading_weight }};
    font-family: Playfair, serif;
    font-weight: 400;
    font-style: normal;
  }

  .testimonials-heading-{{ section.id }} strong {
    color: {{ section.settings.heading_highlight_color }};
    font-family: Playfair, serif;
    font-weight: 400;
    font-style: normal;
  }

  .testimonials-text-block-{{ section.id }} {
    position: relative;
    text-align: center;
    margin-top: {{ section.settings.text_margin_mobile }}px;
  }
      
  .testimonials-text-block-{{ section.id }} * {
    margin: 0;
    font-size: {{ section.settings.text_block_size_mobile }}px;
    color: {{ section.settings.text_block_color }};
    line-height: 160%;
    text-transform: unset;
  }

  .testimonials-button-{{ section.id }} {
    position: relative;
    text-decoration: none;
    margin-top: {{ section.settings.button_margin_mobile }}px !important;
    {% if section.settings.button_full_width_mobile %}width: 100%;{% endif %}
  }
  
  .testimonials-button-inner-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    {% unless section.settings.button_full_width_mobile %}max-width: 100%;{% endunless %}
    gap: 10px;
    width: 100%;
    margin: 0;          
    font-size: {{ section.settings.button_text_size_mobile }}px;
    color: {{ section.settings.button_text_color }};
    line-height: 100%;
    text-align: center;
    text-transform: unset;
    text-decoration: none;
    padding: {{ section.settings.button_padding_vertical_mobile }}px {{ section.settings.button_padding_horizontal_mobile }}px;
    border-radius: {{ section.settings.button_border_radius }}px;
    transition: all 0.25s ease 0s;
    background-color: transparent;
    border: {{ section.settings.button_border_size }}px solid {{ section.settings.button_border_color }};
    cursor: pointer;
    {% if section.settings.button_effect_shine %}position: relative; overflow: hidden;{% endif %}
    {% if section.settings.button_gradient_enabled %}
      background: linear-gradient(145deg, {{ section.settings.button_gradient_color_1 }}, {{ section.settings.button_gradient_color_2 }});
      box-shadow: 0 8px 16px {{ section.settings.button_shadow_color | default: '#0000004d' }}, 0 4px 8px {{ section.settings.button_shadow_color | default: '#00000033' }}, inset 0 1px 0 {{ section.settings.button_highlight_color | default: '#ffffff1a' }}, inset 0 -1px 0 {{ section.settings.button_shadow_dark_color | default: '#0000004d' }};
      backdrop-filter: saturate(1.05);
    {% else %}
      background: {{ section.settings.button_bg_color }};
    {% endif %}
  }

  {% if section.settings.button_effect_shine %}
    .testimonials-button-inner-{{ section.id }}::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, {{ section.settings.button_shine_color | default: 'rgba(255, 255, 255, 0.1)' }}, transparent);
      transition: left 0.6s ease;
    }

    .testimonials-button-inner-{{ section.id }}:hover::before {
      left: 100%;
    }
  {% endif %}

  .testimonials-button-inner-{{ section.id }}:hover {
    color: {{ section.settings.button_hover_text_color }};
    {% if section.settings.button_gradient_enabled %}
      background: linear-gradient(145deg, {{ section.settings.button_gradient_color_1 }}, {{ section.settings.button_gradient_color_2 }});
      transform: translateY(-2px);
      box-shadow: 0 12px 24px {{ section.settings.button_hover_shadow_color | default: '#00000066' }}, 0 6px 12px {{ section.settings.button_hover_shadow_dark_color | default: '#0000004d' }}, inset 0 1px 0 {{ section.settings.button_hover_highlight_color | default: '#ffffff26' }}, inset 0 -1px 0 {{ section.settings.button_hover_shadow_dark_color | default: '#00000066' }};
    {% else %}
      background: {{ section.settings.button_hover_bg_color }};
      border: {{ section.settings.button_hover_border_size }}px solid {{ section.settings.button_hover_border_color }};
    {% endif %}
  }

  .testimonials-button-inner-{{ section.id }}:active {
    transform: translateY(1px);
    filter: brightness(1.00208);
    box-shadow: 0 4px 8px {{ section.settings.button_active_shadow_color | default: '#0000004d' }}, 0 2px 4px {{ section.settings.button_active_shadow_dark_color | default: '#00000033' }}, inset 0 1px 0 {{ section.settings.button_active_highlight_color | default: '#ffffff0d' }}, inset 0 -1px 0 {{ section.settings.button_active_shadow_dark_color | default: '#00000033' }};
  }

  .testimonials-button-inner-{{ section.id }} svg {
    width: 14px !important;
    height: 14px !important;
    background: transparent;
    min-height: auto !important;
  }

  .testimonials-button-inner-{{ section.id }} svg path {
    fill: {{ section.settings.button_text_color }};
    transition: all 0.25s ease 0s;
  }

  .testimonials-button-inner-{{ section.id }}:hover svg path {
    fill: {{ section.settings.button_hover_text_color }};
    transition: all 0.25s ease 0s;
  }

  @media(min-width: 1024px) {
    .section-{{ section.id }} {
      margin-top: {{ section.settings.margin_top_desktop }}px;
      margin-bottom: {{ section.settings.margin_bottom_desktop }}px;         
      margin-left: {{ section.settings.margin_left_desktop }}rem;
      margin-right: {{ section.settings.margin_right_desktop }}rem;    
      border-radius: {{ section.settings.border_radius_desktop }}px;
    }
    
    .section-{{ section.id }}-settings {
      padding: 0 5rem;
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
      padding-left: {{ section.settings.padding_left_desktop }}rem;
      padding-right: {{ section.settings.padding_right_desktop }}rem;
    }

    .testimonials-body-{{ section.id }} {
      grid-template-columns: 1fr 1fr;
    }

    .testimonials-content-{{ section.id }} {
      align-items: center;
    }

    .testimonials-slider-body-{{ section.id }} {
      display: flex; 
      align-items: stretch; 
      grid-template-columns: unset;  
      margin-top: -{{ section.settings.padding_top_desktop }}px;
      margin-bottom: -{{ section.settings.padding_bottom_desktop }}px;
    }

    .testimonials-slider-wrapper-{{ section.id }} {
      flex: 1;
      height: 100%;
      overflow: hidden;
      position: relative;
    }

    .testimonials-slider-{{ section.id }} {
      height: 100% !important;
      width: 100%;
    }

    .testimonials-slider-{{ section.id }} .swiper-wrapper {
      height: 100%;
    }
    
    .testimonials-card-{{ section.id }} {
      height: 100%;
    }

    .testimonials-navigation-{{ section.id }} {
      flex-direction: column;
    }

    .testimonials-card-{{ section.id }} .testimonials-card-content-{{ section.id }} {
      padding: {{ section.settings.card_padding_vertical_desktop }}px {{ section.settings.card_padding_horizontal_desktop }}px;
    }

    .testimonials-author-text-{{ section.id }} {    
      justify-content: center;
      font-size: {{ section.settings.author_size_desktop }}px;
      text-align: center;
    }

    .testimonials-card-bottom-{{ section.id }} {
      margin-top: {{ section.settings.bottom_margin_desktop }}px;
      justify-content: center;
      flex-direction: row;
    }

    .testimonials-text-{{ section.id }} {
      margin-top: 0px;
      text-align: center;
    }

    .testimonials-text-{{ section.id }} * {
      font-size: {{ section.settings.text_size_desktop }}px;
    }

    .testimonials-stars-{{ section.id }} {
      justify-content: center;
      margin-top: 8px;
    }

    .testimonials-stars-{{ section.id }} svg,
    .testimonials-stars-{{ section.id }} img {
      width: {{ section.settings.star_size_desktop }}px;
      height: {{ section.settings.star_size_desktop }}px;
    }

    .testimonials-author-image-{{ section.id }} {
      width: {{ section.settings.author_image_size_desktop }}px;
    }

    .testimonials-btn-prev-{{ section.id }},
    .testimonials-btn-next-{{ section.id }} {
      transform: rotate(90deg);
      width: {{ section.settings.nav_size_desktop }}px;
      height: {{ section.settings.nav_size_desktop }}px;
      transition: all 0.25s ease 0s;
    }

    .testimonials-btn-prev-{{ section.id }} .animate-icon:before,
    .testimonials-btn-next-{{ section.id }} .animate-icon:before {
      width: 10px;
      height: 10px;
    }

    .testimonials-btn-prev-{{ section.id }} .animate-icon:after,
    .testimonials-btn-next-{{ section.id }} .animate-icon:after {
      width: 9.7px;
    }

    .testimonials-caption-{{ section.id }} {           
      justify-content: center;
      margin-top: {{ section.settings.caption_margin_desktop }}px;
      text-align: center;
    }

    .testimonials-caption-{{ section.id }} * {                
      font-size: {{ section.settings.caption_size_desktop }}px;
    }

    .testimonials-heading-{{ section.id }} {
      text-align: center;
      margin-top: {{ section.settings.heading_margin_desktop }}px;
    }
        
    .testimonials-heading-{{ section.id }} * {
      font-size: {{ section.settings.heading_size_desktop }}px;
    }

    .testimonials-text-block-{{ section.id }} {
      text-align: center;
      margin-top: {{ section.settings.text_margin_desktop }}px;
    }
        
    .testimonials-text-block-{{ section.id }} * {
      font-size: {{ section.settings.text_block_size_desktop }}px;
    }

    .testimonials-button-{{ section.id }} {
      margin-top: {{ section.settings.button_margin_desktop }}px !important;
      width: fit-content;
    }

    .testimonials-button-inner-{{ section.id }} {
      display: flex !important;
      max-width: fit-content;            
      padding: {{ section.settings.button_padding_vertical_desktop }}px {{ section.settings.button_padding_horizontal_desktop }}px;
      font-size: {{ section.settings.button_text_size_desktop }}px;
    }
  }

  .section-{{ section.id }}-settings {
    height: 100%;
  }

  .testimonials-slider-body-{{ section.id }} {
