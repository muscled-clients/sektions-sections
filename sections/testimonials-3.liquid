<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
  (function() {
    const sectionId = '{{ section.id }}';
    const sliderSelector = `.testimonials-slider-${sectionId}`;
    const nextBtn = `.testimonials-btn-next-${sectionId}`;
    const prevBtn = `.testimonials-btn-prev-${sectionId}`;
    
    let swiperInstance = null;
    
    const desktopMediaQuery = window.matchMedia('(min-width: 1024px)');

    function initSwiper() {
      const isDesktop = desktopMediaQuery.matches;

      if (swiperInstance) {
        swiperInstance.destroy(true, true);
        swiperInstance = null;
      }

      const sliderEl = document.querySelector(sliderSelector);
      if (sliderEl) {
        sliderEl.removeAttribute('style');
        const wrapper = sliderEl.querySelector('.swiper-wrapper');
        if (wrapper) wrapper.removeAttribute('style');
        const slides = sliderEl.querySelectorAll('.swiper-slide');
        slides.forEach(slide => slide.removeAttribute('style'));
      }

      let swiperConfig = {
        speed: {{ section.settings.slider_speed }},
        navigation: {
          nextEl: nextBtn,
          prevEl: prevBtn,
        },
        loop: {{ section.settings.enable_loop }},
      };

      if (isDesktop) {
        Object.assign(swiperConfig, {
          direction: 'vertical',
          slidesPerView: {{ section.settings.slides_per_view_desktop }},
          spaceBetween: {{ section.settings.space_between_desktop }},
          centeredSlides: {{ section.settings.centered_slides_desktop }},
          autoHeight: false 
        });
      } else {
        Object.assign(swiperConfig, {
          direction: 'horizontal',
          slidesPerView: {{ section.settings.slides_per_view_mobile }},
          spaceBetween: {{ section.settings.space_between_mobile }},
          centeredSlides: {{ section.settings.centered_slides_mobile }},
          autoHeight: {{ section.settings.auto_height_mobile }}
        });
      }

      swiperInstance = new Swiper(sliderSelector, swiperConfig);
    }

    document.addEventListener('DOMContentLoaded', initSwiper);

    try {
      desktopMediaQuery.addEventListener('change', initSwiper);
    } catch (e1) {
      try {
        desktopMediaQuery.addListener(initSwiper);
      } catch (e2) {
        console.error(e2);
      }
    }

    {% if request.design_mode %}
      document.addEventListener('shopify:section:load', initSwiper);
      document.addEventListener('shopify:section:unload', function() {
        if (swiperInstance) {
          swiperInstance.destroy(true, true);
        }
      });
      document.addEventListener('shopify:block:select', function() {
        setTimeout(initSwiper, 100);
      });
    {% endif %}
  })();
</script>

