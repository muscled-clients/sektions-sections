                                    <rect width="32" height="32" fill="{{ section.settings.star_fill }}"></rect>
                                    <g clip-path="url(#clip0_25_4)"><path d="M9.20283 27L16.001 21.807L22.7972 27L20.2018 18.596L27 13.403H18.5984L16.001 5L13.4037 13.403H5L11.7982 18.596L9.20283 27Z" fill="{{ section.settings.star_symbol_color }}"></path></g>
                                    <defs><clipPath id="clip0_25_4"><rect width="22" height="22" fill="{{ section.settings.star_symbol_color }}" transform="translate(5 5)"></rect></clipPath></defs>
                                  </svg>
                                {%- else -%}
