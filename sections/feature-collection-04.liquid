{% comment %}
  Featured Video Collection Section - Throw Rugs Collection
  Displays a video card with a product slider from a selected collection
{% endcomment %}

{{ 'https://fonts.googleapis.com/css2?family=Petrona:wght@400;700&family=Inter:wght@300;400&display=swap' | stylesheet_tag }}
{{ 'https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css' | stylesheet_tag }}

<style data-shopify="">
  {%- assign section_id = '#shopify-section-' | append: section.id -%}
  
  .section-{{ section.id }} {
    border-top: solid {{ section.settings.border_color }} {{ section.settings.border_width }}px;
    border-bottom: solid {{ section.settings.border_color }} {{ section.settings.border_width }}px;
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
    margin-left: {{ section.settings.margin_left_mobile }}rem;
    margin-right: {{ section.settings.margin_right_mobile }}rem;
    border-radius: {{ section.settings.border_radius_mobile }}px;
    overflow: hidden;
  }
  
  .section-{{ section.id }}-settings {
    margin: 0 auto;
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    max-width: {{ section.settings.max_width }}px;
  }

  .basics-refresh-top-{{ section.id }} {
    display: flex;
    width: 100%;
    justify-content: space-between;
    gap: 40px;
    align-items: center;
  }

  .basics-refresh-heading-{{ section.id }} {
    width: 100%;
    text-align: {{ section.settings.heading_alignment_mobile }};
  }
  
  .basics-refresh-heading-{{ section.id }} * {
    margin: 0px;
    font-size: {{ section.settings.heading_size_mobile }}px;
    line-height: 130%;
    color: {{ section.settings.heading_color }};
    text-transform: unset;
    word-break: break-word;
    font-weight: {{ section.settings.heading_weight }};
    font-family: {{ section.settings.heading_font }};
  }

  .basics-refresh-buttons-{{ section.id }} {
    display: flex;    
    align-items: center;
    gap: 10px;
    margin-left: auto;
  }

  .basics-refresh-buttons-mobile-{{ section.id }} {
    display: flex;
    justify-content: center;
  }

  .basics-refresh-buttons-desktop-{{ section.id }} {
    display: none;
  }

  .basics-refresh-btn-prev-{{ section.id }},
  .basics-refresh-btn-next-{{ section.id }} {
    display: flex;
    width: {{ section.settings.nav_button_size_mobile }}px;
    height: {{ section.settings.nav_button_size_mobile }}px;
    border: {{ section.settings.nav_button_border_width }}px solid {{ section.settings.nav_button_border_color }};
    border-radius: 100px;
    background: {{ section.settings.nav_button_bg_color }};
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease 0s;
    cursor: pointer;
    -webkit-appearance: none;
  }

  .basics-refresh-btn-prev-{{ section.id }} .animate-icon,
  .basics-refresh-btn-next-{{ section.id }} .animate-icon {
    pointer-events: none;
    place-items: center;
    display: grid;
    color: {{ section.settings.nav_button_icon_color }};
  }

  .basics-refresh-btn-prev-{{ section.id }} .animate-icon:before,
  .basics-refresh-btn-next-{{ section.id }} .animate-icon:before {
    content: "";
    grid-area: 1 / -1;
    transition: all .2s ease;
    width: 9px;
    height: 9px;
    transform: rotate(calc(1 * 45deg));
    box-sizing: border-box;
    border-style: solid;
    border: 0px;
    border-right: 2px solid currentColor;
    border-top: 2px solid currentColor;
    position: relative;
    left: -1px;
  }

  .basics-refresh-btn-prev-{{ section.id }} .animate-icon:before {
    left: unset;
    right: -1px;
    border-right: 0px;
    border-top: 0px;
    border-bottom: 2px solid currentColor;
    border-left: 2px solid currentColor;
  }

  .basics-refresh-btn-prev-{{ section.id }} .animate-icon:after,
  .basics-refresh-btn-next-{{ section.id }} .animate-icon:after {
    content: "";
    grid-area: 1 / -1;
    transition: all .2s ease;
    width: 8.7px;
    height: 1.6px;
    transform-origin: center;
    opacity: 0;
    background: currentColor;
    transform: scaleX(.5);
  }

  .basics-refresh-btn-prev-{{ section.id }} span,
  .basics-refresh-btn-next-{{ section.id }} span {
    color: {{ section.settings.nav_button_icon_color }};
  }

  .basics-refresh-btn-prev-{{ section.id }}.swiper-button-disabled,
  .basics-refresh-btn-next-{{ section.id }}.swiper-button-disabled {
    opacity: 0.5;
  }

  .basics-refresh-bottom-{{ section.id }} {
    display: flex;
    flex-direction: column-reverse;
    margin-top: {{ section.settings.bottom_margin_mobile }}px;
    gap: {{ section.settings.bottom_gap_mobile }}px;
  }
  
  .basics-refresh-media-{{ section.id }} {
    width: 100%;
    position: relative;
    border: {{ section.settings.media_border_width }}px solid {{ section.settings.media_border_color }};
    border-radius: {{ section.settings.media_border_radius_mobile }}px;
    overflow: hidden;
    aspect-ratio: {{ section.settings.media_aspect_ratio_mobile }};
  }

  .basics-refresh-media-{{ section.id }}::after {
    content: "";
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    z-index: 1;
    background-color: {{ section.settings.media_overlay_color }};
  }

  .basics-refresh-media-{{ section.id }} img,
  .basics-refresh-media-{{ section.id }} svg {
    border: 0px;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .basics-refresh-media-{{ section.id }} svg {
    background-color: #AFAFAF
  }

  .basics-refresh-media-content-{{ section.id }} {
    position: absolute;
    display: flex;
    height: 100%;
    width: 100%;
    top: 0;
    left: 0;
    flex-direction: column;
    justify-content: space-between;
    gap: 20px;
    z-index: 2;
    padding: 24px 16px;
  }

  .basics-refresh-media-top-{{ section.id }} {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 20px;
  }

  .basics-refresh-media-badge-{{ section.id }} {
    margin: 0px;
    max-width: fit-content;
    padding: {{ section.settings.badge_padding_mobile }}px {{ section.settings.badge_padding_mobile }}px;
    background-color: {{ section.settings.badge_bg_color }};
    border-radius: {{ section.settings.badge_border_radius_mobile }}px;
    font-size: {{ section.settings.badge_size_mobile }}px;
    line-height: 100%;
    color: {{ section.settings.badge_color }};
    text-transform: unset;
    word-break: break-word;
    font-family: {{ section.settings.badge_font }};
    font-weight: {{ section.settings.badge_weight }};
  }

  .basics-refresh-media-title-{{ section.id }} {
    margin: 0px;  
    text-align: {{ section.settings.media_title_alignment_mobile }};
    font-size: {{ section.settings.media_title_size_mobile }}px;
    line-height: 130%;
    color: {{ section.settings.media_title_color }};
    text-transform: unset;
    word-break: break-word;
    font-family: {{ section.settings.media_title_font }};
    font-weight: {{ section.settings.media_title_weight }};
  }

  .basics-refresh-media-text-{{ section.id }} {
    text-align: {{ section.settings.media_text_alignment_mobile }};
    margin-top: {{ section.settings.media_text_margin_mobile }}px;
  }

  .basics-refresh-media-text-{{ section.id }} * {
    margin: 0px;     
    font-size: {{ section.settings.media_text_size_mobile }}px;
    line-height: 150%;
    color: {{ section.settings.media_text_color }};
    text-transform: unset;
    word-break: break-word;
    font-family: {{ section.settings.media_text_font }};
    font-weight: {{ section.settings.media_text_weight }};
  }

  .basics-refresh-slider-wrapper-{{ section.id }} {
    width: 100%;
  }

  .basics-refresh-slider-{{ section.id }} {
    min-width: 0 !important;
    margin-left: -1.5rem !important;
    margin-right: -1.5rem !important;
    padding-left: 1.5rem !important;
    padding-right: 1.5rem !important;
  }

  .basics-refresh-slide-{{ section.id }} {
    box-sizing: border-box !important;
    display: flex !important;
    flex-direction: column !important;
  }

  .basics-refresh-product-image-{{ section.id }} {
    display: block;
    border-radius: {{ section.settings.product_image_border_radius_mobile }}px;
    overflow: hidden;
  }

  .basics-refresh-image-{{ section.id }} {
    border: {{ section.settings.product_image_border_width }}px solid {{ section.settings.product_image_border_color }};
    border-radius: {{ section.settings.product_image_border_radius_mobile }}px;
    display: block;
    box-sizing: border-box !important;
    overflow: hidden;
    aspect-ratio: {{ section.settings.product_image_aspect_ratio_mobile }};
    transition: transform 0.3s ease;
  }

  .basics-refresh-image-{{ section.id }} img,
  .basics-refresh-image-{{ section.id }} svg {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .basics-refresh-image-{{ section.id }} svg {
    background-color: #AFAFAF;
  }

  /* Hover scale effect */
  .basics-refresh-slide-{{ section.id }}:hover .basics-refresh-image-{{ section.id }} {
    transform: scale(1.05);
  }

  .basics-refresh-content-{{ section.id }} {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    align-items: {{ section.settings.product_alignment_mobile }};
    width: 100%;
    min-width: 0;
  }

  .basics-refresh-content-wrapper-{{ section.id }} {
    width: 100%;
    min-width: 0;
    overflow: hidden;
  }

  .basics-refresh-title-{{ section.id }} {
    margin: 0;   
    text-align: {{ section.settings.product_alignment_mobile }};
    margin-top: {{ section.settings.product_title_margin_top_mobile }}px;
    font-size: {{ section.settings.product_title_size_mobile }}px;
    color: {{ section.settings.product_title_color }};
    line-height: 130%;
    text-transform: unset;
    transition: all 0.25s ease 0s;
    font-family: {{ section.settings.product_title_font }};
    font-weight: {{ section.settings.product_title_weight }};
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    width: 100%;
    max-width: 100%;
    display: block;
  }   
  
  .basics-refresh-text-{{ section.id }} {
    text-align: {{ section.settings.product_alignment_mobile }};
    margin-top: {{ section.settings.product_text_margin_top_mobile }}px;    
  }

  .basics-refresh-text-{{ section.id }} * {
    margin: 0;    
    font-size: {{ section.settings.product_text_size_mobile }}px;
    line-height: 150%;
    color: {{ section.settings.product_text_color }};  
    text-transform: unset;  
    word-break: break-word;
    font-family: {{ section.settings.product_text_font }};
    font-weight: {{ section.settings.product_text_weight }};
  }

  .basics-refresh-price-{{ section.id }} {
    margin-top: {{ section.settings.product_price_margin_top_mobile }}px;  
    width: 100%;
    display: flex;
    align-items: center;
    gap: 5px;
    justify-content: {{ section.settings.product_alignment_mobile }};
  }

  .basics-refresh-price-{{ section.id }} * {
    margin: 0;        
    text-align: {{ section.settings.product_alignment_mobile }};
    font-size: {{ section.settings.product_price_size_mobile }}px;
    color: {{ section.settings.product_price_color }};
    line-height: 130%;
    text-transform: unset;
    word-break: break-word;
    transition: all 0.25s ease 0s;
    font-family: {{ section.settings.product_price_font }};
    font-weight: {{ section.settings.product_price_weight }};
  }   

  .basics-refresh-compare-price-{{ section.id }} {
    text-decoration: line-through;
    color: {{ section.settings.product_compare_price_color }};
  }

  .basics-refresh-button-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    margin: 0;
    font-size: {{ section.settings.button_text_size_mobile }}px;
    color: {{ section.settings.button_text_color }};
    line-height: 100%;
    text-align: center;
    text-transform: unset;
    text-decoration: none;
    padding: {{ section.settings.button_padding_vertical_mobile }}px {{ section.settings.button_padding_horizontal_mobile }}px;
    border-radius: {{ section.settings.button_border_radius_mobile }}px;
    transition: all 0.25s ease 0s;
    background-color: {{ section.settings.button_bg_color }};
    border: {{ section.settings.button_border_width_mobile }}px solid {{ section.settings.button_border_color }};
    cursor: pointer;
    margin-top: {{ section.settings.button_margin_top_mobile }}px;
    font-family: {{ section.settings.button_font }};
    font-weight: {{ section.settings.button_weight }};
  }

  .basics-refresh-button-inner-{{ section.id }} {
    margin: 0px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }

  .basics-refresh-button-{{ section.id }}:hover {
    color: {{ section.settings.button_hover_text_color }};
    background-color: {{ section.settings.button_hover_bg_color }};
    border: {{ section.settings.button_border_width_mobile }}px solid {{ section.settings.button_hover_border_color }};
    transition: all 0.25s ease 0s;
  }

  .basics-refresh-button-{{ section.id }} svg {
    width: 14px;
    height: 14px;
    border: none;
    background-color: transparent;
  }

  .basics-refresh-button-{{ section.id }} svg path {
    fill: {{ section.settings.button_text_color }};
    transition: all 0.25s ease 0s;
  }

  .basics-refresh-button-{{ section.id }}:hover svg path {
    fill: {{ section.settings.button_hover_text_color }};
  }
  
  @media(min-width: 1024px) {
    .section-{{ section.id }} {
      margin-top: {{ section.settings.margin_top_desktop }}px;
      margin-bottom: {{ section.settings.margin_bottom_desktop }}px;
      margin-left: {{ section.settings.margin_left_desktop }}rem;
      margin-right: {{ section.settings.margin_right_desktop }}rem;
      border-radius: {{ section.settings.border_radius_desktop }}px;
    }
    
    .section-{{ section.id }}-settings {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
      padding-left: 5rem;
      padding-right: 5rem;
    }

    .basics-refresh-heading-{{ section.id }} {
      text-align: {{ section.settings.heading_alignment_desktop }};
    }
    
    .basics-refresh-heading-{{ section.id }} * {
      font-size: {{ section.settings.heading_size_desktop }}px;
    }

    .basics-refresh-btn-prev-{{ section.id }},
    .basics-refresh-btn-next-{{ section.id }} {
      width: {{ section.settings.nav_button_size_desktop }}px;
      height: {{ section.settings.nav_button_size_desktop }}px;
    }    

    .basics-refresh-bottom-{{ section.id }} {
      flex-direction: row;
      margin-top: {{ section.settings.bottom_margin_desktop }}px;
      gap: {{ section.settings.bottom_gap_desktop }}px;
    }

    .basics-refresh-media-{{ section.id }} {
      width: {{ section.settings.media_width_desktop }}%;
      border-radius: {{ section.settings.media_border_radius_desktop }}px;
      aspect-ratio: {{ section.settings.media_aspect_ratio_desktop }};
    }

    .basics-refresh-media-badge-{{ section.id }} {
      padding: {{ section.settings.badge_padding_desktop }}px {{ section.settings.badge_padding_desktop }}px;
      border-radius: {{ section.settings.badge_border_radius_desktop }}px;
      font-size: {{ section.settings.badge_size_desktop }}px;
    }

    .basics-refresh-media-title-{{ section.id }} {
      text-align: {{ section.settings.media_title_alignment_desktop }};
      font-size: {{ section.settings.media_title_size_desktop }}px;
    }

    .basics-refresh-media-text-{{ section.id }} {
      text-align: {{ section.settings.media_text_alignment_desktop }};
      margin-top: {{ section.settings.media_text_margin_desktop }}px;
    }

    .basics-refresh-media-text-{{ section.id }} * {   
      font-size: {{ section.settings.media_text_size_desktop }}px;
    }

    .basics-refresh-slider-wrapper-{{ section.id }} {
      width: {{ section.settings.slider_width_desktop }}%;
    }

    .basics-refresh-slider-{{ section.id }} {
      margin-left: 0rem !important;
      margin-right: 0rem !important;
      padding-left: 0rem !important;
      padding-right: 0rem !important;
    }

    .basics-refresh-image-{{ section.id }} {
      border-radius: {{ section.settings.product_image_border_radius_desktop }}px;
      aspect-ratio: {{ section.settings.product_image_aspect_ratio_desktop }};
    }

    .basics-refresh-content-{{ section.id }} {
      align-items: {{ section.settings.product_alignment_desktop }};
    }

    .basics-refresh-title-{{ section.id }} {
      text-align: {{ section.settings.product_alignment_desktop }};
      margin-top: {{ section.settings.product_title_margin_top_desktop }}px;
      font-size: {{ section.settings.product_title_size_desktop }}px;
    }   
    
    .basics-refresh-text-{{ section.id }} {
      text-align: {{ section.settings.product_alignment_desktop }};
      margin-top: {{ section.settings.product_text_margin_top_desktop }}px;    
    }

    .basics-refresh-text-{{ section.id }} * {    
      font-size: {{ section.settings.product_text_size_desktop }}px;
    }

    .basics-refresh-price-{{ section.id }} {    
      margin-top: {{ section.settings.product_price_margin_top_desktop }}px;       
      justify-content: {{ section.settings.product_alignment_desktop }};
    }

    .basics-refresh-price-{{ section.id }} * {        
      text-align: {{ section.settings.product_alignment_desktop }};
      font-size: {{ section.settings.product_price_size_desktop }}px;    
    }   

    .basics-refresh-button-{{ section.id }} {
      margin-top: {{ section.settings.button_margin_top_desktop }}px;
      padding: {{ section.settings.button_padding_vertical_desktop }}px {{ section.settings.button_padding_horizontal_desktop }}px;
      font-size: {{ section.settings.button_text_size_desktop }}px;
      border-width: {{ section.settings.button_border_width_desktop }}px;
    }
  }

  /* Preview styles for theme editor */
  .basics-refresh-slider-{{ section.id }}.preview .swiper-wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    overflow: hidden;
  }

  .basics-refresh-slider-{{ section.id }}.preview .basics-refresh-slide-{{ section.id }} {
    width: 100%;
  }

  .basics-refresh-slider-{{ section.id }}.preview .basics-refresh-slide-{{ section.id }}:not(:first-child) {
    margin-left: {{ section.settings.slider_gap_mobile }}px;
  } 

  @media(min-width: 1024px) {
    .basics-refresh-slider-{{ section.id }}.preview .basics-refresh-slide-{{ section.id }}:not(:first-child) {
      margin-left: {{ section.settings.slider_gap_desktop }}px;
    } 

    .basics-refresh-slider-{{ section.id }}.preview .basics-refresh-slide-{{ section.id }} {
      width: calc(100% / {{ section.settings.slides_per_view_desktop }} - ({{ section.settings.slider_gap_desktop }}px));
    }
  }
</style>

<div class="section-{{ section.id }}" style="background-color:{{ section.settings.background_color }};">
  <div class="section-{{ section.id }}-settings">
    <div class="basics-refresh-top-{{ section.id }}">
      {% if section.settings.heading_text != blank %}
        <div class="basics-refresh-heading-{{ section.id }}">
          <{{ section.settings.heading_tag }}>{{ section.settings.heading_text }}</{{ section.settings.heading_tag }}>
        </div>
      {% endif %}
      <div class="basics-refresh-buttons-{{ section.id }}">
        <button class="basics-refresh-btn-prev-{{ section.id }}" aria-label="Previous slide">
          <span class="animate-icon"></span>
        </button>
        <button class="basics-refresh-btn-next-{{ section.id }}" aria-label="Next slide">
          <span class="animate-icon"></span>
        </button>   
      </div>
    </div>
    <div class="basics-refresh-bottom-{{ section.id }}">
      <div class="basics-refresh-media-{{ section.id }}">
        {% if section.settings.image != blank %}
          <img src="{{ section.settings.image | img_url: '1500x' }}" 
               srcset="{{ section.settings.image | img_url: '375x' }} 375w, {{ section.settings.image | img_url: '550x' }} 550w, {{ section.settings.image | img_url: '750x' }} 750w, {{ section.settings.image | img_url: '1100x' }} 1100w, {{ section.settings.image | img_url: '1500x' }} 1500w" 
               width="1500" height="1500" loading="lazy" alt="{{ section.settings.image.alt }}">
        {% else %}
          {{ 'image' | placeholder_svg_tag }}
        {% endif %}
        <div class="basics-refresh-media-content-{{ section.id }}">
          <div class="basics-refresh-media-top-{{ section.id }}">
            {% if section.settings.badge_text != blank %}
              <p class="basics-refresh-media-badge-{{ section.id }}">{{ section.settings.badge_text }}</p>
            {% endif %}
          </div>
          <div class="basics-refresh-media-bottom-{{ section.id }}">
            {% if section.settings.media_title != blank %}
              <p class="basics-refresh-media-title-{{ section.id }}">{{ section.settings.media_title }}</p>
            {% endif %}
            {% if section.settings.media_text != blank %}
              <div class="basics-refresh-media-text-{{ section.id }}">{{ section.settings.media_text }}</div>
            {% endif %}
          </div>
        </div>
      </div>

      <div class="basics-refresh-slider-wrapper-{{ section.id }}">
        <div class="basics-refresh-slider-{{ section.id }} swiper" 
             data-gap="{{ section.settings.slider_gap_desktop }}" 
             data-gap-mobile="{{ section.settings.slider_gap_mobile }}" 
             data-view="{{ section.settings.slides_per_view_desktop }}" 
             data-view-mobile="{{ section.settings.slides_per_view_mobile }}" 
             style="opacity: 0;">
          <div class="swiper-wrapper">
            {% assign collection = collections[section.settings.collection] %}
            {% if collection != blank and collection.products.size > 0 %}
              {% for product in collection.products limit: section.settings.product_limit %}
                <div class="basics-refresh-slide-{{ section.id }} swiper-slide">
                  <a href="{{ product.url }}" class="basics-refresh-product-image-{{ section.id }}">
                    <div class="basics-refresh-image-{{ section.id }}">    
                      {% if product.featured_image != blank %}
                        <img src="{{ product.featured_image | img_url: '1500x' }}" 
                             srcset="{{ product.featured_image | img_url: '375x' }} 375w, {{ product.featured_image | img_url: '550x' }} 550w, {{ product.featured_image | img_url: '750x' }} 750w, {{ product.featured_image | img_url: '1100x' }} 1100w, {{ product.featured_image | img_url: '1500x' }} 1500w" 
                             width="1500" height="1500" loading="lazy" alt="{{ product.featured_image.alt | escape }}">
                      {% else %}
                        {{ 'product-1' | placeholder_svg_tag }}
                      {% endif %}
                    </div>
                  </a>
                  <div class="basics-refresh-content-{{ section.id }}">
                    <div class="basics-refresh-content-wrapper-{{ section.id }}">
                      <h3 class="basics-refresh-title-{{ section.id }}">{{ product.title }}</h3>
                      {% if section.settings.show_product_description and product.description != blank %}
                        <div class="basics-refresh-text-{{ section.id }}">
                          {{ product.description | strip_html | truncatewords: section.settings.description_words }}
                        </div>
                      {% endif %}
                      <div class="basics-refresh-price-{{ section.id }}">
                        {% if product.compare_at_price > product.price %}
                          <p class="basics-refresh-compare-price-{{ section.id }}">{{ product.compare_at_price | money }}</p>
                        {% endif %}
                        <p class="basics-refresh-regular-price-{{ section.id }}">
                          {{ product.price | money }}
                        </p>
                      </div>
                    </div>
                    {% if section.settings.button_text != blank %}
                      <a href="{{ product.url }}" class="basics-refresh-button-{{ section.id }}">
                        <span class="basics-refresh-button-inner-{{ section.id }}">
                          {{ section.settings.button_text }}
                          {% if section.settings.button_icon %}
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <path d="M1 7H13M13 7L7 1M13 7L7 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                          {% endif %}
                        </span>
                      </a>
                    {% endif %}
                  </div>
                </div>
              {% endfor %}
            {% else %}
              <div class="basics-refresh-slide-{{ section.id }} swiper-slide">
                <p style="text-align:center;">Please select a collection or add products to display.</p>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

<script>
  (function() {
    const sectionId = '{{ section.id }}';

    function initBasicsRefresh() {
      // Remove preview class
      const sliderEl = document.querySelector('.basics-refresh-slider-' + sectionId);
      if (sliderEl) sliderEl.classList.remove('preview');

      // Swiper
      if (sliderEl && document.querySelector('.basics-refresh-slider-wrapper-' + sectionId)) {
        new Swiper('.basics-refresh-slider-' + sectionId, {
          speed: 300,
          loop: true,
          navigation: {
            nextEl: '.basics-refresh-btn-next-' + sectionId,
            prevEl: '.basics-refresh-btn-prev-' + sectionId,
          },
          breakpoints: {
            320: {
              spaceBetween: parseInt(sliderEl.dataset.gapMobile) || {{ section.settings.slider_gap_mobile }},
              slidesPerView: parseFloat(sliderEl.dataset.viewMobile) || {{ section.settings.slides_per_view_mobile }},
            },
            768: {
              spaceBetween: parseInt(sliderEl.dataset.gap) || {{ section.settings.slider_gap_desktop }},
              slidesPerView: parseFloat(sliderEl.dataset.viewMobile) || {{ section.settings.slides_per_view_mobile }},
            },
            1024: {
              spaceBetween: parseInt(sliderEl.dataset.gap) || {{ section.settings.slider_gap_desktop }},
              slidesPerView: parseFloat(sliderEl.dataset.view) || {{ section.settings.slides_per_view_desktop }},
            }
          },
          on: {
            init: function() {
              this.el.style.opacity = '1';
            }
          }
        });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initBasicsRefresh);
    } else {
      initBasicsRefresh();
    }

    if (Shopify.designMode) {
      document.addEventListener('shopify:section:unload', function(e) {
        if (e.detail.sectionId !== '{{ section.id }}') return;
        // no video cleanup needed
      });
      document.addEventListener('shopify:section:load', initBasicsRefresh);
    }
  })();
</script>

