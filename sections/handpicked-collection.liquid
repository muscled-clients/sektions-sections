<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

{%- style -%}
  /* ===== SECTION ===== */
  .hp-section-{{ section.id }} {
    overflow: hidden;
    position: relative;
    background: {{ section.settings.background_color }};
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    border-radius: 0;
  }

  .hp-settings-{{ section.id }} {
    margin: 0 auto;
    padding: 60px 2rem 50px;
    overflow: hidden;
  }

  /* ===== TRIANGLE SHAPE ===== */
  .hp-shape-wrap-{{ section.id }} {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    height: 100%;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .hp-shape-{{ section.id }} {
    display: block !important;
    position: absolute;
    width: 1900px;
    height: 1900px;
    top: 0;
    left: 50%;
    transform: translateX(-50%) translateY(-1600px) rotate(45deg);
    transform-origin: center center;
    z-index: 0;
    border-radius: 100px;
    transition: background-color 0.4s ease;
    background-color: {{ section.settings.shape_color }};
  }

  @media(max-width: 1624px) {
    .hp-shape-{{ section.id }} { width: 1800px; height: 1800px; }
  }
  @media(max-width: 1224px) {
    .hp-shape-{{ section.id }} { width: 1700px; height: 1700px; }
  }
  @media(max-width: 768px) {
    .hp-shape-{{ section.id }} {
      width: 600px;
      height: 600px;
      transform: translateX(-50%) translateY(-280px) rotate(45deg);
    }
  }

  /* ===== HEADING ===== */
  .hp-heading-{{ section.id }} {
    text-align: center;
    position: relative;
    z-index: 2;
  }

  .hp-heading-{{ section.id }} * {
    margin: 0;
    font-size: 36px;
    color: {{ section.settings.heading_color }};
    line-height: 120%;
    font-weight: 900;
    font-family: "Inter", sans-serif;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* ===== TABS ===== */
  .hp-tabs-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
    gap: 0;
    margin-top: 30px;
    flex-wrap: wrap;
  }

  .hp-tab-{{ section.id }} {
    margin: 0;
    padding: 14px 32px;
    border: 1px solid {{ section.settings.tab_border_color }};
    background: transparent;
    font-size: 13px;
    line-height: 100%;
    color: {{ section.settings.heading_color }};
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 600;
    cursor: pointer;
    text-align: center;
    transition: all 0.25s ease;
    font-family: "Inter", sans-serif;
  }

  .hp-tab-{{ section.id }} + .hp-tab-{{ section.id }} {
    border-left: none;
  }

  .hp-tab-{{ section.id }}:hover {
    background: rgba(255,255,255,0.5);
  }

  .hp-tab-{{ section.id }}.active {
    background: {{ section.settings.tab_active_bg }};
    border-color: {{ section.settings.heading_color }};
    color: {{ section.settings.heading_color }};
  }

  /* ===== SLIDER WRAPPER ===== */
  .hp-slider-wrapper-{{ section.id }} {
    display: grid;
    margin-top: 30px;
    margin-left: -2rem;
    margin-right: -2rem;
  }

  .hp-slider-{{ section.id }} {
    display: none !important;
    min-width: 0 !important;
    width: 100% !important;
  }

  .hp-slider-{{ section.id }}.active {
    display: flex !important;
    flex-direction: column;
    overflow: visible !important;
    overflow-x: clip !important;
  }

  .hp-slider-{{ section.id }}:not(.swiper-initialized) {
    visibility: hidden;
  }

  .hp-slider-{{ section.id }}.swiper-initialized {
    visibility: visible;
  }

  /* ===== SLIDES ===== */
  .hp-slide-{{ section.id }} {
    height: auto !important;
    box-sizing: border-box !important;
    transition: all 0.25s ease;
    z-index: 1;
    position: relative;
  }

  .hp-slide-{{ section.id }}.swiper-slide-active {
    z-index: 2;
  }

  .hp-slide-inner-{{ section.id }} {
    position: relative;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .hp-images-{{ section.id }} {
    overflow: hidden;
    text-decoration: none;
    display: block;
  }

  /* ===== IMAGE WITH BEIGE BORDER ===== */
  .hp-image-{{ section.id }} {
    overflow: hidden;
    aspect-ratio: 9.6/12;
    transition: all 0.25s ease;
  }

  .hp-image-wrap-{{ section.id }} {
    overflow: hidden;
    transition: all 0.25s ease;
    aspect-ratio: 9.6/10;
    transform: translateY(10%);
    background: {{ section.settings.image_border_color }};
    padding: 6px;
    position: relative;
  }

  .hp-slide-{{ section.id }}.swiper-slide-active .hp-image-wrap-{{ section.id }} {
    aspect-ratio: 9.6/12;
    transform: translateY(0);
  }

  .hp-image-{{ section.id }} img,
  .hp-image-{{ section.id }} svg {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hp-image-{{ section.id }} svg {
    background-color: #e0ddd0;
  }

  .hp-image-{{ section.id }} img.hp-hover-img-{{ section.id }} {
    position: absolute;
    top: 6px;
    left: 6px;
    width: calc(100% - 12px);
    height: calc(100% - 12px);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .hp-image-wrap-{{ section.id }}:hover img.hp-hover-img-{{ section.id }} {
    opacity: 1;
  }

  /* ===== SLIDE CONTENT ===== */
  .hp-slide-content-{{ section.id }} {
    opacity: 0;
    display: flex;
    flex-direction: column;
    flex: 1 1 0;
    align-items: flex-start;
    padding: 16px 0 0;
    pointer-events: none;
    transition: opacity 0.1s ease;
  }

  .hp-slide-{{ section.id }}.swiper-slide-active .hp-slide-content-{{ section.id }} {
    opacity: 1;
    pointer-events: auto;
    transition: opacity 0.4s ease 0.4s;
  }

  .hp-title-{{ section.id }} {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
    color: {{ section.settings.product_title_color }};
    line-height: 140%;
    text-align: left;
    font-family: "Inter", sans-serif;
  }

  .hp-price-{{ section.id }} {
    margin-top: 6px;
    font-size: 15px;
    color: {{ section.settings.product_price_color }};
    font-family: "Inter", sans-serif;
    font-weight: 400;
  }

  /* ===== NAV BUTTONS ===== */
  .hp-buttons-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 20px;
    justify-content: center;
  }

  .hp-btn-prev-{{ section.id }},
  .hp-btn-next-{{ section.id }} {
    display: none;
    position: static !important;
    width: 44px;
    height: 44px;
    border: none;
    border-radius: 0;
    background: {{ section.settings.nav_bg_color }};
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    cursor: pointer;
    -webkit-appearance: none;
  }

  .hp-btn-prev-{{ section.id }} .hp-arrow,
  .hp-btn-next-{{ section.id }} .hp-arrow {
    pointer-events: none;
    display: grid;
    place-items: center;
    color: {{ section.settings.nav_icon_color }};
  }

  .hp-btn-prev-{{ section.id }} .hp-arrow::before,
  .hp-btn-next-{{ section.id }} .hp-arrow::before {
    content: "";
    grid-area: 1 / -1;
    width: 10px;
    height: 10px;
    transform: rotate(45deg);
    box-sizing: border-box;
    border: 0;
    border-right: 2px solid currentColor;
    border-top: 2px solid currentColor;
    position: relative;
    left: -2px;
  }

  .hp-btn-prev-{{ section.id }} .hp-arrow::before {
    left: 2px;
    border-right: 0;
    border-top: 0;
    border-bottom: 2px solid currentColor;
    border-left: 2px solid currentColor;
  }

  .hp-btn-prev-{{ section.id }}:hover,
  .hp-btn-next-{{ section.id }}:hover {
    background: {{ section.settings.nav_hover_bg }};
  }

  .hp-btn-prev-{{ section.id }}.swiper-button-disabled,
  .hp-btn-next-{{ section.id }}.swiper-button-disabled {
    opacity: 0.3;
  }

  /* ===== DESKTOP ===== */
  @media(min-width: 1024px) {
    .hp-settings-{{ section.id }} {
      padding: 50px 2rem 50px;
    }

    .hp-heading-{{ section.id }} * {
      font-size: 48px;
    }

    .hp-slider-wrapper-{{ section.id }} {
      margin-left: -2rem;
      margin-right: -2rem;
    }

    .hp-title-{{ section.id }} {
      font-size: 18px;
    }

    .hp-image-{{ section.id }} img {
      transform: translateZ(0);
      transition: transform 1.2s cubic-bezier(.4,0,0,1);
    }

    .hp-image-{{ section.id }}:hover img:not(.hp-hover-img-{{ section.id }}) {
      transform: scale(1.05) translateZ(0);
      transition: transform 1.2s cubic-bezier(.4,0,0,1);
    }

    .hp-btn-prev-{{ section.id }},
    .hp-btn-next-{{ section.id }} {
      display: flex;
      margin: 0;
      position: absolute !important;
      z-index: 2;
      width: 50px;
      height: 50px;
      top: 50%;
      transform: translateY(-50%);
    }

    .hp-btn-prev-{{ section.id }} {
      left: 1%;
    }

    .hp-btn-next-{{ section.id }} {
      right: 1%;
    }
  }

  /* ===== MOBILE ===== */
  @media(max-width: 1023px) {
    .hp-slider-wrapper-{{ section.id }} {
      margin-top: 60px;
    }

    .hp-tabs-{{ section.id }} {
      gap: 0;
      overflow-x: auto;
      flex-wrap: nowrap;
      scrollbar-width: none;
      margin-left: -1.5rem;
      margin-right: -1.5rem;
      padding-left: 1.5rem;
      padding-right: 1.5rem;
      justify-content: flex-start;
    }
    .hp-tabs-{{ section.id }}::-webkit-scrollbar { display: none; }

    .hp-btn-prev-{{ section.id }},
    .hp-btn-next-{{ section.id }} {
      display: none !important;
    }
  }
{%- endstyle -%}

<div class="hp-section-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="hp-shape-wrap-{{ section.id }}">
    <div class="hp-shape-{{ section.id }}" id="hp-shape-{{ section.id }}"></div>
  </div>
  <div class="hp-settings-{{ section.id }}">

    {%- if section.settings.heading != blank -%}
      <div class="hp-heading-{{ section.id }}">
        <h2>{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="hp-tabs-{{ section.id }}">
        {%- for block in section.blocks -%}
          <p
            class="hp-tab-{{ section.id }}{% if forloop.first %} active{% endif %}"
            id="hp-tab-{{ section.id }}-{{ block.id }}"
            data-shape-color="{{ block.settings.shape_color | default: section.settings.shape_color }}"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.tab_label | default: block.settings.collection.title | default: 'Collection' }}
          </p>
        {%- endfor -%}
      </div>

      <div class="hp-slider-wrapper-{{ section.id }}">
        {%- for block in section.blocks -%}
          {%- assign collection = block.settings.collection -%}
          {%- assign limit = block.settings.products_to_show | default: 10 -%}

          <div
            class="hp-slider-{{ section.id }} swiper{% if forloop.first %} active{% endif %}"
            data-id="hp-tab-{{ section.id }}-{{ block.id }}"
            data-view="{{ section.settings.slides_per_view_desktop }}"
            data-view-mobile="{{ section.settings.slides_per_view_mobile }}"
          >
            <div class="swiper-wrapper">
              {%- if collection != blank and collection.products.size > 0 -%}
                {%- assign product_count = collection.products.size -%}
                {%- if product_count > limit -%}
                  {%- assign product_count = limit -%}
                {%- endif -%}
                {%- assign min_slides = 15 -%}
                {%- assign repeat_count = min_slides | plus: product_count | minus: 1 | divided_by: product_count -%}
                {%- if repeat_count < 3 -%}
                  {%- assign repeat_count = 3 -%}
                {%- endif -%}
                {%- for repeat in (1..repeat_count) -%}
                  {%- for product in collection.products limit: limit -%}
                    <div class="hp-slide-{{ section.id }} swiper-slide">
                      <div class="hp-slide-inner-{{ section.id }}">
                        <a href="{{ product.url }}" class="hp-images-{{ section.id }}">
                          <div class="hp-image-{{ section.id }}">
                            <div class="hp-image-wrap-{{ section.id }}">
                              {%- if product.featured_image != blank -%}
                                <img
                                  src="{{ product.featured_image | image_url: width: 600 }}"
                                  alt="{{ product.featured_image.alt | escape }}"
                                  width="600"
                                  height="{{ 600 | divided_by: product.featured_image.aspect_ratio | round }}"
                                  loading="lazy"
                                >
                                {%- if product.images.size > 1 -%}
                                  <img
                                    src="{{ product.images[1] | image_url: width: 600 }}"
                                    alt="{{ product.images[1].alt | escape }}"
                                    class="hp-hover-img-{{ section.id }}"
                                    width="600"
                                    height="{{ 600 | divided_by: product.images[1].aspect_ratio | round }}"
                                    loading="lazy"
                                  >
                                {%- endif -%}
                              {%- else -%}
                                {{ 'product-1' | placeholder_svg_tag }}
                              {%- endif -%}
                            </div>
                          </div>
                        </a>
                        <div class="hp-slide-content-{{ section.id }}">
                          <p class="hp-title-{{ section.id }}">{{ product.title }}</p>
                          <p class="hp-price-{{ section.id }}">{{ product.price | money }}</p>
                        </div>
                      </div>
                    </div>
                  {%- endfor -%}
                {%- endfor -%}
              {%- else -%}
                {%- for i in (1..15) -%}
                  {%- assign placeholder_index = i | modulo: 6 -%}
                  {%- if placeholder_index == 0 -%}{%- assign placeholder_index = 1 -%}{%- endif -%}
                  <div class="hp-slide-{{ section.id }} swiper-slide">
                    <div class="hp-slide-inner-{{ section.id }}">
                      <a href="#" class="hp-images-{{ section.id }}">
                        <div class="hp-image-{{ section.id }}">
                          <div class="hp-image-wrap-{{ section.id }}">
                            {{ 'product-' | append: placeholder_index | placeholder_svg_tag }}
                          </div>
                        </div>
                      </a>
                      <div class="hp-slide-content-{{ section.id }}">
                        <p class="hp-title-{{ section.id }}">Sample Product {{ i }}</p>
                        <p class="hp-price-{{ section.id }}">$0.00</p>
                      </div>
                    </div>
                  </div>
                {%- endfor -%}
              {%- endif -%}
            </div>

            <div class="hp-buttons-{{ section.id }}">
              <button class="hp-btn-prev-{{ section.id }}" tabindex="0" aria-label="Previous slide">
                <span class="hp-arrow"></span>
              </button>
              <button class="hp-btn-next-{{ section.id }}" tabindex="0" aria-label="Next slide">
                <span class="hp-arrow"></span>
              </button>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

<script>
  function initHP_{{ section.id | replace: '-', '_' }}() {
    var sid = '{{ section.id }}';
    var sectionEl = document.querySelector('.hp-section-' + sid);
    if (!sectionEl) return;

    var tabs = sectionEl.querySelectorAll('.hp-tab-' + sid);
    var sliders = sectionEl.querySelectorAll('.hp-slider-' + sid);
    var shape = document.getElementById('hp-shape-' + sid);

    if (tabs.length > 0 && sliders.length > 0) {
      tabs.forEach(function(t) { t.classList.remove('active'); });
      sliders.forEach(function(s) { s.classList.remove('active'); });
      tabs[0].classList.add('active');
      sliders[0].classList.add('active');
      updateShapeColor(tabs[0]);
    }

    function updateShapeColor(tab) {
      if (!shape || !tab) return;
      var color = tab.getAttribute('data-shape-color');
      if (color) shape.style.backgroundColor = color;
    }

    function initSlider(sliderEl) {
      if (!sliderEl || sliderEl.swiper) return;

      var viewDesktop = parseFloat(sliderEl.dataset.view || 5);
      var viewMobile = parseFloat(sliderEl.dataset.viewMobile || 1.6);
      var prevBtn = sliderEl.querySelector('.hp-btn-prev-' + sid);
      var nextBtn = sliderEl.querySelector('.hp-btn-next-' + sid);

      new Swiper(sliderEl, {
        speed: 300,
        loop: true,
        centeredSlides: true,
        loopAdditionalSlides: 5,
        navigation: {
          nextEl: nextBtn,
          prevEl: prevBtn,
        },
        breakpoints: {
          320: {
            spaceBetween: 15,
            slidesPerView: viewMobile,
          },
          768: {
            spaceBetween: 15,
            slidesPerView: viewDesktop,
          },
          1024: {
            spaceBetween: 15,
            slidesPerView: viewDesktop,
          }
        }
      });
    }

    function waitForSwiper() {
      if (typeof Swiper === 'undefined') {
        setTimeout(waitForSwiper, 100);
        return;
      }

      sliders.forEach(function(sliderEl) {
        if (sliderEl.classList.contains('active')) {
          initSlider(sliderEl);
        }
      });

      tabs.forEach(function(tab) {
        tab.addEventListener('click', function() {
          tabs.forEach(function(t) { t.classList.remove('active'); });
          sliders.forEach(function(s) { s.classList.remove('active'); });

          tab.classList.add('active');
          updateShapeColor(tab);

          sliders.forEach(function(slider) {
            if (tab.id === slider.getAttribute('data-id')) {
              slider.classList.add('active');
              initSlider(slider);
              var swiperInstance = slider.swiper;
              if (swiperInstance) {
                swiperInstance.update();
              }
            }
          });
        });
      });
    }

    waitForSwiper();
  }

  document.addEventListener('DOMContentLoaded', initHP_{{ section.id | replace: '-', '_' }});

  if (typeof Shopify !== 'undefined' && Shopify.designMode) {
    document.addEventListener('shopify:section:load', function(e) {
      if (e.detail.sectionId === '{{ section.id }}') {
        initHP_{{ section.id | replace: '-', '_' }}();
      }
    });
  }
</script>

{% schema %}
{
  "name": "Handpicked Collection",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hand-Picked For You"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Section max width (px)",
      "min": 900,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1440
    },
    {
      "type": "range",
      "id": "slides_per_view_desktop",
      "label": "Slides per view (desktop)",
      "min": 3,
      "max": 7,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "slides_per_view_mobile",
      "label": "Slides per view (mobile)",
      "min": 1,
      "max": 3,
      "step": 0.1,
      "default": 1.6
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "shape_color",
      "label": "Triangle shape color",
      "default": "#d9d2b8"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "tab_border_color",
      "label": "Tab border color",
      "default": "#999999"
    },
    {
      "type": "color",
      "id": "tab_active_bg",
      "label": "Tab active background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "image_border_color",
      "label": "Image border color",
      "default": "#e8e2c8"
    },
    {
      "type": "color",
      "id": "product_title_color",
      "label": "Product title color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "product_price_color",
      "label": "Product price color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "nav_bg_color",
      "label": "Nav button background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "nav_icon_color",
      "label": "Nav icon color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "nav_hover_bg",
      "label": "Nav hover background",
      "default": "#333333"
    }
  ],
  "blocks": [
    {
      "type": "collection_tab",
      "name": "Collection Tab",
      "limit": 8,
      "settings": [
        {
          "type": "text",
          "id": "tab_label",
          "label": "Tab label",
          "info": "If empty, the collection title will be used"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "range",
          "id": "products_to_show",
          "label": "Products to show",
          "min": 3,
          "max": 25,
          "step": 1,
          "default": 10
        },
        {
          "type": "color",
          "id": "shape_color",
          "label": "Triangle color for this tab",
          "info": "Changes the triangle color when this tab is active"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Handpicked Collection",
      "blocks": [
        {
          "type": "collection_tab",
          "settings": {
            "tab_label": "UNISEX",
            "shape_color": "#d9d2b8"
          }
        },
        {
          "type": "collection_tab",
          "settings": {
            "tab_label": "WOMEN",
            "shape_color": "#c8bfa5"
          }
        },
        {
          "type": "collection_tab",
          "settings": {
            "tab_label": "MEN",
            "shape_color": "#b8b095"
          }
        }
      ]
    }
  ]
}
{% endschema %}
