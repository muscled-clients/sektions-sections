<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

<script>
  (function() {
    function initMyCollectionSlider() {
      const sectionId = '{{ section.id }}';
      
      function recalcCardHeights(card) {
        var textWrap = card.querySelector('.my-collection-card-text-wrap-' + sectionId);
        var featuresWrap = card.querySelector('.my-collection-card-features-wrap-' + sectionId);

        if (textWrap) {
          card.style.setProperty('--text-height', textWrap.scrollHeight + 'px');
        }

        if (featuresWrap) {
          var prevMax = featuresWrap.style.maxHeight;
          featuresWrap.style.maxHeight = 'none';
          card.style.setProperty('--features-height', featuresWrap.scrollHeight + 'px');
          featuresWrap.style.maxHeight = prevMax;
        }
      }

      document.querySelectorAll('.my-collection-card-' + sectionId).forEach(function(card) {
        recalcCardHeights(card);
      });

      if (window.ResizeObserver) {
        var ro = new ResizeObserver(function() {
          document.querySelectorAll('.my-collection-card-' + sectionId).forEach(function(card) {
            recalcCardHeights(card);
          });
        });
        var sectionEl = document.querySelector('.section-' + sectionId);
        if (sectionEl) ro.observe(sectionEl);
      }

      // Preview video on hover
      document.querySelectorAll('.my-collection-card-' + sectionId).forEach(function(card) {
        var previewEl = card.querySelector('.my-collection-card-preview-' + sectionId);
        if (!previewEl) return;
        var previewVideo = previewEl.querySelector('video');
        if (!previewVideo) return;

        card.addEventListener('mouseenter', function() {
          if (card.classList.contains('is-playing')) return;
          previewVideo.currentTime = 0;
          previewVideo.play().catch(function() {});
        });

        card.addEventListener('mouseleave', function() {
          previewVideo.pause();
          previewVideo.currentTime = 0;
        });
      });

      function playPreview(card) {
        if (card.classList.contains('is-playing')) return;
        var previewEl = card.querySelector('.my-collection-card-preview-' + sectionId);
        if (!previewEl) return;
        var pv = previewEl.querySelector('video');
        if (pv) { pv.currentTime = 0; pv.play().catch(function() {}); }
      }

      function pausePreview(card) {
        var previewEl = card.querySelector('.my-collection-card-preview-' + sectionId);
        if (!previewEl) return;
        var pv = previewEl.querySelector('video');
        if (pv) { pv.pause(); pv.currentTime = 0; }
      }

      function toggleExpandCard(card) {
        if (card.classList.contains('is-expanded')) {
          card.classList.remove('is-expanded');
          pausePreview(card);
        } else {
          document.querySelectorAll('.my-collection-card-' + sectionId + '.is-expanded').forEach(function(other) {
            other.classList.remove('is-expanded');
            pausePreview(other);
          });
          card.classList.add('is-expanded');
          playPreview(card);
        }
      }

      document.querySelectorAll('.my-collection-plus-trigger-' + sectionId).forEach(function(plusBtn) {
        plusBtn.addEventListener('click', function(e) {
          e.stopPropagation();
          var card = plusBtn.closest('.my-collection-card-' + sectionId);
          if (card) toggleExpandCard(card);
        });
      });

      document.querySelectorAll('.my-collection-card-' + sectionId).forEach(function(card) {
        card.addEventListener('click', function(e) {
          if (e.target.closest('.my-collection-video-trigger-' + sectionId)) return;
          if (e.target.closest('.my-collection-video-close-' + sectionId)) return;
          if (e.target.closest('.my-collection-card-video-' + sectionId)) return;
          if (e.target.closest('.my-collection-plus-trigger-' + sectionId)) return;

          if (window.innerWidth < 1024) {
            if (e.target.closest('.my-collection-button-' + sectionId)) return;
            if (card.classList.contains('is-expanded') && e.target.closest('.my-collection-card-content-' + sectionId)) {
              var btn = card.querySelector('.my-collection-button-' + sectionId);
              if (btn && btn.tagName === 'A' && btn.href) {
                if (btn.target === '_blank') {
                  window.open(btn.href, '_blank');
                } else {
                  window.location.href = btn.href;
                }
              }
            }
          } else {
            if (!e.target.closest('.my-collection-card-content-' + sectionId)) return;
            var btn = card.querySelector('.my-collection-button-' + sectionId);
            if (btn && btn.tagName === 'A' && btn.href) {
              if (btn.target === '_blank') {
                window.open(btn.href, '_blank');
              } else {
                window.location.href = btn.href;
              }
            }
          }
        });
      });

      // Video trigger
      document.querySelectorAll('.my-collection-video-trigger-' + sectionId).forEach(function(trigger) {
        trigger.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();

          var card = trigger.closest('.my-collection-card-' + sectionId);
          if (!card) return;

          var videoPanel = card.querySelector('.my-collection-card-video-' + sectionId);
          if (!videoPanel) return;

          document.querySelectorAll('.my-collection-card-' + sectionId + '.is-playing').forEach(function(other) {
            if (other === card) return;
            other.classList.remove('is-playing');
            other.classList.remove('is-expanded');
            var otherPanel = other.querySelector('.my-collection-card-video-' + sectionId);
            if (otherPanel) {
              var otherVideo = otherPanel.querySelector('video');
              var otherIframe = otherPanel.querySelector('iframe');
              if (otherVideo) { otherVideo.pause(); otherVideo.currentTime = 0; }
              if (otherIframe) { otherIframe.src = 'about:blank'; }
            }
            var otherPreview = other.querySelector('.my-collection-card-preview-' + sectionId);
            if (otherPreview) {
              var pv = otherPreview.querySelector('video');
              if (pv) pv.pause();
            }
          });

          var previewEl = card.querySelector('.my-collection-card-preview-' + sectionId);
          if (previewEl) {
            var previewVideo = previewEl.querySelector('video');
            if (previewVideo) previewVideo.pause();
          }

          card.classList.add('is-playing');

          var videoTag = videoPanel.querySelector('video');
          var iframeTag = videoPanel.querySelector('iframe');

          if (videoTag) {
            videoTag.currentTime = 0;
            videoTag.play().catch(function() {});
          }
          if (iframeTag && iframeTag.dataset.src) {
            iframeTag.src = iframeTag.dataset.src;
          }
        });
      });

      // Video close
      document.querySelectorAll('.my-collection-video-close-' + sectionId).forEach(function(closeBtn) {
        closeBtn.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();

          var card = closeBtn.closest('.my-collection-card-' + sectionId);
          if (!card) return;

          card.classList.remove('is-playing');
          card.classList.remove('is-expanded');

          var videoPanel = card.querySelector('.my-collection-card-video-' + sectionId);
          if (!videoPanel) return;

          var videoTag = videoPanel.querySelector('video');
          var iframeTag = videoPanel.querySelector('iframe');

          if (videoTag) {
            videoTag.pause();
            videoTag.currentTime = 0;
          }
          if (iframeTag) {
            iframeTag.src = 'about:blank';
          }
        });
      });

      // Swiper initialization
      var sliderWrap = document.querySelector('.my-collection-slider-wrap-' + sectionId);
      var sliderEl = document.querySelector('.my-collection-slider-' + sectionId);

      if (sliderEl && sliderWrap && window.getComputedStyle(sliderWrap).display !== 'none') {
        sliderEl.classList.remove('preview');
        new Swiper('.my-collection-slider-' + sectionId, {
          speed: 300,
          navigation: {
            nextEl: `.my-collection-slider-next-${sectionId}`,
            prevEl: `.my-collection-slider-prev-${sectionId}`,
          },
          scrollbar: {
            el: '.my-collection-scrollbar-' + sectionId,
            draggable: true,
          },
          breakpoints: {
            320: {
              spaceBetween: parseInt(sliderEl.dataset.gapMobile) || {{ section.settings.slider_gap_mobile }},
              slidesPerView: parseFloat(sliderEl.dataset.viewMobile) || {{ section.settings.slides_per_view_mobile }},
            },
            1024: {
              spaceBetween: parseInt(sliderEl.dataset.gap) || {{ section.settings.slider_gap_desktop }},
              slidesPerView: parseFloat(sliderEl.dataset.view) || {{ section.settings.slides_per_view_desktop }},
            }
          },
          on: {
            init: function() {
              this.el.style.opacity = '1';
            }
          }
        });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initMyCollectionSlider);
    } else {
      initMyCollectionSlider();
    }

    {% if request.design_mode %}
      document.addEventListener('shopify:section:load', function(event) {
        if (event.detail.sectionId === '{{ section.id }}') {
          setTimeout(initMyCollectionSlider, 100);
        }
      });
      document.addEventListener('shopify:section:unload', function(event) {
        if (event.detail.sectionId === '{{ section.id }}') {
          document.querySelectorAll('.my-collection-card-{{ section.id }}.is-playing').forEach(function(card) {
            card.classList.remove('is-playing');
          });
        }
      });
    {% endif %}
  })();
</script>

{% schema %}
{
  "name": "Featured Collection 02",
  "settings": [
    {
      "type": "header",
      "content": "General Settings"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#fbf9f4"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#d9d1c8"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border Radius (Mobile)",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 16,
      "unit": "px"
    },
