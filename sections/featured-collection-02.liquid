      font-size: {{ section.settings.title_size_desktop }}px;
    }

    .my-collection-card-text-{{ section.id }} * {
      font-size: {{ section.settings.text_size_desktop }}px;
    }

    .my-collection-card-features-{{ section.id }} li {
      font-size: {{ section.settings.feature_size_desktop }}px;
      flex-direction: row;
    }

