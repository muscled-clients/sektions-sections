            },
            {
              "value": "cross",
              "label": "Cross"
            },
            {
              "value": "star",
              "label": "Star"
            }
          ],
          "default": "cross"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sek Comparison Section 1",
      "blocks": [
        {
          "type": "comparison_row",
          "settings": {
            "left_text": "Plant-based",
            "left_icon": "check",
            "right_text": "Plastic",
            "right_icon": "cross"
          }
        },
        {
          "type": "comparison_row",
          "settings": {
            "left_text": "Biodegradable",
            "left_icon": "check",
            "right_text": "Non-degradable",
            "right_icon": "cross"
          }
        },
        {
          "type": "comparison_row",
          "settings": {
