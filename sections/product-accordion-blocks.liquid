<style>
  .pab-{{ section.id }} {
    width: 100%;
    font-family: {{ section.settings.font_family }};
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .pab-{{ section.id }} .pab__item {
    border-bottom: 1px solid {{ section.settings.divider_color }};
  }

  .pab-{{ section.id }} .pab__item:first-child {
    border-top: 1px solid {{ section.settings.divider_color }};
  }

  .pab-{{ section.id }} .pab__trigger {
    display: flex;
    align-items: center;
    gap: 16px;
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    padding: 16px 0;
    text-align: left;
  }

  .pab-{{ section.id }} .pab__icon-wrap {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    border-radius: 50%;
    border: 1.5px solid {{ section.settings.icon_border_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: {{ section.settings.icon_color }};
  }

  .pab-{{ section.id }} .pab__icon-wrap svg {
    width: calc({{ section.settings.icon_size }}px * 0.5);
    height: calc({{ section.settings.icon_size }}px * 0.5);
  }

  .pab-{{ section.id }} .pab__label {
    flex: 1;
    font-size: {{ section.settings.label_size }}px;
    font-weight: {{ section.settings.label_weight }};
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: {{ section.settings.label_color }};
    margin: 0;
  }

  .pab-{{ section.id }} .pab__plus {
    font-size: {{ section.settings.label_size }}px;
    color: {{ section.settings.label_color }};
    line-height: 1;
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }

  .pab-{{ section.id }} .pab__item.is-open .pab__plus {
    transform: rotate(45deg);
  }

  .pab-{{ section.id }} .pab__content {
    display: none;
    padding: 0 0 16px {{ section.settings.icon_size | plus: 16 }}px;
    font-size: {{ section.settings.content_size }}px;
    color: {{ section.settings.content_color }};
    line-height: 1.7;
  }

  .pab-{{ section.id }} .pab__item.is-open .pab__content {
    display: block;
  }
</style>

<div class="pab-{{ section.id }}">
  {% for block in section.blocks %}
    <div class="pab__item" {{ block.shopify_attributes }}>
      <button class="pab__trigger" onclick="pabToggle(this)">
        <div class="pab__icon-wrap">
          {% if block.settings.icon_svg != blank %}
            {{ block.settings.icon_svg }}
          {% else %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="16"/>
              <line x1="8" y1="12" x2="16" y2="12"/>
            </svg>
          {% endif %}
        </div>
        <span class="pab__label">{{ block.settings.label }}</span>
        <span class="pab__plus">+</span>
      </button>
      {% if block.settings.content != blank %}
        <div class="pab__content">{{ block.settings.content }}</div>
      {% endif %}
    </div>
  {% endfor %}
</div>

<script>
function pabToggle(trigger) {
  var item = trigger.closest('.pab__item');
  var isOpen = item.classList.contains('is-open');
  {% if section.settings.one_at_a_time %}
  var allItems = trigger.closest('.pab-{{ section.id }}').querySelectorAll('.pab__item');
  allItems.forEach(function(i) { i.classList.remove('is-open'); });
  {% endif %}
  if (!isOpen) item.classList.add('is-open');
}
</script>

{% schema %}
{
  "name": "Product Accordion Blocks",
  "tag": "section",
  "class": "section-product-accordion-blocks",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "one_at_a_time",
      "label": "Close others when one opens",
      "default": true
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 32,
      "max": 64,
      "step": 4,
      "unit": "px",
      "label": "Icon circle size",
      "default": 44
    },
    {
      "type": "color",
      "id": "icon_border_color",
      "label": "Icon circle border",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "font_family",
      "label": "Font family",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Theme default" },
        { "value": "Arial, sans-serif", "label": "Arial" },
        { "value": "'Helvetica Neue', Helvetica, sans-serif", "label": "Helvetica" },
        { "value": "Georgia, serif", "label": "Georgia" },
        { "value": "'Courier New', monospace", "label": "Courier New" }
      ]
    },
    {
      "type": "range",
      "id": "label_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Label font size",
      "default": 13
    },
    {
      "type": "select",
      "id": "label_weight",
      "label": "Label font weight",
      "default": "600",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "range",
      "id": "content_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Content font size",
      "default": 14
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider color",
      "default": "#e0e0e0"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label & plus color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "content_color",
      "label": "Content text color",
      "default": "#555555"
    }
  ],
  "blocks": [
    {
      "type": "accordion_item",
      "name": "Accordion Item",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG code",
          "info": "Paste your SVG icon code here. Leave blank for default icon."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "PRODUCT DESCRIPTION"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Add your content here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Accordion Blocks",
      "blocks": [
        {
          "type": "accordion_item",
          "settings": {
            "label": "PRODUCT DESCRIPTION"
          }
        },
        {
          "type": "accordion_item",
          "settings": {
            "label": "LOCALLY CRAFTED"
          }
        },
        {
          "type": "accordion_item",
          "settings": {
            "label": "OUTDOOR TESTED"
          }
        }
      ]
    }
  ]
}
{% endschema %}
