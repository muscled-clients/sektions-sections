{% comment %}
  PLP Promo Header
  Promotional collection banner with event label, headline, badge offer,
  subtitle, and decorative sparkle/starburst accents — Kind Laundry
{% endcomment %}

{%- style -%}
  .pph--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
