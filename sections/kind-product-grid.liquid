{% comment %}
  Kind Product Grid
  3-column product card grid with star ratings — Kind Laundry style
  Cards: #f8f8f8 bg, product image, 5 gold stars, title, teal price
{% endcomment %}

{%- style -%}
  .kpg--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  }
{%- endstyle -%}

<section class="kpg kpg--{{ section.id }}">
  <div class="kpg__inner">

    {%- if section.settings.heading != blank -%}
      <h2 class="kpg__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="kpg__grid kpg__grid--{{ section.settings.columns }}col">
        {%- for block in section.blocks -%}
          {%- assign card_product = block.settings.product -%}
          {%- assign star_count = block.settings.star_rating | default: 5 -%}

          <div class="kpg__card" {{ block.shopify_attributes }}>
            {%- comment -%} Product image {%- endcomment -%}
            <a
              href="{% if card_product != blank %}{{ card_product.url }}{% else %}#{% endif %}"
              class="kpg__img-link"
              {% if card_product == blank %}tabindex="-1" aria-hidden="true"{% endif %}
            >
              <div class="kpg__img-wrap">
                {%- if card_product != blank and card_product.featured_image -%}
                  {%- assign img_alt = card_product.featured_image.alt | default: card_product.title | escape -%}
                  {{
                    card_product.featured_image
                    | image_url: width: 640
                    | image_tag:
                      loading: 'lazy',
                      alt: img_alt,
                      class: 'kpg__img',
                      widths: '321, 480, 640'
                  }}
                {%- elsif block.settings.custom_image -%}
                  {%- assign custom_alt = block.settings.custom_title | default: 'Product' | escape -%}
                  {{
                    block.settings.custom_image
                    | image_url: width: 640
                    | image_tag: loading: 'lazy', alt: custom_alt, class: 'kpg__img'
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'kpg__img kpg__img--placeholder' }}
                {%- endif -%}
              </div>
            </a>

            {%- comment -%} Stars {%- endcomment -%}
            <div class="kpg__stars" aria-label="{{ star_count }} out of 5 stars">
              {%- for i in (1..5) -%}
                {%- if i <= star_count -%}
                  <svg class="kpg__star kpg__star--filled" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                    <path d="M9 1.5L11.163 6.31L16.5 6.927L12.75 10.477L13.826 15.75L9 13.077L4.174 15.75L5.25 10.477L1.5 6.927L6.837 6.31L9 1.5Z" fill="#FFD11B"/>
                  </svg>
                {%- else -%}
                  <svg class="kpg__star kpg__star--empty" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                    <path d="M9 1.5L11.163 6.31L16.5 6.927L12.75 10.477L13.826 15.75L9 13.077L4.174 15.75L5.25 10.477L1.5 6.927L6.837 6.31L9 1.5Z" fill="none" stroke="#FFD11B" stroke-width="1.2"/>
                  </svg>
                {%- endif -%}
              {%- endfor -%}
            </div>

            {%- comment -%} Title {%- endcomment -%}
            <h3 class="kpg__title">
              <a href="{% if card_product != blank %}{{ card_product.url }}{% else %}#{% endif %}" class="kpg__title-link">
                {%- if card_product != blank -%}
                  {{ card_product.title | escape }}
                {%- elsif block.settings.custom_title != blank -%}
                  {{ block.settings.custom_title | escape }}
                {%- else -%}
                  Product Title
                {%- endif -%}
              </a>
            </h3>

            {%- comment -%} Price {%- endcomment -%}
            <p class="kpg__price">
              {%- if card_product != blank -%}
                {%- if card_product.compare_at_price > card_product.price -%}
                  <s class="kpg__price-compare">{{ card_product.compare_at_price | money_with_currency }}</s>
                {%- endif -%}
                <span class="kpg__price-sale">{{ card_product.price | money_with_currency }}</span>
              {%- elsif block.settings.custom_price != blank -%}
                <span class="kpg__price-sale">{{ block.settings.custom_price | escape }}</span>
              {%- endif -%}
            </p>

          </div>
        {%- endfor -%}
      </div>

      {%- if section.settings.show_view_all and section.settings.view_all_url != blank -%}
        <div class="kpg__footer">
          <a href="{{ section.settings.view_all_url }}" class="kpg__view-all">
            {{ section.settings.view_all_label | default: 'View All' | escape }}
          </a>
        </div>
      {%- endif -%}

    {%- else -%}
      {%- comment -%} Placeholder when no blocks added {%- endcomment -%}
      <div class="kpg__grid kpg__grid--3col">
        {%- for i in (1..3) -%}
          <div class="kpg__card">
            <div class="kpg__img-wrap">
              {{ 'product-' | append: i | placeholder_svg_tag: 'kpg__img kpg__img--placeholder' }}
            </div>
            <div class="kpg__stars">
              {%- for s in (1..5) -%}
                <svg class="kpg__star kpg__star--filled" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <path d="M9 1.5L11.163 6.31L16.5 6.927L12.75 10.477L13.826 15.75L9 13.077L4.174 15.75L5.25 10.477L1.5 6.927L6.837 6.31L9 1.5Z" fill="#FFD11B"/>
                </svg>
              {%- endfor -%}
            </div>
            <h3 class="kpg__title"><span class="kpg__title-link">Product Title</span></h3>
            <p class="kpg__price"><span class="kpg__price-sale">$54.00 USD</span></p>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

<style>
/* ── Root ──────────────────────────────────────────────────────────────────── */
.kpg {
  font-family: 'Inter', sans-serif;
}

.kpg__inner {
  max-width: 1200px;
  margin: 0 auto;
  padding-left: 24px;
  padding-right: 24px;
  display: flex;
  flex-direction: column;
  gap: 40px;
}

/* ── Section heading ───────────────────────────────────────────────────────── */
.kpg__heading {
  margin: 0;
  font-size: 32px;
  font-weight: 700;
  color: #222;
  text-align: center;
}

/* ── Grid ──────────────────────────────────────────────────────────────────── */
.kpg__grid {
  display: grid;
  gap: 20px;
  row-gap: 70px;
}
.kpg__grid--3col { grid-template-columns: repeat(3, 1fr); }
.kpg__grid--2col { grid-template-columns: repeat(2, 1fr); }
.kpg__grid--4col { grid-template-columns: repeat(4, 1fr); }

/* ── Card ──────────────────────────────────────────────────────────────────── */
.kpg__card {
  background: #f8f8f8;
  border-radius: 6px;
  padding: 34px 23px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 27px;
  overflow: hidden;
}

/* ── Image ─────────────────────────────────────────────────────────────────── */
.kpg__img-link {
  display: block;
  width: 100%;
  text-decoration: none;
}
.kpg__img-wrap {
  width: 100%;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  border-radius: 2px;
}
.kpg__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.35s ease;
}
.kpg__img-link:hover .kpg__img {
  transform: scale(1.04);
}
.kpg__img--placeholder {
  width: 100%;
  height: 100%;
  background: #e8e8e8;
}

/* ── Stars ─────────────────────────────────────────────────────────────────── */
.kpg__stars {
  display: flex;
  align-items: center;
  gap: 3px;
}
.kpg__star {
  flex-shrink: 0;
}

/* ── Title ─────────────────────────────────────────────────────────────────── */
.kpg__title {
  margin: 0;
  font-size: 22px;
  font-weight: 600;
  color: #222;
  text-align: center;
  line-height: 35px;
}
.kpg__title-link {
  color: inherit;
  text-decoration: none;
}
.kpg__title-link:hover {
  text-decoration: underline;
}

/* ── Price ─────────────────────────────────────────────────────────────────── */
.kpg__price {
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  flex-wrap: wrap;
}
.kpg__price-sale {
  font-size: 30px;
  font-weight: 600;
  color: #269b9a;
  text-align: center;
  line-height: 1.3;
}
.kpg__price-compare {
  font-size: 20px;
  font-weight: 400;
  color: #999;
  text-decoration: line-through;
}

/* ── View all ──────────────────────────────────────────────────────────────── */
.kpg__footer {
  display: flex;
  justify-content: center;
}
.kpg__view-all {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14px 40px;
  border: 2px solid #269b9a;
  border-radius: 4px;
  color: #269b9a;
  font-size: 16px;
  font-weight: 600;
  text-decoration: none;
  transition: background 0.2s ease, color 0.2s ease;
}
.kpg__view-all:hover {
  background: #269b9a;
  color: #fff;
}

/* ── Responsive ────────────────────────────────────────────────────────────── */
@media screen and (max-width: 1024px) {
  .kpg__grid--4col { grid-template-columns: repeat(3, 1fr); }
}

@media screen and (max-width: 749px) {
  .kpg__grid--3col,
  .kpg__grid--4col { grid-template-columns: repeat(2, 1fr); }
  .kpg__grid { row-gap: 32px; }
  .kpg__title { font-size: 16px; line-height: 26px; }
  .kpg__price-sale { font-size: 22px; }
  .kpg__card { padding: 20px 16px; gap: 16px; }
}

@media screen and (max-width: 480px) {
  .kpg__grid--2col,
  .kpg__grid--3col,
  .kpg__grid--4col { grid-template-columns: 1fr; }
}
</style>

{% schema %}
{
  "name": "Kind Product Grid",
  "tag": "section",
  "class": "kind-product-grid-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "placeholder": "e.g. Our Products"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "3"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View All' button",
      "default": false
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View All URL"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View All button label",
      "default": "View All"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "label": "Top padding",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "label": "Bottom padding",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "range",
          "id": "star_rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Star rating",
          "default": 5
        },
        {
          "type": "header",
          "content": "Fallback (no product selected)"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom image"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom title",
          "default": "Eco-Friendly Laundry Detergent Sheets"
        },
        {
          "type": "text",
          "id": "custom_price",
          "label": "Custom price",
          "default": "$54.00 USD"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kind Product Grid",
      "blocks": [
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}
