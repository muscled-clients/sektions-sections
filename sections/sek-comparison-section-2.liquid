{%- style -%}
  /* Section Scoped Styles for comparison-section-2 */

  /* Base Section */
  #shopify-section-{{ section.id }} .comparison-2-section {
    position: relative;
    width: 100%;
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .comparison-2-section {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #shopify-section-{{ section.id }} .comparison-2__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Heading */
  #shopify-section-{{ section.id }} .comparison-2__heading {
    text-align: center;
    font-family: var(--font-heading-family, Georgia, serif);
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin: 0 0 3rem 0;
    letter-spacing: 0.02em;
  }

  /* Main Content Layout */
  #shopify-section-{{ section.id }} .comparison-2__content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    position: relative;
  }

  /* Images */
  #shopify-section-{{ section.id }} .comparison-2__image {
    flex: 0 0 auto;
    width: 360px;
    height: 270px;
    overflow: hidden;
    border-radius: 8px;
  }

  #shopify-section-{{ section.id }} .comparison-2__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .comparison-2__image .placeholder-svg {
    width: 100%;
    height: 270px;
    background-color: #f0f0f0;
  }

  /* Comparison Table */
  #shopify-section-{{ section.id }} .comparison-2__table {
    flex: 1;
    max-width: 500px;
    position: relative;
  }

  #shopify-section-{{ section.id }} .comparison-2__rows {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Each Row */
  #shopify-section-{{ section.id }} .comparison-2__row {
    display: flex;
    position: relative;
    gap: 5px;
    margin-bottom: 5px;
  }

  /* Cells */
  #shopify-section-{{ section.id }} .comparison-2__cell {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 20px;
    border: 1px solid {{ section.settings.cell_border_color }};
    background-color: {{ section.settings.cell_bg_color }};
    margin: -0.5px;
  }

  #shopify-section-{{ section.id }} .comparison-2__cell--left {
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .comparison-2__cell--right {
    justify-content: center;
  }

  /* Icons */
  #shopify-section-{{ section.id }} .comparison-2__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .comparison-2__icon svg {
    width: 20px;
    height: 20px;
  }

  /* Text */
  #shopify-section-{{ section.id }} .comparison-2__text {
    font-family: var(--font-body-family, sans-serif);
    font-size: 15px;
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .comparison-2__text--positive {
    color: {{ section.settings.positive_text_color }};
  }

  #shopify-section-{{ section.id }} .comparison-2__text--negative {
    color: {{ section.settings.negative_text_color }};
  }

  /* VS Badge */
  #shopify-section-{{ section.id }} .comparison-2__vs {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 50px;
    height: 50px;
    background-color: {{ section.settings.vs_bg_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
  }

  #shopify-section-{{ section.id }} .comparison-2__vs span {
    font-family: var(--font-body-family, sans-serif);
    font-size: 14px;
    font-weight: 700;
    color: {{ section.settings.vs_text_color }};
    letter-spacing: 0.05em;
  }

  /* Mobile VS Badge - hidden on desktop */
  #shopify-section-{{ section.id }} .comparison-2__vs--mobile {
    display: none;
  }

  /* Button */
  #shopify-section-{{ section.id }} .comparison-2__button-wrapper {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
  }

  #shopify-section-{{ section.id }} .comparison-2__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 40px;
    background-color: {{ section.settings.button_bg_color }};
    color: {{ section.settings.button_text_color }};
    font-family: var(--font-body-family, sans-serif);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    border-radius: 50px;
    border: none;
    transition: all 0.25s ease;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  #shopify-section-{{ section.id }} .comparison-2__button:hover {
    opacity: 0.9;
  }

  /* Responsive Styles */

  /* Tablet */
  @media screen and (max-width: 1024px) {
    #shopify-section-{{ section.id }} .comparison-2__image {
      width: 280px;
      height: 210px;
    }

    #shopify-section-{{ section.id }} .comparison-2__table {
      max-width: 400px;
    }

    #shopify-section-{{ section.id }} .comparison-2__cell {
      padding: 12px 15px;
    }

    #shopify-section-{{ section.id }} .comparison-2__text {
      font-size: 14px;
    }
  }

  /* Mobile */
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .comparison-2__container {
      padding: 0 1rem;
    }

    #shopify-section-{{ section.id }} .comparison-2__heading {
      font-size: calc({{ section.settings.heading_size }}px * 0.67);
      margin-bottom: 2rem;
    }

    #shopify-section-{{ section.id }} .comparison-2__content {
      flex-wrap: wrap;
      gap: 1rem;
      position: relative;
    }

    #shopify-section-{{ section.id }} .comparison-2__image {
      width: calc(50% - 0.5rem);
      height: auto;
      max-width: none;
      order: 0;
    }

    #shopify-section-{{ section.id }} .comparison-2__image--left {
      order: 0;
    }

    #shopify-section-{{ section.id }} .comparison-2__image--right {
      order: 1;
    }

    #shopify-section-{{ section.id }} .comparison-2__table {
      width: 100%;
      max-width: 100%;
      order: 2;
    }

    #shopify-section-{{ section.id }} .comparison-2__cell {
      padding: 12px 10px;
      gap: 8px;
    }

    #shopify-section-{{ section.id }} .comparison-2__text {
      font-size: 13px;
    }

    /* Hide VS in table on mobile */
    #shopify-section-{{ section.id }} .comparison-2__row .comparison-2__vs {
      display: none;
    }

    /* Show VS between images on mobile */
    #shopify-section-{{ section.id }} .comparison-2__vs--mobile {
      display: flex;
      position: absolute;
      left: 50%;
      transform: translate(-50%, -50%);
      top: calc((50vw - 1rem) / 2);
      width: 40px;
      height: 40px;
    }

    #shopify-section-{{ section.id }} .comparison-2__vs--mobile span {
      font-size: 12px;
    }

    #shopify-section-{{ section.id }} .comparison-2__button {
      width: 100%;
      max-width: 300px;
    }
  }

{%- endstyle -%}

<div class="comparison-2-section">
  <div class="comparison-2__container">
    <!-- Heading -->
    {%- if section.settings.heading != blank -%}
      <h2 class="comparison-2__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <!-- Main Content -->
    <div class="comparison-2__content">
      <!-- Mobile VS Badge -->
      <div class="comparison-2__vs comparison-2__vs--mobile">
        <span>VS</span>
      </div>

      <!-- Left Image -->
      <div class="comparison-2__image comparison-2__image--left">
        {%- if section.settings.left_image != blank -%}
          <img
            src="{{ section.settings.left_image | image_url: width: 600 }}"
            alt="{{ section.settings.left_image.alt | default: 'Our product' | escape }}"
            loading="lazy"
            width="600"
            height="{{ 600 | divided_by: section.settings.left_image.aspect_ratio | round }}"
          >
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>

      <!-- Comparison Table -->
      <div class="comparison-2__table">
        <div class="comparison-2__rows">
          {%- assign middle_index = section.blocks.size | divided_by: 2 -%}
          {%- for block in section.blocks -%}
            <div class="comparison-2__row" {{ block.shopify_attributes }}>
              <!-- Left Column (Positive) -->
              <div class="comparison-2__cell comparison-2__cell--left">
                <span class="comparison-2__icon">
                  <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="11" cy="11" r="11" fill="{{ section.settings.positive_icon_color }}"/>
                    <path d="M6.5 11L9.5 14L15.5 8" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                <span class="comparison-2__text comparison-2__text--positive">{{ block.settings.left_text }}</span>
              </div>

              <!-- VS Badge (only show on middle row) -->
              {%- if forloop.index0 == middle_index -%}
                <div class="comparison-2__vs">
                  <span>VS</span>
                </div>
              {%- endif -%}

              <!-- Right Column (Negative) -->
              <div class="comparison-2__cell comparison-2__cell--right">
                <span class="comparison-2__icon">
                  <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="11" cy="11" r="11" fill="{{ section.settings.negative_icon_color }}"/>
                    <path d="M7.5 7.5L14.5 14.5M14.5 7.5L7.5 14.5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                <span class="comparison-2__text comparison-2__text--negative">{{ block.settings.right_text }}</span>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>

      <!-- Right Image -->
      <div class="comparison-2__image comparison-2__image--right">
        {%- if section.settings.right_image != blank -%}
          <img
            src="{{ section.settings.right_image | image_url: width: 600 }}"
            alt="{{ section.settings.right_image.alt | default: 'Competitor product' | escape }}"
            loading="lazy"
            width="600"
            height="{{ 600 | divided_by: section.settings.right_image.aspect_ratio | round }}"
          >
        {%- else -%}
          {{ 'product-2' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    </div>

    <!-- Button -->
    {%- if section.settings.button_text != blank -%}
      <div class="comparison-2__button-wrapper">
        <a href="{{ section.settings.button_link }}" class="comparison-2__button">
          {{ section.settings.button_text }}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

<script>
  (function() {
    const sectionId = '{{ section.id }}';
    const section = document.querySelector('#shopify-section-' + sectionId);

    if (section) {
      // Add any interactive functionality here if needed
      const button = section.querySelector('.comparison-2__button');
      if (button) {
        button.addEventListener('mouseenter', function() {
          this.style.boxShadow = '0 4px 15px rgba(0, 0, 0, 0.2)';
        });
        button.addEventListener('mouseleave', function() {
          this.style.boxShadow = 'none';
        });
      }
    }
  })();
</script>

