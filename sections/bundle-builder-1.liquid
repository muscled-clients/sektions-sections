{{ 'bundle-builder.css' | asset_url | stylesheet_tag }}

<div class="bundle-builder" data-section-id="{{ section.id }}" style="background-color: {{ section.settings.background_color }};">
  <div class="bundle-builder__container full-width-container">
    <!-- Mobile Heading -->
    <div class="bundle-builder__mobile-heading">
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.subheading }}</p>
    </div>

    <div class="bundle-builder__body">
      <!-- Main Content (Left) -->
      <div class="bundle-builder__content">
        <!-- Desktop Heading -->
        <div class="bundle-builder__desktop-heading">
          <h1>{{ section.settings.heading }}</h1>
          <p>{{ section.settings.subheading }}</p>
        </div>

<!-- Pack Size Selection -->
<div class="bundle-builder__size-wrapper">
  <h3 class="bundle-builder__size-title">{{ section.settings.size_label }}</h3>
  <div class="bundle-builder__size-buttons">
    {% for block in section.blocks %}
      {% if block.type == 'size_option' %}
        {% assign discount_value = block.settings.discount | plus: 0 %}
        {% assign pack_size = block.settings.pack_size | plus: 0 %}
        
        <button class="bundle-builder__size-button {% if forloop.first %}active{% endif %}" 
                data-pack-size="{{ pack_size }}"
                data-pack-discount="{{ discount_value }}">
          
          <!-- Uploaded Badge Image -->
          {% if block.settings.badge_image != blank %}
            <img class="bundle-builder__size-badge bundle-builder__size-badge--png" 
                 src="{{ block.settings.badge_image | img_url: '170x170' }}" 
                 srcset="{{ block.settings.badge_image | img_url: '170x170' }} 2x"
                 alt="{{ pack_size }} Pack - {{ discount_value }}% OFF"
                 loading="lazy"
                 width="85"
                 height="85">
          {% else %}
            <!-- Fallback text badge if no image uploaded -->
            <span class="bundle-builder__size-badge bundle-builder__size-badge--text">
              {{ discount_value }}% OFF
            </span>
          {% endif %}
          
          <!-- Optional Icon Image -->
          {% if block.settings.icon != blank %}
            <img src="{{ block.settings.icon | img_url: '120x' }}" 
                 alt="{{ block.settings.pack_size }} Pack" 
                 class="bundle-builder__size-icon" 
                 loading="lazy">
          {% endif %}
          
          {{ pack_size }} Pack
        </button>
      {% endif %}
    {% endfor %}
  </div>
</div>

        <!-- Product Filter -->
        <div class="bundle-builder__filter-wrapper">
          <h3 class="bundle-builder__filter-title">{{ section.settings.filter_label }}</h3>
          <div class="bundle-builder__filter-buttons">
            <button class="bundle-builder__filter-button active" data-filter="all">All Products</button>
            {% assign all_tags = '' %}
            {% for product in collections[section.settings.collection].products %}
              {% for tag in product.tags %}
                {% unless all_tags contains tag %}
                  {% assign all_tags = all_tags | append: tag | append: ',' %}
                  <button class="bundle-builder__filter-button" data-filter="{{ tag | handleize }}">{{ tag }}</button>
                {% endunless %}
              {% endfor %}
            {% endfor %}
          </div>
        </div>

        <!-- Products Grid -->
        <div class="bundle-builder__products-wrapper">
          <div class="bundle-builder__products-grid">
            {% for product in collections[section.settings.collection].products %}
              {% assign first_variant = product.variants.first %}
              <div class="bundle-builder__product" 
                   data-product-id="{{ product.id }}"
                   data-product-handle="{{ product.handle }}"
                   data-first-variant-id="{{ first_variant.id }}"
                   data-first-variant-price="{{ first_variant.price }}"
                   data-first-variant-image="{{ first_variant.featured_image | default: product.featured_image | img_url: '200x' }}"
                   data-title="{{ product.title }}"
                   data-url="{{ product.url }}"
                   data-tags="{{ product.tags | join: ',' | downcase }}">
                <div class="bundle-builder__product-top">
                  <div class="bundle-builder__product-image">
                    <img src="{{ product.featured_image | img_url: '300x' }}" 
                         alt="{{ product.title }}"
                         loading="lazy">
                  </div>
                  <p class="bundle-builder__product-title">{{ product.title }}</p>
                </div>

                <div class="bundle-builder__product-bottom">
                  {% if product.variants.size > 1 %}
                    <div class="bundle-builder__variant-selector">
                      <select class="bundle-builder__variant-select">
                        {% for variant in product.variants %}
                          <option value="{{ variant.id }}" 
                                  data-price="{{ variant.price }}" 
                                  {% if variant.featured_image %}
                                    data-image="{{ variant.featured_image | img_url: '200x' }}"
                                  {% else %}
                                    data-image="{{ product.featured_image | img_url: '200x' }}"
                                  {% endif %}
                                  {% if forloop.first %}selected{% endif %}>
                            {{ variant.title }}
                          </option>
                        {% endfor %}
                      </select>
                    </div>
                  {% endif %}

                  <div class="bundle-builder__quantity-wrapper">
                    <button class="bundle-builder__quantity-minus" type="button">
                      <svg width="12" height="2" viewBox="0 0 12 2" fill="none">
                        <rect width="12" height="2" rx="1" fill="#121212"></rect>
                      </svg>
                    </button>
                    <p class="bundle-builder__quantity">1</p>
                    <button class="bundle-builder__quantity-plus" type="button">
                      <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                        <path d="M6.75 5.25V0.75C6.75 0.335786 6.41421 0 6 0C5.58579 0 5.25 0.335786 5.25 0.75V5.25H0.75C0.335786 5.25 0 5.58579 0 6C0 6.41421 0.335786 6.75 0.75 6.75H5.25V11.25C5.25 11.6642 5.58579 12 6 12C6.41421 12 6.75 11.6642 6.75 11.25V6.75H11.25C11.6642 6.75 12 6.41421 12 6C12 5.58579 11.6642 5.25 11.25 5.25H6.75Z" fill="#121212"></path>
                      </svg>
                    </button>
                  </div>
                 
                  <button class="bundle-builder__add-button" type="button">
                    <span class="bundle-builder__add-button-inner">
                      ADD - {{ first_variant.price | money }}
                    </span>
                  </button>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>

      <!-- Sidebar (Right) -->
      <div class="bundle-builder__sidebar-wrapper">
        <div class="bundle-builder__sidebar-sticky">
          <div class="bundle-builder__sidebar">
            <div class="bundle-builder__sidebar-heading">
              <h2>{{ section.settings.bundle_title }}</h2>
            </div>

            <!-- Selected Products -->
            <div class="bundle-builder__sidebar-products">
              <!-- Empty slots will be rendered here by JavaScript -->
            </div>

            <!-- Price Summary -->
            <div class="bundle-builder__sidebar-price">
              <div class="bundle-builder__price-row">
                <span>Subtotal</span>
                <span class="bundle-builder__subtotal-value">$0.00</span>
              </div>
              <div class="bundle-builder__price-row bundle-builder__price-row--savings">
                <span>Bundle Savings</span>
                <span class="bundle-builder__savings-value">- $0.00</span>
              </div>
              <div class="bundle-builder__price-row bundle-builder__price-row--total">
                <span>Total</span>
                <span class="bundle-builder__total-value">$0.00</span>
              </div>
            </div>

            <!-- Add to Cart Form -->
            <form class="bundle-builder__form" method="post" action="/cart/add" accept-charset="UTF-8" enctype="multipart/form-data">
              <button type="submit" class="bundle-builder__submit-button" disabled>
                {{ section.settings.button_label }}
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
