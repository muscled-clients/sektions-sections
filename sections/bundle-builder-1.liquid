  pointer-events: none;
  z-index: 2;
  background-color: #ff4f2c;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 14px;
  font-weight: 700;
  font-family: 'Bricolage Grotesque', sans-serif;
  text-align: center;
  padding: 5px;
  filter: drop-shadow(0px 2px 4px rgba(0, 0, 0, 0.2));
