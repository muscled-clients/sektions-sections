  }

  .bundle-builder__sidebar-products {
    grid-template-columns: repeat(2, 1fr);
  }
  
  /* Optional: Adjust font sizes for better fit */
  .bundle-builder__product-title {
    font-size: 10px;
    margin: 6px 4px 0;
  }
  
  .bundle-builder__add-button {
    padding: 12px 8px;
    font-size: 11px;
  }
