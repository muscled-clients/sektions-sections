.bundle-builder__filter-buttons {
    display: flex;
    gap: 10px;
}
</style>

<script>
  class BundleBuilder {
    constructor(sectionId) {
      this.sectionId = sectionId;
      this.currentPackSize = this.getInitialPackSize();
      this.currentPackDiscount = this.getInitialPackDiscount();
      this.selectedProducts = {};
      this.currentFilterTag = 'all';
      
      this.init();
    }

    getInitialPackSize() {
      const activeSizeButton = document.querySelector(`[data-section-id="${this.sectionId}"] .bundle-builder__size-button.active`);
      if (activeSizeButton) {
        return parseInt(activeSizeButton.dataset.packSize) || 2;
      }
      return 2;
    }

    getInitialPackDiscount() {
      const activeSizeButton = document.querySelector(`[data-section-id="${this.sectionId}"] .bundle-builder__size-button.active`);
      if (activeSizeButton) {
        return parseInt(activeSizeButton.dataset.packDiscount) || 10;
      }
      return 10;
    }

    init() {
      this.setupSizeButtons();
      this.setupFilterButtons();
      this.setupProductButtons();
      this.setupRemoveButtons();
      this.setupFormSubmission();
      this.renderSidebarSlots();
      this.updateTotalPrice();
      this.setupStickySidebar();
    }

    formatMoney(cents) {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        minimumFractionDigits: 2
      }).format(cents / 100);
    }

    calculateDiscountedPrice(originalPrice, discountPercent) {
      const discountAmount = (originalPrice * discountPercent) / 100;
      return Math.round(originalPrice - discountAmount);
    }

    setupSizeButtons() {
      const sizeButtons = document.querySelectorAll(`[data-section-id="${this.sectionId}"] .bundle-builder__size-button`);
      sizeButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          sizeButtons.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          
          const newPackSize = parseInt(btn.dataset.packSize);
          const newPackDiscount = parseInt(btn.dataset.packDiscount);
          
          // Remove excess products if switching to a smaller pack size
          this.handlePackSizeChange(newPackSize, newPackDiscount);
        });
      });
    }

    handlePackSizeChange(newPackSize, newPackDiscount) {
      const totalCount = this.getTotalProductCount();
      
      // If switching to a smaller pack size and we have more products than the new pack size
      if (totalCount > newPackSize) {
        // Calculate how many products to remove
        const productsToRemove = totalCount - newPackSize;
        
        // Create an array of product IDs to remove (starting from the end)
        const productIds = Object.keys(this.selectedProducts);
        let removedCount = 0;
        
        // Remove products until we reach the new pack size
        for (let i = productIds.length - 1; i >= 0 && removedCount < productsToRemove; i--) {
          const variantId = productIds[i];
          const product = this.selectedProducts[variantId];
          
          // Reduce quantity or remove the product
          if (product.quantity > 1) {
            // Reduce quantity if product has more than 1
            const reduceBy = Math.min(product.quantity - 1, productsToRemove - removedCount);
            product.quantity -= reduceBy;
            removedCount += reduceBy;
            
            // Update the displayed quantity in the product card
            this.updateProductQuantityDisplay(variantId, product.quantity);
            
            // If quantity becomes 0, remove the product
            if (product.quantity === 0) {
              delete this.selectedProducts[variantId];
              this.updateProductActiveState(variantId, false);
            }
          } else {
            // Remove the product completely
            delete this.selectedProducts[variantId];
            this.updateProductActiveState(variantId, false);
            removedCount += 1;
          }
        }
      }
      
      // Update pack size and discount
      this.currentPackSize = newPackSize;
      this.currentPackDiscount = newPackDiscount;
      
      this.updateProductLimits();
      this.renderSidebarSlots();
      this.updateTotalPrice();
    }

    updateProductQuantityDisplay(variantId, newQuantity) {
      // Find and update the quantity display for this variant
      const products = document.querySelectorAll(`[data-section-id="${this.sectionId}"] .bundle-builder__product`);
      products.forEach(product => {
        const variantSelect = product.querySelector('.bundle-builder__variant-select');
        const currentVariantId = variantSelect ? variantSelect.value : product.dataset.firstVariantId;
        const quantityElement = product.querySelector('.bundle-builder__quantity');
        
        if (currentVariantId === variantId && quantityElement) {
          quantityElement.textContent = newQuantity;
        }
      });
    }

    updateProductActiveState(variantId, isActive) {
      // Find and update the active state for this variant
      const products = document.querySelectorAll(`[data-section-id="${this.sectionId}"] .bundle-builder__product`);
      products.forEach(product => {
        const variantSelect = product.querySelector('.bundle-builder__variant-select');
        const currentVariantId = variantSelect ? variantSelect.value : product.dataset.firstVariantId;
        
        if (currentVariantId === variantId) {
          if (isActive) {
            product.classList.add('active');
          } else {
            product.classList.remove('active');
            // Reset quantity display to 1
            const quantityElement = product.querySelector('.bundle-builder__quantity');
            if (quantityElement) {
              quantityElement.textContent = '1';
            }
          }
        }
      });
    }

    setupFilterButtons() {
      const filterButtons = document.querySelectorAll(`[data-section-id="${this.sectionId}"] .bundle-builder__filter-button`);
      const products = document.querySelectorAll(`[data-section-id="${this.sectionId}"] .bundle-builder__product`);

      filterButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          filterButtons.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          
          this.currentFilterTag = btn.dataset.filter;
          
          products.forEach(product => {
            if (this.currentFilterTag === 'all') {
              product.style.display = '';
              return;
            }
            
            const productTags = product.dataset.tags.toLowerCase().split(',');
            const hasTag = productTags.includes(this.currentFilterTag);
            product.style.display = hasTag ? '' : 'none';
          });
        });
      });
    }

    setupProductButtons() {
      const products = document.querySelectorAll(`[data-section-id="${this.sectionId}"] .bundle-builder__product`);
      
      products.forEach(product => {
        const addButton = product.querySelector('.bundle-builder__add-button');
        const minusButton = product.querySelector('.bundle-builder__quantity-minus');
        const plusButton = product.querySelector('.bundle-builder__quantity-plus');
        const quantityElement = product.querySelector('.bundle-builder__quantity');
        const variantSelect = product.querySelector('.bundle-builder__variant-select');

        addButton.addEventListener('click', () => {
          if (product.classList.contains('limit')) return;
          
          const totalCount = this.getTotalProductCount();
          if (totalCount >= this.currentPackSize) {
            return; // Don't allow adding more products than the pack size
          }
          
          let variantId;
          let variantPrice;
          let variantImage;
          let variantTitle = '';
          
          if (variantSelect) {
            variantId = variantSelect.value;
            const selectedOption = variantSelect.options[variantSelect.selectedIndex];
            variantPrice = parseInt(selectedOption.dataset.price);
            variantImage = selectedOption.dataset.image || product.dataset.image;
            variantTitle = selectedOption.textContent.trim();
          } else {
            variantId = product.dataset.firstVariantId;
            variantPrice = parseInt(product.dataset.firstVariantPrice);
            variantImage = product.dataset.firstVariantImage;
          }
          
          if (!variantId || variantId === 'undefined') {
            console.error('No valid variant ID found for product:', product.dataset.title);
            return;
          }
          
          const productData = {
            id: variantId,
            price: variantPrice,
            image: variantImage,
            title: product.dataset.title,
            url: product.dataset.url,
            variantTitle: variantTitle,
            quantity: 1
          };

          if (this.selectedProducts[variantId]) {
            this.selectedProducts[variantId].quantity++;
            // Update the displayed quantity in the product card
            if (quantityElement) {
              quantityElement.textContent = this.selectedProducts[variantId].quantity;
            }
          } else {
            this.selectedProducts[variantId] = productData;
            // Set the displayed quantity to 1 when first adding
            if (quantityElement) {
              quantityElement.textContent = '1';
            }
          }

          product.classList.add('active');
          this.updateProductLimits();
          this.renderSidebarSlots();
          this.updateTotalPrice();
        });

        if (minusButton) {
          minusButton.addEventListener('click', (e) => {
            e.stopPropagation();
            const variantSelect = product.querySelector('.bundle-builder__variant-select');
            const variantId = variantSelect ? variantSelect.value : product.dataset.firstVariantId;
            
            if (this.selectedProducts[variantId]) {
              this.selectedProducts[variantId].quantity--;
              
              // Update the displayed quantity in the product card
              if (quantityElement) {
                quantityElement.textContent = this.selectedProducts[variantId].quantity;
              }
              
              if (this.selectedProducts[variantId].quantity === 0) {
                delete this.selectedProducts[variantId];
                product.classList.remove('active');
              }

              this.updateProductLimits();
              this.renderSidebarSlots();
              this.updateTotalPrice();
            }
          });
        }

        if (plusButton) {
          plusButton.addEventListener('click', (e) => {
            e.stopPropagation();
            const variantSelect = product.querySelector('.bundle-builder__variant-select');
            const variantId = variantSelect ? variantSelect.value : product.dataset.firstVariantId;
            
            if (this.selectedProducts[variantId]) {
              const totalCount = this.getTotalProductCount();
              if (totalCount >= this.currentPackSize) {
                return; // Don't allow adding more if we've reached the pack size limit
              }
              
              this.selectedProducts[variantId].quantity++;
              
              // Update the displayed quantity in the product card
              if (quantityElement) {
                quantityElement.textContent = this.selectedProducts[variantId].quantity;
              }
              
              this.updateProductLimits();
              this.renderSidebarSlots();
              this.updateTotalPrice();
            }
          });
        }

        if (variantSelect) {
          variantSelect.addEventListener('change', () => {
            const newVariantId = variantSelect.value;
            const selectedOption = variantSelect.options[variantSelect.selectedIndex];
            
            const addButtonInner = addButton.querySelector('.bundle-builder__add-button-inner');
            if (addButtonInner) {
              const newPrice = parseInt(selectedOption.dataset.price);
              addButtonInner.textContent = `ADD - ${this.formatMoney(newPrice)}`;
            }

            // Check if the new variant is selected and update quantity display
            if (this.selectedProducts[newVariantId]) {
              product.classList.add('active');
              // Update the quantity display for the new variant
              if (quantityElement) {
                quantityElement.textContent = this.selectedProducts[newVariantId].quantity;
              }
            } else {
              product.classList.remove('active');
            }
          });
        }
      });
    }

    setupRemoveButtons() {
      document.addEventListener('click', (e) => {
        if (e.target.closest('.bundle-builder__remove-button')) {
          const removeBtn = e.target.closest('.bundle-builder__remove-button');
          const variantId = removeBtn.dataset.variantId;
          
          if (this.selectedProducts[variantId]) {
            delete this.selectedProducts[variantId];
            
            // Update all product cards to reset their quantity displays
            const products = document.querySelectorAll(`[data-section-id="${this.sectionId}"] .bundle-builder__product`);
            products.forEach(product => {
              const variantSelect = product.querySelector('.bundle-builder__variant-select');
              const currentVariantId = variantSelect ? variantSelect.value : product.dataset.firstVariantId;
              const quantityElement = product.querySelector('.bundle-builder__quantity');
              
              if (!this.selectedProducts[currentVariantId]) {
                product.classList.remove('active');
                // Reset the quantity display
                if (quantityElement) {
                  quantityElement.textContent = '1';
                }
              }
            });
            
            this.updateProductLimits();
            this.renderSidebarSlots();
            this.updateTotalPrice();
          }
        }
      });
    }

    setupFormSubmission() {
      const form = document.querySelector(`[data-section-id="${this.sectionId}"] .bundle-builder__form`);
      if (!form) return;

      form.addEventListener('submit', (e) => {
        e.preventDefault();
        
        if (Object.keys(this.selectedProducts).length === 0) {
          alert('Please add products to your bundle first');
          return;
        }

        const items = [];
        for (let variantId in this.selectedProducts) {
          const product = this.selectedProducts[variantId];
          // Calculate discounted price for display only
          const discountedPrice = this.calculateDiscountedPrice(product.price, this.currentPackDiscount);
          
          items.push({
            id: variantId,
            quantity: product.quantity,
            properties: {
              '_bundle': 'true',
              '_bundle_pack_size': this.currentPackSize.toString(),
              '_bundle_discount': this.currentPackDiscount.toString() + '%'
            }
          });
        }

        console.log('Adding to cart with automatic discount for pack size:', this.currentPackSize);
        this.addToCart(items);
      });
    }

    addToCart(items) {
      const addToCartBtn = document.querySelector(`[data-section-id="${this.sectionId}"] .bundle-builder__submit-button`);
      
      if (addToCartBtn) {
        addToCartBtn.disabled = true;
        addToCartBtn.textContent = 'Adding...';
      }

      console.log('Starting addToCart process for', items.length, 'items');

      // CRITICAL: Clear cart first to ensure only bundle items are present
      fetch('/cart/clear.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        }
      })
      .then(response => {
        if (!response.ok) {
          throw new Error('Failed to clear cart');
        }
        console.log('Cart cleared successfully');
        
        // Add all bundle items at once
        const formData = {
          items: items
        };
        
        return fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify(formData)
        });
      })
      .then(response => {
        if (!response.ok) {
          throw new Error('Failed to add items to cart');
        }
        return response.json();
      })
      .then(cartData => {
        console.log('Items added to cart:', cartData);
        
        // Verify the correct number of items were added
        const totalQuantity = cartData.items.reduce((sum, item) => sum + item.quantity, 0);
        console.log(`Total quantity: ${totalQuantity}, Expected: ${this.currentPackSize}`);
        
        // Shopify's automatic discount will apply now based on cart conditions
        console.log(`Automatic discount should apply: BUNDLE${this.currentPackSize} (${this.currentPackDiscount}%)`);
        
        // Redirect to cart to see the applied discount
        window.location.href = '/cart';
      })
      .catch(error => {
        console.error('Error in addToCart process:', error);
        alert('Error adding items to cart. Please try again or contact support.');
        
        if (addToCartBtn) {
          addToCartBtn.disabled = false;
          this.updateSubmitButton();
        }
      });
    }

    getTotalProductCount() {
      let total = 0;
      for (let id in this.selectedProducts) {
        total += this.selectedProducts[id].quantity;
      }
      return total;
    }

    updateProductLimits() {
      const totalCount = this.getTotalProductCount();
      const isLimitReached = totalCount >= this.currentPackSize;
      
      const products = document.querySelectorAll(`[data-section-id="${this.sectionId}"] .bundle-builder__product`);
      
      products.forEach(product => {
        const variantSelect = product.querySelector('.bundle-builder__variant-select');
        const currentVariantId = variantSelect ? variantSelect.value : product.dataset.firstVariantId;
        const isSelected = this.selectedProducts.hasOwnProperty(currentVariantId);
        const addButton = product.querySelector('.bundle-builder__add-button');
        const plusButton = product.querySelector('.bundle-builder__quantity-plus');
        
        if (isLimitReached && !isSelected) {
          product.classList.add('limit');
          if (addButton) {
            addButton.disabled = true;
          }
        } else {
          product.classList.remove('limit');
          if (addButton) {
            addButton.disabled = false;
          }
        }
        
        // Also disable plus button if limit is reached
        if (plusButton) {
          if (isLimitReached && isSelected) {
            plusButton.disabled = true;
          } else {
            plusButton.disabled = false;
          }
        }
      });
    }

    renderSidebarSlots() {
      const sidebarContainer = document.querySelector(`[data-section-id="${this.sectionId}"] .bundle-builder__sidebar-products`);
      if (!sidebarContainer) return;
      
      sidebarContainer.innerHTML = '';
      
      const totalCount = this.getTotalProductCount();
      
      if (totalCount === 0) {
        for (let i = 0; i < this.currentPackSize; i++) {
          const emptyDiv = document.createElement('div');
          emptyDiv.className = 'bundle-builder__sidebar-product empty';
          emptyDiv.innerHTML = `
            <div class="bundle-builder__sidebar-product-image empty"></div>
            <div class="bundle-builder__sidebar-product-content">
              <div class="bundle-sidebar-empty-content-template--25377744486729__ss_bundle_builder_6_aAN8ec"></div>
              <div class="bundle-sidebar-empty-content-template--25377744486729__ss_bundle_builder_6_aAN8ec"></div>
            </div>
          `;
          sidebarContainer.appendChild(emptyDiv);
        }
      } else {
        for (let variantId in this.selectedProducts) {
          const product = this.selectedProducts[variantId];
          // Calculate discounted price for display
          const discountedPrice = this.calculateDiscountedPrice(product.price, this.currentPackDiscount);
          
          const productDiv = document.createElement('div');
          productDiv.className = 'bundle-builder__sidebar-product';
          
          productDiv.innerHTML = `
            <div class="bundle-builder__sidebar-product-image">
              <img src="${product.image}" alt="${product.title}" loading="lazy">
              <span class="bundle-builder__product-badge">${product.quantity}</span>
            </div>
            <div class="bundle-builder__sidebar-product-content">
              <p class="bundle-builder__sidebar-product-title">${product.title}${product.variantTitle ? ' - ' + product.variantTitle : ''}</p>
              <p class="bundle-builder__sidebar-product-price">
                <span style="text-decoration: line-through; color: #999; margin-right: 5px;">${this.formatMoney(product.price)}</span>
                <span style="color: #e83a87; font-weight: bold;">${this.formatMoney(discountedPrice)}</span>
              </p>
              <a href="${product.url}" target="_blank" class="bundle-builder__sidebar-product-link">View details</a>
            </div>
          `;

          const removeButton = document.createElement('button');
          removeButton.className = 'bundle-builder__remove-button';
          removeButton.dataset.variantId = variantId;
          removeButton.innerHTML = `
            <svg width="32" height="32" viewBox="0 0 32 32">
              <path d="M32,32H0V0H32V32ZM16,18.121h0l5.333,5.333,2.121-2.121L18.122,16l5.333-5.334-2.121-2.12L16,13.877,10.667,8.545l-2.12,2.12L13.879,16,8.546,21.333l2.12,2.121L16,18.121Z" fill="#000"></path>
            </svg>
          `;

          removeButton.addEventListener('click', (e) => {
            e.preventDefault();
            delete this.selectedProducts[variantId];
            this.updateProductLimits();
            this.renderSidebarSlots();
            this.updateTotalPrice();
          });

          productDiv.appendChild(removeButton);
          sidebarContainer.appendChild(productDiv);
        }
        
        const emptySlots = this.currentPackSize - totalCount;
        for (let i = 0; i < emptySlots; i++) {
          const emptyDiv = document.createElement('div');
          emptyDiv.className = 'bundle-builder__sidebar-product empty';
          emptyDiv.innerHTML = `
            <div class="bundle-builder__sidebar-product-image empty"></div>
            <div class="bundle-builder__sidebar-product-content">
              <div class="bundle-sidebar-empty-content-template--25377744486729__ss_bundle_builder_6_aAN8ec"></div>
              <div class="bundle-sidebar-empty-content-template--25377744486729__ss_bundle_builder_6_aAN8ec"></div>
            </div>
          `;
          sidebarContainer.appendChild(emptyDiv);
        }
      }
    }

    updateTotalPrice() {
      let subtotal = 0;
      
      for (let id in this.selectedProducts) {
        const product = this.selectedProducts[id];
        subtotal += product.price * product.quantity;
      }

      // CORRECT DISCOUNT CALCULATION FORMULA
      const discountRate = this.currentPackDiscount / 100;
      const savingsAmount = subtotal * discountRate;
      const total = subtotal - savingsAmount;

      const subtotalEl = document.querySelector(`[data-section-id="${this.sectionId}"] .bundle-builder__subtotal-value`);
      const savingsEl = document.querySelector(`[data-section-id="${this.sectionId}"] .bundle-builder__savings-value`);
      const totalEl = document.querySelector(`[data-section-id="${this.sectionId}"] .bundle-builder__total-value`);

      if (subtotalEl) subtotalEl.textContent = this.formatMoney(subtotal);
      if (savingsEl) savingsEl.textContent = `- ${this.formatMoney(savingsAmount)}`;
      if (totalEl) totalEl.textContent = this.formatMoney(total);
      
      this.updateSubmitButton();
    }

    updateSubmitButton() {
      const submitButton = document.querySelector(`[data-section-id="${this.sectionId}"] .bundle-builder__submit-button`);
      if (!submitButton) return;
      
      const totalCount = this.getTotalProductCount();
      const allSlotsFilled = totalCount === this.currentPackSize;
      
      submitButton.disabled = !allSlotsFilled;
      if (allSlotsFilled) {
        submitButton.textContent = 'ADD TO CART';
      } else {
        submitButton.textContent = `ADD ${this.currentPackSize - totalCount} MORE ITEM${this.currentPackSize - totalCount === 1 ? '' : 'S'}`;
      }
    }

    setupStickySidebar() {
      if (window.innerWidth < 1024) return;
      
      const sidebarSticky = document.querySelector(`[data-section-id="${this.sectionId}"] .bundle-builder__sidebar-sticky`);
      const sidebarWrapper = document.querySelector(`[data-section-id="${this.sectionId}"] .bundle-builder__sidebar-wrapper`);
      const bundleBuilder = document.querySelector(`[data-section-id="${this.sectionId}"] .bundle-builder`);
      
      if (!sidebarSticky || !sidebarWrapper || !bundleBuilder) return;
      
      const originalSidebarWidth = sidebarWrapper.offsetWidth;
      const originalOffsetTop = sidebarWrapper.offsetTop;
      const originalOffsetLeft = sidebarWrapper.offsetLeft;
      
      const sectionTop = bundleBuilder.offsetTop;
      const sectionBottom = sectionTop + bundleBuilder.offsetHeight;
      const headerHeight = 100;
      
      function updateSticky() {
        if (window.innerWidth < 1024) return;
        
        const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        
        // Simpler calculation without height restrictions
        const startStickPoint = originalOffsetTop - headerHeight;
        
        if (scrollTop > startStickPoint) {
          // Stick the sidebar at the top
          sidebarSticky.style.position = 'fixed';
          sidebarSticky.style.top = headerHeight + 'px';
          sidebarSticky.style.left = originalOffsetLeft + 'px';
          sidebarSticky.style.width = originalSidebarWidth + 'px';
          sidebarSticky.style.zIndex = '100';
        } else {
          // Reset to original position
          sidebarSticky.style.position = '';
          sidebarSticky.style.top = '';
          sidebarSticky.style.left = '';
          sidebarSticky.style.width = '';
          sidebarSticky.style.zIndex = '';
        }
      }
      
      updateSticky();
      window.addEventListener('scroll', updateSticky);
      
      window.addEventListener('resize', function() {
        if (window.innerWidth >= 1024) {
          setTimeout(() => {
            const newOriginalSidebarWidth = sidebarWrapper.offsetWidth;
            const newOriginalOffsetLeft = sidebarWrapper.offsetLeft;
            
            sidebarSticky.style.width = newOriginalSidebarWidth + 'px';
            sidebarSticky.style.left = newOriginalOffsetLeft + 'px';
            
            updateSticky();
          }, 100);
        } else {
          sidebarSticky.style.position = '';
          sidebarSticky.style.top = '';
          sidebarSticky.style.left = '';
          sidebarSticky.style.width = '';
          sidebarSticky.style.zIndex = '';
        }
      });
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const bundleBuilders = document.querySelectorAll('.bundle-builder');
    bundleBuilders.forEach(builder => {
      const sectionId = builder.dataset.sectionId;
      new BundleBuilder(sectionId);
    });
  });
</script>

