              </div>
            {% endif %}
            
            {% if video_badge != blank %}
              <p class="featured-media-badge-{{ section_id }}">{{ video_badge }}</p>
            {% endif %}
          </div>
          <div class="featured-media-bottom-{{ section_id }}">
            {% if video_title != blank %}
              <p class="featured-media-title-{{ section_id }}">{{ video_title }}</p>
            {% endif %}
            {% if video_text != blank %}
              <div class="featured-media-text-{{ section_id }}">{{ video_text }}</div>
            {% endif %}
          </div>
        </div>
      </div>

      <div class="featured-slider-wrapper-{{ section_id }}">
        <div class="featured-slider-{{ section_id }} swiper" 
             data-gap="{{ products_gap | default: 24 }}" 
             data-gap-mobile="{{ products_gap_mobile | default: 16 }}" 
             data-speed="{{ slider_speed | default: 300 }}"
             data-loop="{{ slider_loop | default: true }}">
          <div class="swiper-wrapper">
            {% if collection != blank and collection.products.size > 0 %}
              {% for product in collection.products %}
                <div class="featured-slide-{{ section_id }} swiper-slide">
                  <a href="{{ product.url }}" class="featured-product-image-{{ section_id }}">
                    <div class="featured-image-{{ section_id }}">
                      {% if product.featured_image != blank %}
                        <img 
                          src="{{ product.featured_image | img_url: 'master' }}" 
                          srcset="
                            {{ product.featured_image | img_url: '375x' }} 375w,
                            {{ product.featured_image | img_url: '550x' }} 550w,
                            {{ product.featured_image | img_url: '750x' }} 750w,
                            {{ product.featured_image | img_url: '1100x' }} 1100w,
                            {{ product.featured_image | img_url: '1500x' }} 1500w
                          "
                          width="{{ product.featured_image.width }}"
                          height="{{ product.featured_image.height }}"
                          loading="lazy"
                          alt="{{ product.featured_image.alt | escape }}"
                          sizes="(min-width: 1024px) 100vw, 100vw"
                        >
                      {% else %}
                        {{ 'product-1' | placeholder_svg_tag }}
                      {% endif %}
                    </div>
                  </a>

                  <div class="featured-content-{{ section_id }}">
                    <div class="featured-content-wrapper-{{ section_id }}">
                      {% if product.title != blank %}
                        <h3 class="featured-title-{{ section_id }}">{{ product.title }}</h3>
                      {% endif %}
                      
                      {% if product.description != blank %}
                        <div class="featured-text-{{ section_id }}">
                          {{ product.description | strip_html | truncatewords: 15 }}
                        </div>
                      {% endif %}
                        
                      <div class="featured-price-{{ section_id }}">
                        {% if product.compare_at_price > product.price %}
                          <p class="featured-compare-price-{{ section_id }}">
                            {{ product.compare_at_price | money }}
                          </p>
                        {% endif %}
                        <p class="featured-regular-price-{{ section_id }}">
                          {{ product.price | money }}                        
                        </p>                     
                      </div>
                    </div>                     
                  </div>
                </div>
              {% endfor %}
            {% else %}
              {% for i in (1..5) %}
                <div class="featured-slide-{{ section_id }} swiper-slide">
                  <a href="#" class="featured-product-image-{{ section_id }}">
                    <div class="featured-image-{{ section_id }}">
                      {{ 'product-' | append: i | placeholder_svg_tag }}
                    </div>
                  </a>
                  <div class="featured-content-{{ section_id }}">
                    <div class="featured-content-wrapper-{{ section_id }}">
                      <h3 class="featured-title-{{ section_id }}">Example product title</h3>
                      <div class="featured-text-{{ section_id }}">
                        <p>Example product description</p>
                      </div>
                      <div class="featured-price-{{ section_id }}">
                        <p class="featured-regular-price-{{ section_id }}">
                          $49.00                        
                        </p>                     
                      </div>
                    </div>
                  </div>
                </div>
              {% endfor %}
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const sliderElement = document.querySelector('.featured-slider-{{ section_id }}');
    if (!sliderElement) return;
    
    const gap = parseInt(sliderElement.dataset.gap || 24);
    const gapMobile = parseInt(sliderElement.dataset.gapMobile || 16);
    const speed = parseInt(sliderElement.dataset.speed || 300);
    const loopEnabled = sliderElement.dataset.loop === 'true';
    
    const totalSlides = sliderElement.querySelectorAll('.swiper-slide').length;
    let shouldLoop = loopEnabled && totalSlides > 2;
    
    new Swiper(".featured-slider-{{ section_id }}", {
      speed: speed,
      loop: shouldLoop,
      slidesPerView: 2,
      spaceBetween: gap,
      navigation: {
        nextEl: '.featured-btn-next-{{ section_id }}',
        prevEl: '.featured-btn-prev-{{ section_id }}',
      },
      breakpoints: {
        320: {
          slidesPerView: 1.1,
          spaceBetween: gapMobile,
        },
        768: {
          slidesPerView: 2,
          spaceBetween: gap,
        }
      }
    });
    
    // Video mute functionality
    const medias = document.querySelector('.featured-media-{{ section_id }}');
    if (medias) {
      const video = medias.querySelector('video');
      const muteButton = medias.querySelector('.featured-media-mute-{{ section_id }}');
      if (muteButton && video) {
        muteButton.addEventListener('click', function() {
          const isMuted = muteButton.classList.contains('active');
          video.muted = !isMuted;
          muteButton.classList.toggle('active');
        });
      }
    }
  });
</script>

