{% comment %}
  Featured Video Collection Section
  Displays a video card with a product slider from a selected collection
{% endcomment %}

{{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign section_id = section.id
  assign heading = section.settings.heading
  assign heading_size_mobile = section.settings.heading_size_mobile
  assign heading_size_desktop = section.settings.heading_size_desktop
  assign video_url = section.settings.video_url
  assign video_upload = section.settings.video_upload
  assign video_autoplay = section.settings.video_autoplay
  assign video_muted = section.settings.video_muted
  assign video_loop = section.settings.video_loop
  assign video_overlay_opacity = section.settings.video_overlay_opacity
  
  assign collection = collections[section.settings.collection]
  assign products_gap = section.settings.products_gap
  assign products_gap_mobile = section.settings.products_gap_mobile
  assign slider_speed = section.settings.slider_speed
  assign slider_loop = section.settings.slider_loop
  
  assign section_margin_top = section.settings.margin_top | default: 36 | append: 'px'
  assign section_margin_bottom = section.settings.margin_bottom | default: 36 | append: 'px'
  assign section_margin_top_desktop = section.settings.margin_top_desktop | default: 48 | append: 'px'
  assign section_margin_bottom_desktop = section.settings.margin_bottom_desktop | default: 48 | append: 'px'
  assign section_padding_top = section.settings.padding_top | default: 27 | append: 'px'
  assign section_padding_bottom = section.settings.padding_bottom | default: 27 | append: 'px'
  assign section_padding_top_desktop = section.settings.padding_top_desktop | default: 36 | append: 'px'
  assign section_padding_bottom_desktop = section.settings.padding_bottom_desktop | default: 36 | append: 'px'
  
  assign heading_font = section.settings.heading_font
  assign heading_font_weight = section.settings.heading_font_weight
  assign video_title_font = section.settings.video_title_font
  assign video_text_font = section.settings.video_text_font
  assign product_title_font = section.settings.product_title_font
  assign product_text_font = section.settings.product_text_font
  assign product_price_font = section.settings.product_price_font
  assign button_font = section.settings.button_font
  
  assign video_title = section.settings.video_title
  assign video_text = section.settings.video_text
  assign video_badge = section.settings.video_badge
  assign show_video_controls = section.settings.show_video_controls
  
  assign button_bg_color = section.settings.button_bg_color
  assign button_text_color = section.settings.button_text_color
  assign button_hover_bg_color = section.settings.button_hover_bg_color
  assign button_hover_text_color = section.settings.button_hover_text_color
  assign button_border_color = section.settings.button_border_color
  assign button_border_hover_color = section.settings.button_border_hover_color
  assign button_radius = section.settings.button_radius
  
  assign nav_button_bg = section.settings.nav_button_bg
  assign nav_button_color = section.settings.nav_button_color
  assign nav_button_border_color = section.settings.nav_button_border_color
  assign nav_button_hover_bg = section.settings.nav_button_hover_bg
  assign nav_button_hover_color = section.settings.nav_button_hover_color
  assign nav_button_hover_border_color = section.settings.nav_button_hover_border_color
  
  assign media_border_color = section.settings.media_border_color
  assign media_border_width = section.settings.media_border_width | default: 0 | append: 'px'
  assign media_border_radius = section.settings.media_border_radius | default: 0 | append: 'px'
  assign product_image_radius = section.settings.product_image_radius | default: 0 | append: 'px'
  
  assign text_color = section.settings.text_color
  assign heading_color = section.settings.heading_color
  assign product_title_color = section.settings.product_title_color
  assign product_price_color = section.settings.product_price_color
  assign product_compare_price_color = section.settings.product_compare_price_color
  assign video_title_color = section.settings.video_title_color
  assign video_text_color = section.settings.video_text_color
  assign badge_bg = section.settings.badge_bg
  assign badge_text = section.settings.badge_text
  assign mute_button_color = section.settings.mute_button_color
  assign mute_button_hover_color = section.settings.mute_button_hover_color
  
  assign bg_image = section.settings.section_bg_image
-%}

<style>
  @font-face {
    font-family: Newsreader;
    font-weight: 300;
    font-style: normal;
    font-display: swap;
    src: url("//section.store/cdn/fonts/newsreader/newsreader_n3.91c821924f9e885be236f45ca7ea362dc66668b6.woff2") format("woff2"),
         url("//section.store/cdn/fonts/newsreader/newsreader_n3.8603b522459182a0f3f6cdc888978218bf52a907.woff") format("woff");
  }

  @font-face {
    font-family: "Josefin Sans";
    font-weight: 400;
    font-style: normal;
    font-display: swap;
    src: url("//section.store/cdn/fonts/josefin_sans/josefinsans_n4.70f7efd699799949e6d9f99bc20843a2c86a2e0f.woff2") format("woff2"),
         url("//section.store/cdn/fonts/josefin_sans/josefinsans_n4.35d308a1bdf56e5556bc2ac79702c721e4e2e983.woff") format("woff");
  }

  @font-face {
    font-family: Newsreader;
    font-weight: 700;
    font-style: normal;
    font-display: swap;
    src: url("//section.store/cdn/fonts/newsreader/newsreader_n7.23ab8134dd970213aaed7699491a8a2cb47dae45.woff2") format("woff2"),
         url("//section.store/cdn/fonts/newsreader/newsreader_n7.d508f4855ca4dedbd83fa582e42d6513c7e89b8a.woff") format("woff");
  }

  @font-face {
    font-family: Figtree;
    font-weight: 400;
    font-style: normal;
    font-display: swap;
    src: url("//section.store/cdn/fonts/figtree/figtree_n4.3c0838aba1701047e60be6a99a1b0a40ce9b8419.woff2") format("woff2"),
         url("//section.store/cdn/fonts/figtree/figtree_n4.c0575d1db21fc3821f17fd6617d3dee552312137.woff") format("woff");
  }

  .section-{{ section_id }} {
    border-top: solid {{ section.settings.border_top_color | default: '#313131' }} {{ section.settings.border_top_width | default: 0 }}px;
    border-bottom: solid {{ section.settings.border_bottom_color | default: '#313131' }} {{ section.settings.border_bottom_width | default: 0 }}px;
    margin-top: {{ section_margin_top }};
    margin-bottom: {{ section_margin_bottom }};
    margin-left: {{ section.settings.margin_left | default: 0 }}rem;
    margin-right: {{ section.settings.margin_right | default: 0 }}rem;
    border-radius: {{ section.settings.section_border_radius | default: 0 }}px;
    overflow: hidden;
  }
  
  .section-{{ section_id }}-settings {
    max-width: {{ section.settings.container_width | default: 1200 }}px;
    margin: 0 auto;
    padding-top: {{ section_padding_top }};
    padding-bottom: {{ section_padding_bottom }};
    padding-left: {{ section.settings.padding_left | default: 1.5 }}rem;
    padding-right: {{ section.settings.padding_right | default: 1.5 }}rem;
  }

  .featured-top-{{ section_id }} {
    display: flex;
    width: 100%;
    justify-content: space-between;
    gap: 40px;
    align-items: center;
  }

  .featured-heading-{{ section_id }} {
    width: 100%;
    text-align: left;
  }
  
  .featured-heading-{{ section_id }} * {
    margin: 0px;
    font-size: {{ heading_size_mobile | default: 28 }}px;
    line-height: 130%;
    color: {{ heading_color | default: '#313131' }};
    text-transform: unset;
    word-break: break-word;
    font-weight: {{ heading_font_weight | default: 700 }};
  }

  .featured-buttons-{{ section_id }} {
    display: flex;    
    align-items: center;
    gap: 10px;
    margin-left: auto;
  }

  .featured-btn-prev-{{ section_id }},
  .featured-btn-next-{{ section_id }} {
    display: flex;
    width: {{ section.settings.nav_button_size | default: 48 }}px;
    height: {{ section.settings.nav_button_size | default: 48 }}px;
    border: {{ section.settings.nav_button_border_width | default: 1 }}px solid {{ nav_button_border_color | default: '#313131' }};
    border-radius: 100px;
    background: {{ nav_button_bg | default: '#313131' }};
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease 0s;
    cursor: pointer;
    -webkit-appearance: none;
  }

  .featured-btn-prev-{{ section_id }} .animate-icon,
  .featured-btn-next-{{ section_id }} .animate-icon {
    pointer-events: none;
    place-items: center;
    display: grid;
  }

  .featured-btn-prev-{{ section_id }} .animate-icon:before,
  .featured-btn-next-{{ section_id }} .animate-icon:before {
    content: "";
    grid-area: 1 / -1;
    transition: all .2s ease;
    width: {{ section.settings.nav_icon_size | default: 8 }}px;
    height: {{ section.settings.nav_icon_size | default: 8 }}px;
    transform: rotate(calc(1 * 45deg));
    box-sizing: border-box;
    border-style: solid;
    border: 0px;
    border-right: 2px solid {{ nav_button_color | default: '#ffffff' }};
    border-top: 2px solid {{ nav_button_color | default: '#ffffff' }};
    position: relative;
    left: -1px;
  }

  .featured-btn-prev-{{ section_id }} .animate-icon:before {
    left: unset;
    right: -1px;
    border-right: 0px;
    border-top: 0px;
    border-bottom: 2px solid {{ nav_button_color | default: '#ffffff' }};
    border-left: 2px solid {{ nav_button_color | default: '#ffffff' }};
  }

  .featured-btn-prev-{{ section_id }} .animate-icon:after,
  .featured-btn-next-{{ section_id }} .animate-icon:after {
    content: "";
    grid-area: 1 / -1;
    transition: all .2s ease;
    width: {{ section.settings.nav_icon_size | default: 8 | minus: 0.3 | append: 'px' }};
    height: 1.6px;
    transform-origin: center;
    opacity: 0;
    background: {{ nav_button_color | default: '#ffffff' }};
    transform: scaleX(.5);
  }

  .featured-btn-prev-{{ section_id }} span,
  .featured-btn-next-{{ section_id }} span {
    color: {{ nav_button_color | default: '#ffffff' }};
  }

  .featured-btn-prev-{{ section_id }}.swiper-button-disabled,
  .featured-btn-next-{{ section_id }}.swiper-button-disabled {
    opacity: 0.5;
  }
  
  .featured-btn-prev-{{ section_id }}:hover,
  .featured-btn-next-{{ section_id }}:hover {
    transition: all 0.3s ease 0s;
    border: {{ section.settings.nav_button_hover_border_width | default: 1 }}px solid {{ nav_button_hover_border_color | default: '#313131' }};
    background: {{ nav_button_hover_bg | default: '#ffffff' }};
  }
  
  .featured-btn-prev-{{ section_id }}:hover .animate-icon,
  .featured-btn-next-{{ section_id }}:hover .animate-icon {
    color: {{ nav_button_hover_color | default: '#313131' }};
  }
  
  .featured-btn-prev-{{ section_id }}:hover .animate-icon:before,
  .featured-btn-next-{{ section_id }}:hover .animate-icon:before {
    border-right-color: {{ nav_button_hover_color | default: '#313131' }};
    border-top-color: {{ nav_button_hover_color | default: '#313131' }};
  }
  
  .featured-btn-prev-{{ section_id }}:hover .animate-icon:before {
    border-bottom-color: {{ nav_button_hover_color | default: '#313131' }};
    border-left-color: {{ nav_button_hover_color | default: '#313131' }};
  }

  .featured-bottom-{{ section_id }} {
    display: flex;
    flex-direction: column-reverse;
    margin-top: 16px;
    gap: 16px;
  }
  
  .featured-slider-wrapper-{{ section_id }} {
    display: grid;    
    width: 100% !important;
  }

  .featured-slider-{{ section_id }} {
    width: 100%;
    overflow: hidden;
  }
  
  .featured-slider-{{ section_id }} .swiper-wrapper {
    display: flex;
  }

  .featured-slide-{{ section_id }} {
    flex-shrink: 0;
    box-sizing: border-box !important;
    display: flex !important;
    flex-direction: column !important;
  }

  .featured-media-{{ section_id }} {
    width: 100%;
    position: relative;
    border: {{ media_border_width }} solid {{ media_border_color | default: '#313131' }};
    border-radius: {{ media_border_radius }};
    overflow: hidden;
    aspect-ratio: {{ section.settings.media_aspect_ratio_mobile | default: '12/12' }};
  }

  .featured-media-{{ section_id }}::after {
    content: "";
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    z-index: 1;
    background-color: {{ section.settings.video_overlay_color | default: '#313131' }};
    opacity: {{ video_overlay_opacity | default: 0.2 }};
  }

  .featured-media-{{ section_id }} img,
  .featured-media-{{ section_id }} svg,
  .featured-media-{{ section_id }} video,
  .featured-media-{{ section_id }} iframe {
    border: 0px;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .featured-media-{{ section_id }} svg {
    background-color: #AFAFAF;
  }

  .featured-media-content-{{ section_id }} {
    position: absolute;
    display: flex;
    height: 100%;
    width: 100%;
    top: 0;
    left: 0;
    flex-direction: column;
    justify-content: space-between;
    gap: 20px;
    z-index: 2;
    padding: 24px 16px;
  }

  .featured-media-top-{{ section_id }} {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 20px;
  }

  .featured-media-controls-{{ section_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .featured-media-mute-{{ section_id }} {
    transition: all 0.25s ease 0s;
    background-color: rgba(0,0,0,0);
    width: {{ section.settings.mute_button_size | default: 42 }}px;
    height: {{ section.settings.mute_button_size | default: 42 }}px;
    padding: {{ section.settings.mute_button_size | default: 42 | divided_by: 4 | append: 'px' }};
    border-radius: 50px;
    border: 1px solid {{ mute_button_color | default: '#ffffff' }};
    cursor: pointer;
  }

  .featured-media-mute-{{ section_id }}:hover {
    background-color: {{ mute_button_hover_color | default: '#ffffff' }};
    border-color: {{ mute_button_hover_color | default: '#ffffff' }};
  }

  .featured-media-mute-{{ section_id }} svg {
    display: block;
    background-color: transparent;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .featured-media-mute-{{ section_id }} svg path {
    fill: {{ mute_button_color | default: '#ffffff' }};
    transition: fill 0.25s ease;
  }

  .featured-media-mute-{{ section_id }}:hover svg path {
    fill: {{ section.settings.mute_button_hover_icon_color | default: '#313131' }};
  }

  .featured-media-mute-{{ section_id }}.active svg:first-child {
    display: block;
  }

  .featured-media-mute-{{ section_id }} svg:first-child {
    display: none;
  }

  .featured-media-mute-{{ section_id }}.active svg:last-child {
    display: none;
  }

  .featured-media-mute-{{ section_id }} svg:last-child {
    display: block;
  }

  .featured-media-badge-{{ section_id }} {
    margin: 0px;
    max-width: fit-content;
    padding: {{ section.settings.badge_padding_vertical | default: 6 }}px {{ section.settings.badge_padding_horizontal | default: 10 }}px;
    background-color: {{ badge_bg | default: '#ffffff' }};
    border-radius: 100px;
    font-size: {{ section.settings.badge_font_size | default: 12 }}px;
    line-height: 100%;
    color: {{ badge_text | default: '#313131' }};
    text-transform: unset;
    word-break: break-word;
  }

  .featured-media-title-{{ section_id }} {
    margin: 0px;  
    font-size: {{ section.settings.video_title_size | default: 28 }}px;
    line-height: 130%;
    color: {{ video_title_color | default: '#ffffff' }};
    text-transform: unset;
    word-break: break-word;
  }

  .featured-media-text-{{ section_id }} {
    margin-top: 4px;
  }

  .featured-media-text-{{ section_id }} * {
    margin: 0px;     
    font-size: {{ section.settings.video_text_size | default: 14 }}px;
    line-height: 170%;
    color: {{ video_text_color | default: '#ffffff' }};
    text-transform: unset;
    word-break: break-word;
  }

  .featured-image-{{ section_id }} {
    border: {{ media_border_width }} solid {{ media_border_color | default: '#313131' }};
    border-radius: {{ product_image_radius }};
    display: block;
    box-sizing: border-box !important;
    overflow: hidden;
    aspect-ratio: {{ section.settings.product_image_aspect_ratio | default: '12/12' }};
  }

  .featured-image-{{ section_id }} img,
  .featured-image-{{ section_id }} svg {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .featured-image-{{ section_id }} img{

        background: #E8E8E8;
}


  .featured-image-{{ section_id }} svg {
    background-color: #AFAFAF;
  }

  .featured-content-{{ section_id }} {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    align-items: start;
  }

  .featured-title-{{ section_id }} {
    margin: 0;   
    text-align: left;
    margin-top: {{ section.settings.product_title_margin_top | default: 16 }}px;
    font-size: {{ section.settings.product_title_size | default: 15 }}px;
    color: {{ product_title_color | default: '#313131' }};
    line-height: 130%;
    text-transform: unset;
    word-break: break-word;
    transition: all 0.25s ease 0s;
  }   
  
  .featured-text-{{ section_id }} {
    text-align: left;
    margin-top: {{ section.settings.product_text_margin_top | default: 8 }}px;    
  }

  .featured-text-{{ section_id }} * {
    margin: 0;    
    font-size: {{ section.settings.product_text_size | default: 12 }}px;
    line-height: 150%;
    color: {{ text_color | default: '#313131' }};  
    text-transform: unset;  
    word-break: break-word;
  }

  .featured-price-{{ section_id }} {
    margin-top: {{ section.settings.product_price_margin_top | default: 8 }}px;  
    width: 100%;
    display: flex;
    align-items: center;
    gap: 5px;
    justify-content: start;
  }

  .featured-price-{{ section_id }} * {
    margin: 0;        
    text-align: left;
    font-size: {{ section.settings.product_price_size | default: 12 }}px;
    color: {{ product_price_color | default: '#313131' }};
    line-height: 130%;
    text-transform: unset;
    word-break: break-word;
    transition: all 0.25s ease 0s;
  }   

  .featured-compare-price-{{ section_id }} {
    text-decoration: line-through;
    color: {{ product_compare_price_color | default: '#afafaf' }};
  }

  .featured-button-{{ section_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    margin: 0;
    font-size: {{ section.settings.button_text_size | default: 12 }}px;
    color: {{ button_text_color | default: '#ffffff' }};
    line-height: 100%;
    text-align: center;
    text-transform: unset;
    text-decoration: none;
    padding: {{ section.settings.button_padding_vertical | default: 10 }}px {{ section.settings.button_padding_horizontal | default: 32 }}px;
    border-radius: {{ button_radius | default: 100 }}px;
    transition: all 0.25s ease 0s;
    background-color: {{ button_bg_color | default: '#313131' }};
    border: 1px solid {{ button_border_color | default: '#313131' }};
    cursor: pointer;
    margin-top: {{ section.settings.button_margin_top | default: 12 }}px;
    font-weight: 700;
  }

  .featured-button-inner-{{ section_id }} {
    margin: 0px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }

  .featured-button-{{ section_id }}:hover {
    color: {{ button_hover_text_color | default: '#313131' }};
    background-color: {{ button_hover_bg_color | default: '#ffffff' }};
    border: 1px solid {{ button_border_hover_color | default: '#313131' }};
    transition: all 0.25s ease 0s;
  }

  .featured-button-{{ section_id }} svg {
    width: 14px;
    height: 14px;
    border: none;
    background-color: transparent;
  }

  .featured-button-{{ section_id }} svg path {
    fill: {{ button_text_color | default: '#ffffff' }};
    transition: all 0.25s ease 0s;
  }

  .featured-button-{{ section_id }}:hover svg path {
    fill: {{ button_hover_text_color | default: '#313131' }};
    transition: all 0.25s ease 0s;
  }

  .featured-heading-{{ section_id }} * {
    font-family: {{ heading_font }};
    font-weight: {{ heading_font_weight }};
    font-style: normal;
  }

  .featured-media-title-{{ section_id }} {
    font-family: {{ video_title_font }};
    font-weight: {{ section.settings.video_title_font_weight | default: 700 }};
    font-style: normal;
  }

  .featured-media-text-{{ section_id }} * {
    font-family: {{ video_text_font }};
    font-weight: {{ section.settings.video_text_font_weight | default: 400 }};
    font-style: normal;
  }

  .featured-title-{{ section_id }} {
    font-family: {{ product_title_font }};
    font-weight: {{ section.settings.product_title_font_weight | default: 700 }};
    font-style: normal;
  }

  .featured-text-{{ section_id }} * {
    font-family: {{ product_text_font }};
    font-weight: {{ section.settings.product_text_font_weight | default: 400 }};
    font-style: normal;
  }

  .featured-price-{{ section_id }} * {
    font-family: {{ product_price_font }};
    font-weight: {{ section.settings.product_price_font_weight | default: 400 }};
    font-style: normal;
  }

  .featured-button-{{ section_id }} {
    font-family: {{ button_font }};
    font-weight: {{ section.settings.button_font_weight | default: 400 }};
    font-style: normal;
  }

  @media(max-width: 1023px) {
    .featured-buttons-{{ section_id }} {
      display: none !important;
    }
  }

  @media(min-width: 1024px) {
    .section-{{ section_id }} {
      margin-top: {{ section_margin_top_desktop }};
      margin-bottom: {{ section_margin_bottom_desktop }};
      border-radius: {{ section.settings.section_border_radius_desktop | default: 0 }}px;
    }
    
    .section-{{ section_id }}-settings {
      padding-top: {{ section_padding_top_desktop }};
      padding-bottom: {{ section_padding_bottom_desktop }};
      padding-left: {{ section.settings.padding_left_desktop | default: 5 }}rem;
      padding-right: {{ section.settings.padding_right_desktop | default: 5 }}rem;
    }

    .featured-heading-{{ section_id }} {
      text-align: left;
    }
    
    .featured-heading-{{ section_id }} * {
      font-size: {{ heading_size_desktop | default: 40 }}px;
    }

    .featured-slider-{{ section_id }} {
      margin-left: 0rem !important;
      margin-right: 0rem !important;
      padding-left: 0rem !important;
      padding-right: 0rem !important;
    }

    .featured-btn-prev-{{ section_id }},
    .featured-btn-next-{{ section_id }} {
      width: {{ section.settings.nav_button_size_desktop | default: 48 }}px;
      height: {{ section.settings.nav_button_size_desktop | default: 48 }}px;
    }    

    .featured-bottom-{{ section_id }} {
      flex-direction: row;
      margin-top: 24px;
      gap: 24px;
    }

    .featured-media-{{ section_id }} {
      width: {{ section.settings.video_column_width | default: 30 }}%;
      aspect-ratio: {{ section.settings.media_aspect_ratio_desktop | default: 'auto' }};
    }

    .featured-slider-wrapper-{{ section_id }} {
      width: {{ 100 | minus: section.settings.video_column_width | default: 70 }}% !important;
    }

    .featured-content-{{ section_id }} {
      align-items: start;
    }

    .featured-title-{{ section_id }} {
      text-align: left;
      margin-top: 16px;
      font-size: {{ section.settings.product_title_size_desktop | default: 20 }}px;    
    }   
    
    .featured-text-{{ section_id }} {
      text-align: left;
      margin-top: 8px;    
    }

    .featured-price-{{ section_id }} {    
      margin-top: 8px;       
      justify-content: start;
    }

    .featured-button-{{ section_id }} {
      margin-top: 12px;
      padding: {{ section.settings.button_padding_vertical_desktop | default: 10 }}px {{ section.settings.button_padding_horizontal_desktop | default: 32 }}px;
      font-size: {{ section.settings.button_text_size_desktop | default: 14 }}px;
    }
  }
</style>

<div class="section-{{ section_id }}" 
     style="
       background-color: {{ section.settings.section_bg_color | default: '#ffffff' }};
       {% if bg_image != blank %}
         background-image: url('{{ bg_image | img_url: 'master' }}');
       {% endif %}
     ">
  <div class="section-{{ section_id }}-settings">
    <div class="featured-top-{{ section_id }}">
      {% if heading != blank %}
        <div class="featured-heading-{{ section_id }}">
          {{ heading }}
        </div>
      {% endif %}
      <div class="featured-buttons-{{ section_id }}">
        <button class="featured-btn-prev-{{ section_id }}" tabindex="0" aria-label="Previous slide">
          <span class="animate-icon"></span>
        </button>
        <button class="featured-btn-next-{{ section_id }}" tabindex="0" aria-label="Next slide">
          <span class="animate-icon"></span>
        </button>   
      </div>
    </div>      
    <div class="featured-bottom-{{ section_id }}">
      <div class="featured-media-{{ section_id }}">
        {% if video_upload != blank %}
          {{
            video_upload
            | video_tag:
              autoplay: video_autoplay,
              loop: video_loop,
              muted: video_muted,
              controls: false,
              class: "lazy"
          }}
        {% elsif video_url != blank %}
          {% if video_url contains 'youtube.com/watch' or video_url contains 'youtu.be' %}
            {% assign video_id = video_url | split: 'v=' | last %}
            {% assign video_id = video_id | split: '&' | first %}
            {% if video_url contains 'youtu.be' %}
              {% assign video_id = video_url | split: '/' | last %}
            {% endif %}
            <iframe 
              src="https://www.youtube.com/embed/{{ video_id }}?autoplay={{ video_autoplay }}&mute={{ video_muted }}&loop={{ video_loop }}&controls=0&playlist={{ video_id }}"
              frameborder="0"
              allow="autoplay; encrypted-media"
              allowfullscreen
              loading="lazy">
            </iframe>
          {% elsif video_url contains 'vimeo.com' %}
            {% assign video_id = video_url | split: '/' | last %}
            <iframe
              src="https://player.vimeo.com/video/{{ video_id }}?autoplay={{ video_autoplay }}&muted={{ video_muted }}&loop={{ video_loop }}&controls=0"
              frameborder="0"
              allow="autoplay; encrypted-media"
              allowfullscreen
              loading="lazy">
            </iframe>
          {% elsif video_url contains '.mp4' or video_url contains '.mov' %}
            <video 
              src="{{ video_url }}" 
              muted="{{ video_muted }}" 
              {% if video_autoplay %}autoplay{% endif %} 
              playsinline 
              {% if video_loop %}loop{% endif %} 
              preload="none" 
              controlslist="nodownload">
            </video>
          {% endif %}
        {% endif %}
        
        <div class="featured-media-content-{{ section_id }}">
          <div class="featured-media-top-{{ section_id }}">
            {% if show_video_controls %}
              <div class="featured-media-controls-{{ section_id }}">
