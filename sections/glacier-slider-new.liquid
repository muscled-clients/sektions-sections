{{ 'https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css' | stylesheet_tag }}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;700&display=swap');

  .glacier-section-{{ section.id }} {
    margin: 0;
    border-radius: 0;
    overflow: hidden;
    background-color: {{ section.settings.bg_color }};
  }

  .glacier-inner-{{ section.id }} {
    max-width: var(--page-width);
    margin: 0 auto;
    padding-top: 27px;
    padding-bottom: 27px;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    position: relative;
  }

  .glacier-heading-{{ section.id }} { width: 100%; text-align: left; }
  .glacier-heading-{{ section.id }} h2 {
    margin: 0;
    font-family: 'Comfortaa', sans-serif;
    font-weight: 700;
    font-size: 32px;
    color: {{ section.settings.heading_color }};
    line-height: 130%;
    word-break: break-word;
  }

  .glacier-swiper-{{ section.id }} {
    display: flex !important;
    align-items: end !important;
    position: relative !important;
    min-height: 540px !important;
    margin-left: -1.5rem !important;
    margin-right: -1.5rem !important;
    padding-left: 1.5rem !important;
    padding-right: 1.5rem !important;
  }

  .glacier-swiper-{{ section.id }} .swiper-wrapper {
    align-items: end !important;
  }

  .glacier-slide-{{ section.id }} {
    position: relative !important;
    box-sizing: border-box !important;
    transform: translateY(0) !important;
    transition: transform 0.7s ease 0s !important;
    text-decoration: none;
    display: block;
  }

  .glacier-slide-wrap-{{ section.id }} {
    position: relative;
    height: 420px !important;
    border: 0px solid #121212 !important;
    border-radius: 0px !important;
    overflow: hidden !important;
    padding: 30px 0px;
    transition: all 0.4s ease 0s;
  }

  .glacier-slide-{{ section.id }}.swiper-slide-active {
    transform: translateY(-60px) !important;
    transition: transform 0.7s ease 0s !important;
  }

  .glacier-slide-{{ section.id }}.transparent-slide-{{ section.id }} .glacier-slide-wrap-{{ section.id }} {
    opacity: 0.5;
    transition: all 0.4s ease 0s;
  }

  .glacier-slide-{{ section.id }}.swiper-slide-next {
    transform: translateY(-30px) !important;
    transition: transform 0.7s ease 0s !important;
  }

  .glacier-slide-wrap-{{ section.id }} > img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
  }

  .glacier-slide-wrap-{{ section.id }}:after {
    background: linear-gradient(180deg, transparent, rgba(0, 0, 0, .4));
    content: "";
    height: 100%;
    left: 0;
    position: absolute;
    top: 0;
    width: 100%;
  }

  .glacier-slide-content-{{ section.id }} {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    z-index: 2;
    left: 50%;
    transform: translateX(-50%);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: end;
    padding: 16px;
    align-items: start;
  }

  .glacier-slide-content-left-{{ section.id }} { flex: 1 1 auto; }

  .glacier-slide-title-{{ section.id }} {
    margin: 0;
    text-align: left;
    font-family: 'Comfortaa', sans-serif;
    font-weight: 700;
    font-size: 18px;
    color: {{ section.settings.title_color }};
    line-height: 130%;
    word-break: break-word;
    transition: all 0.4s ease 0s;
  }

  .glacier-btn-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: fit-content;
    gap: 10px;
    width: 100%;
    margin: 0;
    margin-top: 16px;
    font-family: 'Comfortaa', sans-serif;
    font-weight: 400;
    font-size: 14px;
    color: {{ section.settings.btn_text_color }};
    line-height: 100%;
    text-align: center;
    padding: 16px 24px;
    border-radius: 0px;
    transition: all 0.25s ease 0s;
    background-color: {{ section.settings.btn_bg_color }};
    border: 0px;
    cursor: pointer;
    min-width: max-content;
    text-decoration: none;
  }

  .glacier-btn-{{ section.id }}:hover {
    background-color: {{ section.settings.btn_bg_hover }};
    color: {{ section.settings.btn_text_hover }};
    transition: all 0.25s ease 0s;
  }

  .glacier-btn-inner-{{ section.id }} {
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }

  .glacier-nav-{{ section.id }} {
    position: absolute;
    z-index: 3;
    display: none;
    align-items: center;
    gap: 15px;
    width: 100%;
    justify-content: center;
    left: 0;
    bottom: 0px;
  }

  .glacier-prev-{{ section.id }},
  .glacier-next-{{ section.id }} {
    z-index: 2;
    display: flex;
    flex-shrink: 0;
    width: 50px;
    height: 50px;
    border: 2px solid {{ section.settings.nav_border_color }};
    border-radius: 0px;
    background: {{ section.settings.nav_bg_color }};
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease 0s;
    cursor: pointer;
    -webkit-appearance: none;
  }

  .glacier-prev-{{ section.id }}:hover,
  .glacier-next-{{ section.id }}:hover {
    transition: all 0.3s ease 0s;
    border: 2px solid {{ section.settings.nav_border_color }};
    background: {{ section.settings.nav_border_color }};
  }

  .glacier-prev-{{ section.id }}:hover .animate-icon,
  .glacier-next-{{ section.id }}:hover .animate-icon {
    color: {{ section.settings.nav_bg_color }};
  }

  .glacier-prev-{{ section.id }}.swiper-button-disabled,
  .glacier-next-{{ section.id }}.swiper-button-disabled { opacity: 0.5; }

  .glacier-prev-{{ section.id }}.swiper-button-lock,
  .glacier-next-{{ section.id }}.swiper-button-lock { opacity: 0; pointer-events: none; }

  .glacier-prev-{{ section.id }} span,
  .glacier-next-{{ section.id }} span { color: {{ section.settings.nav_arrow_color }}; }

  .glacier-prev-{{ section.id }} .animate-icon,
  .glacier-next-{{ section.id }} .animate-icon {
    pointer-events: none;
    place-items: center;
    display: grid;
  }

  .glacier-next-{{ section.id }} .animate-icon:before {
    content: "";
    grid-area: 1 / -1;
    transition: all .2s ease;
    width: 10px;
    height: 10px;
    transform: rotate(45deg);
    box-sizing: border-box;
    border: 0px;
    border-right: 2px solid currentColor;
    border-top: 2px solid currentColor;
    position: relative;
    left: -1px;
  }

  .glacier-prev-{{ section.id }} .animate-icon:before {
    content: "";
    grid-area: 1 / -1;
    transition: all .2s ease;
    width: 10px;
    height: 10px;
    transform: rotate(45deg);
    box-sizing: border-box;
    border: 0px;
    border-bottom: 2px solid currentColor;
    border-left: 2px solid currentColor;
    position: relative;
    right: -1px;
  }

  .glacier-prev-{{ section.id }} .animate-icon:after,
  .glacier-next-{{ section.id }} .animate-icon:after {
    content: "";
    grid-area: 1 / -1;
    transition: all .2s ease;
    width: 9.7px;
    height: 1.6px;
    transform-origin: center;
    opacity: 0;
    background: currentColor;
    transform: scaleX(.5);
  }

  .glacier-next-{{ section.id }}:hover .animate-icon:before {
    transform: translate(0.125rem) rotate(45deg);
  }

  .glacier-prev-{{ section.id }}:hover .animate-icon:before {
    transform: translate(-0.125rem) rotate(45deg);
  }

  .glacier-prev-{{ section.id }}:hover .animate-icon:after,
  .glacier-next-{{ section.id }}:hover .animate-icon:after {
    opacity: 1;
    transform: scaleX(1);
  }

  @media(min-width: 1024px) {
    .glacier-inner-{{ section.id }} {
      padding-top: 36px;
      padding-bottom: 36px;
      padding-left: 0rem;
      padding-right: 0rem;
    }

    .glacier-heading-{{ section.id }} {
      margin-left: 0px;
      margin-right: auto;
    }

    .glacier-heading-{{ section.id }} h2 {
      font-size: 48px;
    }

    .glacier-swiper-{{ section.id }} {
      min-height: 650px !important;
      margin-left: 0 !important;
      margin-right: 0 !important;
      padding-left: 0 !important;
      padding-right: 0 !important;
    }

    .glacier-slide-wrap-{{ section.id }} {
      height: 500px !important;
    }

    .glacier-slide-content-{{ section.id }} {
      padding: 20px;
      align-items: start;
    }

    .glacier-slide-{{ section.id }}.swiper-slide-active {
      transform: translateY(-100px) !important;
      transition: transform 0.7s ease 0s !important;
    }

    .glacier-slide-{{ section.id }}.swiper-slide-next {
      transform: translateY(-40px) !important;
      transition: transform 0.7s ease 0s !important;
    }

    .glacier-slide-title-{{ section.id }} {
      transform: translateY(62px);
      text-align: left;
      font-size: 22px;
    }

    .glacier-slide-{{ section.id }}:hover .glacier-slide-title-{{ section.id }} {
      transform: translateY(0);
      transition: all 0.4s ease 0s;
    }

    .glacier-slide-content-{{ section.id }} .glacier-btn-{{ section.id }} {
      opacity: 0;
      transition: all 0.3s ease 0s;
    }

    .glacier-slide-{{ section.id }}:hover .glacier-slide-content-{{ section.id }} .glacier-btn-{{ section.id }} {
      opacity: 1;
      transition: all 0.3s ease 0s;
    }

    .glacier-nav-{{ section.id }} {
      display: flex;
      bottom: 30px;
    }

    .glacier-prev-{{ section.id }},
    .glacier-next-{{ section.id }} {
      width: 30px;
      height: 30px;
      transition: all 0.25s ease 0s;
    }

    .glacier-prev-{{ section.id }} .animate-icon:before,
    .glacier-next-{{ section.id }} .animate-icon:before {
      width: 8px;
      height: 8px;
    }

    .glacier-prev-{{ section.id }} .animate-icon:after,
    .glacier-next-{{ section.id }} .animate-icon:after {
      width: 7.7px;
    }

    .glacier-btn-{{ section.id }} {
      margin-top: 16px;
      padding: 16px 24px;
      font-size: 14px;
    }
  }
</style>

<div class="glacier-section-{{ section.id }}">
  <div class="glacier-inner-{{ section.id }}">

    {% if section.settings.heading != blank %}
      <div class="glacier-heading-{{ section.id }}">
        <h2>{{ section.settings.heading }}</h2>
      </div>
    {% endif %}

    <div class="glacier-swiper-{{ section.id }} swiper">
      <div class="swiper-wrapper">
        {% comment %} 3 sets for proper infinite loop {% endcomment %}
        {% for i in (1..3) %}
          {% for block in section.blocks %}
            {% if block.type == 'slide' %}
              <{% if block.settings.link != blank %}a href="{{ block.settings.link }}"{% else %}div{% endif %} class="glacier-slide-{{ section.id }} swiper-slide {% if i == 1 %}transparent-slide-{{ section.id }}{% endif %}" {{ block.shopify_attributes }}>
                <div class="glacier-slide-wrap-{{ section.id }}">
                  {% if block.settings.image != blank %}
                    <img
                      src="{{ block.settings.image | image_url: width: 800 }}"
                      srcset="{{ block.settings.image | image_url: width: 375 }} 375w,
                              {{ block.settings.image | image_url: width: 550 }} 550w,
                              {{ block.settings.image | image_url: width: 750 }} 750w"
                      width="{{ block.settings.image.width }}"
                      height="{{ block.settings.image.height }}"
                      alt="{{ block.settings.title | escape }}"
                      loading="lazy">
                  {% else %}
                    {{ 'collection-1' | placeholder_svg_tag }}
                  {% endif %}
                  <div class="glacier-slide-content-{{ section.id }}">
                    <div class="glacier-slide-content-left-{{ section.id }}"></div>
                    {% if block.settings.title != blank %}
                      <p class="glacier-slide-title-{{ section.id }}">{{ block.settings.title }}</p>
                    {% endif %}
                    {% if block.settings.btn_text != blank %}
                      <div class="glacier-btn-{{ section.id }}">
                        <p class="glacier-btn-inner-{{ section.id }}">{{ block.settings.btn_text }}</p>
                      </div>
                    {% endif %}
                  </div>
                </div>
              </{% if block.settings.link != blank %}a{% else %}div{% endif %}>
            {% endif %}
          {% endfor %}
        {% endfor %}
      </div>

      <div class="glacier-nav-{{ section.id }}">
        <button class="glacier-prev-{{ section.id }}" tabindex="0" aria-label="Previous slide">
          <span class="animate-icon"></span>
        </button>
        <button class="glacier-next-{{ section.id }}" tabindex="0" aria-label="Next slide">
          <span class="animate-icon"></span>
        </button>
      </div>
    </div>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@8/swiper-bundle.min.js"></script>
<script>
  function initGlacierNew_{{ section.id | replace: '-', '_' }}() {
    return new Swiper(".glacier-swiper-{{ section.id }}", {
      speed: 500,
      centeredSlides: true,
      loop: true,
      navigation: {
        nextEl: '.glacier-next-{{ section.id }}',
        prevEl: '.glacier-prev-{{ section.id }}',
      },
      on: {
        slideChange: function () {
          const activeIndex = this.activeIndex;
          this.slides.forEach((slide, index) => {
            slide.classList.remove('transparent-slide-{{ section.id }}');
            if (index < activeIndex) {
              slide.classList.add('transparent-slide-{{ section.id }}');
            }
          });
        },
      },
      breakpoints: {
        320: {
          spaceBetween: 24,
          slidesPerView: 1.2
        },
        768: {
          spaceBetween: 24,
          slidesPerView: 2
        },
        1024: {
          spaceBetween: 32,
          slidesPerView: 3
        }
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initGlacierNew_{{ section.id | replace: '-', '_' }});

  if (typeof Shopify !== 'undefined' && Shopify.designMode) {
    document.addEventListener('shopify:section:load', function(event) {
      if (event.detail.sectionId === '{{ section.id }}') {
        initGlacierNew_{{ section.id | replace: '-', '_' }}();
      }
    });
  }
</script>

{% schema %}
{
  "name": "Glacier Slider New",
  "tag": "section",
  "class": "glacier-slider-new-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your perfect routine"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#e2f5f9"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#155dd7"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Slide Title Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Button Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button Text Color",
      "default": "#155dd7"
    },
    {
      "type": "color",
      "id": "btn_bg_hover",
      "label": "Button Hover Background",
      "default": "#155dd7"
    },
    {
      "type": "color",
      "id": "btn_text_hover",
      "label": "Button Hover Text Color",
      "default": "#deff5b"
    },
    {
      "type": "color",
      "id": "nav_bg_color",
      "label": "Nav Button Background",
      "default": "#deff5b"
    },
    {
      "type": "color",
      "id": "nav_border_color",
      "label": "Nav Button Border",
      "default": "#155dd7"
    },
    {
      "type": "color",
      "id": "nav_arrow_color",
      "label": "Nav Arrow Color",
      "default": "#155dd7"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
