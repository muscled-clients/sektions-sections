          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Slide Title"
        },
        {
          "type": "text",
          "id": "btn_text",
          "label": "Button Text",
          "default": "View"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Glacier Slider New",
      "blocks": [
        { "type": "slide", "settings": { "title": "Oils", "btn_text": "View" } },
        { "type": "slide", "settings": { "title": "Serums", "btn_text": "View" } },
        { "type": "slide", "settings": { "title": "Cleansing", "btn_text": "View" } },
        { "type": "slide", "settings": { "title": "Moisturizers", "btn_text": "View" } }
      ]
    }
  ]
}
{% endschema %}