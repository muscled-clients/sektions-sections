<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
  (function() {
    function initSlideshowPro{{ section.id | replace: '-', '_' }}() {
      const sliderEl = document.querySelector('.slideshow-pro-slider-{{ section.id }}');
      if (!sliderEl) return;

      if (sliderEl.swiper) {
        sliderEl.swiper.destroy(true, true);
      }

      const autoplayEnabled = {{ section.settings.enable_autoplay | json }};
      const autoplayDelay = {{ section.settings.autoplay_speed | times: 1000 }};

      const slider = new Swiper(sliderEl, {
        speed: 1200,
        loop: {% if section.blocks.size > 1 %}true{% else %}false{% endif %},
        navigation: {
          nextEl: '.slideshow-pro-btn-next-{{ section.id }}',
          prevEl: '.slideshow-pro-btn-prev-{{ section.id }}',
        },
        autoplay: autoplayEnabled
          ? {
              delay: autoplayDelay,
              disableOnInteraction: false,
            }
          : false,
        breakpoints: {
          320: {
            spaceBetween: 0,
            slidesPerView: 1
          },
          1024: {
            spaceBetween: 0,
            slidesPerView: 1
          }
        },
        on: {
          init: function() {
            updateProgress(this);
          },
          slideChange: function() {
            updateProgress(this);
          }
        }
      });

      function updateProgress(swiper) {
        sliderEl.querySelectorAll('.slideshow-pro-progress-{{ section.id }}').forEach(function(bar) {
          bar.setAttribute('data-active', 'false');
          bar.style.setProperty('--progress-width', '0%');
        });

        const activeSlide = swiper.slides[swiper.activeIndex];
        if (!activeSlide) return;

        const activeBar = activeSlide.querySelector('.slideshow-pro-progress-{{ section.id }}');
        if (!activeBar) return;

        activeBar.setAttribute('data-active', 'true');

        setTimeout(function() {
          activeBar.style.setProperty('--progress-width', '100%');
        }, 50);
      }
    }

    document.addEventListener('DOMContentLoaded', function() {
      initSlideshowPro{{ section.id | replace: '-', '_' }}();
    });

    if (Shopify.designMode) {
      document.addEventListener('shopify:section:load', function(event) {
        if (event.detail && event.detail.sectionId === '{{ section.id }}') {
          initSlideshowPro{{ section.id | replace: '-', '_' }}();
        }
      });
    }
  })();
</script>
</div>

