{% comment %}
  HDR Video Wall — Before & After Section
  Dark hero with HDR/SDR comparison slider + product cards row
{% endcomment %}

{%- style -%}
  .hvw--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<section class="hvw hvw--{{ section.id }}">

  {%- comment -%} Background image + dark overlay {%- endcomment -%}
  <div class="hvw__bg" aria-hidden="true">
    {%- if section.settings.background_image -%}
      {{
        section.settings.background_image
        | image_url: width: 3000
        | image_tag: loading: 'lazy', alt: '', class: 'hvw__bg-img'
      }}
    {%- endif -%}
    <div class="hvw__bg-overlay"></div>
  </div>

  <div class="hvw__inner">

    {%- comment -%} Heading block {%- endcomment -%}
    <div class="hvw__heading-block">
      {%- if section.settings.subheading != blank -%}
        <p class="hvw__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="hvw__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    {%- comment -%} Before/After slider {%- endcomment -%}
    <div class="hvw__slider-wrap" data-hvw-slider id="hvw-slider-{{ section.id }}">

      {%- comment -%} SDR image — sits behind (right side / "before") {%- endcomment -%}
      <div class="hvw__img-layer hvw__img-layer--sdr">
        {%- if section.settings.sdr_image -%}
          {{
            section.settings.sdr_image
            | image_url: width: 2560
            | image_tag: loading: 'lazy', alt: section.settings.sdr_alt | default: 'SDR', class: 'hvw__slide-img'
          }}
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'hvw__slide-img hvw__slide-img--placeholder' }}
        {%- endif -%}
      </div>

      {%- comment -%} HDR image — clipped to reveal (left side / "after") {%- endcomment -%}
      <div class="hvw__img-layer hvw__img-layer--hdr" data-hvw-hdr>
        {%- if section.settings.hdr_image -%}
          {{
            section.settings.hdr_image
            | image_url: width: 2560
            | image_tag: loading: 'lazy', alt: section.settings.hdr_alt | default: 'HDR', class: 'hvw__slide-img'
          }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'hvw__slide-img hvw__slide-img--placeholder' }}
        {%- endif -%}
      </div>

      {%- comment -%} Divider + handle {%- endcomment -%}
      <div class="hvw__divider" data-hvw-divider>
        <div class="hvw__divider-line"></div>
        <button
          class="hvw__handle"
          type="button"
          role="slider"
          aria-valuemin="0"
          aria-valuemax="100"
          aria-valuenow="50"
          aria-label="Drag to compare HDR and SDR"
          tabindex="0"
          data-hvw-handle
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false">
            <rect x="6"  y="3" width="2" height="14" rx="1" fill="currentColor"/>
            <rect x="12" y="3" width="2" height="14" rx="1" fill="currentColor"/>
          </svg>
        </button>
      </div>

      {%- comment -%} Labels {%- endcomment -%}
      <div class="hvw__label hvw__label--hdr" aria-hidden="true">
        {{ section.settings.hdr_label_prefix | default: 'New Version:' }}
        <strong>{{ section.settings.hdr_label_badge | default: 'HDR' }}</strong>
      </div>
      <div class="hvw__label hvw__label--sdr" aria-hidden="true">
        {{ section.settings.sdr_label_prefix | default: 'Previous Version:' }}
        <strong>{{ section.settings.sdr_label_badge | default: 'SDR' }}</strong>
      </div>

    </div>{%- comment -%} /.hvw__slider-wrap {%- endcomment -%}

    {%- comment -%} Product cards row {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="hvw__products">
        {%- for block in section.blocks -%}
          {%- if block.type == 'product' -%}
            {%- assign card_product = block.settings.product -%}
            <div class="hvw__product-card" {{ block.shopify_attributes }}>
              <div class="hvw__product-img-wrap">
                {%- if card_product != blank and card_product.featured_image -%}
                  {%- assign _img_alt = card_product.featured_image.alt | escape -%}
                  {{
                    card_product.featured_image
                    | image_url: width: 200
                    | image_tag:
                      loading: 'lazy',
                      alt: _img_alt,
                      class: 'hvw__product-img'
                  }}
                {%- elsif block.settings.fallback_image -%}
                  {{
                    block.settings.fallback_image
                    | image_url: width: 200
                    | image_tag: loading: 'lazy', alt: '', class: 'hvw__product-img'
                  }}
                {%- else -%}
                  {{ 'product-apparel-1' | placeholder_svg_tag: 'hvw__product-img hvw__product-img--placeholder' }}
                {%- endif -%}
              </div>

              <div class="hvw__product-info">
                <div class="hvw__product-text">
                  <p class="hvw__product-title">
                    {%- if card_product != blank -%}
                      <a href="{{ card_product.url }}" class="hvw__product-link">{{ card_product.title | escape }}</a>
                    {%- else -%}
                      {{ block.settings.custom_title | default: 'Interactive Flat Panel' | escape }}
                    {%- endif -%}
                  </p>
                  <p class="hvw__product-desc">
                    {%- if card_product != blank -%}
                      {{ card_product.description | strip_html | truncate: 90 }}
                    {%- else -%}
                      {{ block.settings.custom_description | escape }}
                    {%- endif -%}
                  </p>
                </div>

                <div class="hvw__product-footer">
                  <div class="hvw__product-prices">
                    {%- if card_product != blank -%}
                      {%- if card_product.compare_at_price > card_product.price -%}
                        <s class="hvw__price hvw__price--compare">{{ card_product.compare_at_price | money }}</s>
                      {%- endif -%}
                      <span class="hvw__price hvw__price--sale">{{ card_product.price | money }}</span>
                    {%- else -%}
                      {%- if block.settings.compare_price != blank -%}
                        <s class="hvw__price hvw__price--compare">{{ block.settings.compare_price | escape }}</s>
                      {%- endif -%}
                      {%- if block.settings.sale_price != blank -%}
                        <span class="hvw__price hvw__price--sale">{{ block.settings.sale_price | escape }}</span>
                      {%- endif -%}
                    {%- endif -%}
                  </div>

                  {%- if card_product != blank -%}
                    <a
                      href="{{ card_product.url }}"
                      class="hvw__atc-btn"
                      aria-label="View {{ card_product.title | escape }}"
                    >
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false">
                        <path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                      </svg>
                    </a>
                  {%- else -%}
                    <button class="hvw__atc-btn" type="button" aria-label="Add to cart">
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false">
                        <path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                      </svg>
                    </button>
                  {%- endif -%}
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>{%- comment -%} /.hvw__inner {%- endcomment -%}
</section>

<style>
/* ── Root ─────────────────────────────────────────────────────────────────── */
.hvw {
  position: relative;
  overflow: hidden;
  font-family: 'Inter', sans-serif;
}

/* ── Background ───────────────────────────────────────────────────────────── */
.hvw__bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}
.hvw__bg-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 125%;
  top: -25%;
  object-fit: cover;
  display: block;
}
.hvw__bg-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.85);
}

/* ── Inner container ──────────────────────────────────────────────────────── */
.hvw__inner {
  position: relative;
  z-index: 1;
  max-width: 1440px;
  margin: 0 auto;
  padding: 80px 80px;
  display: flex;
  flex-direction: column;
  gap: 40px;
  align-items: flex-start;
}

/* ── Heading block ────────────────────────────────────────────────────────── */
.hvw__heading-block {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  text-align: center;
}
.hvw__subheading {
  margin: 0;
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #d4af37;
}
.hvw__heading {
  margin: 0;
  font-size: 48px;
  font-weight: 700;
  letter-spacing: -2px;
  color: #fff;
  line-height: 1.15;
}

/* ── Slider ───────────────────────────────────────────────────────────────── */
.hvw__slider-wrap {
  position: relative;
  width: 100%;
  height: 650px;
  border-radius: 16px;
  border: 1px solid rgba(255, 255, 255, 0.4);
  overflow: hidden;
  user-select: none;
  touch-action: none;
  cursor: ew-resize;
}

.hvw__img-layer {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}
.hvw__img-layer--sdr { z-index: 1; }
.hvw__img-layer--hdr {
  z-index: 2;
  clip-path: inset(0 50% 0 0);
}

.hvw__slide-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  pointer-events: none;
}
.hvw__slide-img--placeholder {
  width: 100%;
  height: 100%;
  background: #2a2a3a;
}

/* Divider */
.hvw__divider {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.hvw__divider-line {
  width: 4px;
  height: 100%;
  background: #d9d9d9;
  margin: 0 auto;
}
.hvw__handle {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.95);
  border: none;
  cursor: ew-resize;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #333;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.4);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}
.hvw__handle:hover,
.hvw__handle:focus-visible {
  transform: translate(-50%, -50%) scale(1.08);
  box-shadow: 0 0 0 3px rgba(10, 132, 255, 0.45), 0 2px 12px rgba(0,0,0,0.4);
  outline: none;
}
.hvw__handle:active {
  transform: translate(-50%, -50%) scale(0.95);
}

/* Labels */
.hvw__label {
  position: absolute;
  bottom: 24px;
  z-index: 4;
  padding: 6px 20px;
  border-radius: 50px;
  background: rgba(0, 0, 0, 0.8);
  font-size: 12px;
  color: #fff;
  pointer-events: none;
  white-space: nowrap;
}
.hvw__label--hdr {
  left: 40px;
  border: 1px solid #0a84ff;
}
.hvw__label--hdr strong {
  color: #0a84ff;
  font-weight: 700;
}
.hvw__label--sdr {
  right: 40px;
  border: 1px solid #d4af37;
}
.hvw__label--sdr strong {
  color: #d4af37;
  font-weight: 700;
}

/* ── Product cards ────────────────────────────────────────────────────────── */
.hvw__products {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  width: 100%;
}

.hvw__product-card {
  display: flex;
  gap: 16px;
  align-items: center;
  padding: 16px;
  background: rgba(10, 14, 26, 0.6);
  border: 1px solid rgba(10, 132, 255, 0.3);
  border-radius: 16px;
  backdrop-filter: blur(6px);
}

.hvw__product-img-wrap {
  flex-shrink: 0;
  width: 100px;
  height: 100px;
  border-radius: 4px;
  overflow: hidden;
}
.hvw__product-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.hvw__product-img--placeholder {
  width: 100%;
  height: 100%;
  background: #2a2a3a;
}

.hvw__product-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.hvw__product-text {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.hvw__product-title {
  margin: 0;
  font-size: 16px;
  font-weight: 400;
  color: #fff;
  line-height: 1.3;
}
.hvw__product-link {
  color: inherit;
  text-decoration: none;
}
.hvw__product-link:hover { text-decoration: underline; }

.hvw__product-desc {
  margin: 0;
  font-size: 14px;
  color: #a0aec0;
  line-height: 18px;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.hvw__product-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.hvw__product-prices {
  display: flex;
  align-items: center;
  gap: 8px;
}
.hvw__price {
  font-size: 14px;
  white-space: nowrap;
}
.hvw__price--compare {
  color: #a0aec0;
  font-weight: 300;
  text-decoration: line-through;
}
.hvw__price--sale {
  color: #fff;
  font-weight: 400;
}

.hvw__atc-btn {
  flex-shrink: 0;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #0a84ff;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  cursor: pointer;
  text-decoration: none;
  transition: background 0.2s ease, transform 0.15s ease;
}
.hvw__atc-btn:hover { background: #0070e0; transform: scale(1.06); }
.hvw__atc-btn:active { transform: scale(0.95); }

/* ── Responsive ───────────────────────────────────────────────────────────── */
@media screen and (max-width: 1024px) {
  .hvw__inner { padding: 60px 40px; }
  .hvw__heading { font-size: 36px; letter-spacing: -1px; }
  .hvw__slider-wrap { height: 480px; }
  .hvw__products { grid-template-columns: repeat(2, 1fr); }
}

@media screen and (max-width: 749px) {
  .hvw__inner { padding: 48px 20px; gap: 32px; }
  .hvw__heading { font-size: 28px; letter-spacing: -0.5px; }
  .hvw__slider-wrap { height: 300px; border-radius: 12px; }
  .hvw__label { bottom: 12px; padding: 4px 14px; font-size: 11px; }
  .hvw__label--hdr { left: 12px; }
  .hvw__label--sdr { right: 12px; }
  .hvw__handle { width: 36px; height: 36px; }
  .hvw__products { grid-template-columns: 1fr; }
  .hvw__product-img-wrap { width: 80px; height: 80px; }
}
</style>

<script>
(function () {
  const section = document.getElementById('hvw-slider-{{ section.id }}');
  if (!section) return;

  const hdrLayer = section.querySelector('[data-hvw-hdr]');
  const divider  = section.querySelector('[data-hvw-divider]');
  const handle   = section.querySelector('[data-hvw-handle]');

  let pos = 50;
  let dragging = false;

  function setPos(pct) {
    pct = Math.max(0, Math.min(100, pct));
    pos = pct;
    hdrLayer.style.clipPath   = `inset(0 ${100 - pct}% 0 0)`;
    divider.style.left        = pct + '%';
    handle.setAttribute('aria-valuenow', Math.round(pct));
  }

  function pctFromEvent(e) {
    const rect = section.getBoundingClientRect();
    const clientX = e.touches ? e.touches[0].clientX : e.clientX;
    return ((clientX - rect.left) / rect.width) * 100;
  }

  // Mouse
  section.addEventListener('mousedown', function (e) {
    dragging = true;
    setPos(pctFromEvent(e));
    e.preventDefault();
  });
  document.addEventListener('mousemove', function (e) {
    if (!dragging) return;
    setPos(pctFromEvent(e));
    e.preventDefault();
  });
  document.addEventListener('mouseup', function () { dragging = false; });

  // Touch
  section.addEventListener('touchstart', function (e) {
    dragging = true;
    setPos(pctFromEvent(e));
  }, { passive: true });
  document.addEventListener('touchmove', function (e) {
    if (!dragging) return;
    setPos(pctFromEvent(e));
  }, { passive: true });
  document.addEventListener('touchend', function () { dragging = false; });

  // Keyboard
  handle.addEventListener('keydown', function (e) {
    if (e.key === 'ArrowLeft')  { setPos(pos - 5); e.preventDefault(); }
    if (e.key === 'ArrowRight') { setPos(pos + 5); e.preventDefault(); }
    if (e.key === 'Home')       { setPos(0);        e.preventDefault(); }
    if (e.key === 'End')        { setPos(100);       e.preventDefault(); }
  });

  // Init
  setPos({{ section.settings.initial_position | default: 50 }});

  // Theme editor cleanup
  document.addEventListener('shopify:section:unload', function (e) {
    if (e.detail && e.detail.sectionId === '{{ section.id }}') {
      document.removeEventListener('mousemove', arguments.callee);
      document.removeEventListener('mouseup',   arguments.callee);
    }
  });
})();
</script>

{% schema %}
{
  "name": "HDR Video Wall",
  "tag": "section",
  "class": "hdr-video-wall-section",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Before & After"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Enjoy Stunning Visuals with<br>Our New HDR Video Walls</p>"
    },
    {
      "type": "header",
      "content": "Slider Images"
    },
    {
      "type": "image_picker",
      "id": "hdr_image",
      "label": "HDR image (left / new)"
    },
    {
      "type": "text",
      "id": "hdr_alt",
      "label": "HDR image alt text",
      "default": "HDR"
    },
    {
      "type": "image_picker",
      "id": "sdr_image",
      "label": "SDR image (right / before)"
    },
    {
      "type": "text",
      "id": "sdr_alt",
      "label": "SDR image alt text",
      "default": "SDR"
    },
    {
      "type": "range",
      "id": "initial_position",
      "min": 10,
      "max": 90,
      "step": 5,
      "unit": "%",
      "label": "Initial divider position",
      "default": 50
    },
    {
      "type": "header",
      "content": "Slider Labels"
    },
    {
      "type": "text",
      "id": "hdr_label_prefix",
      "label": "HDR label prefix",
      "default": "New Version:"
    },
    {
      "type": "text",
      "id": "hdr_label_badge",
      "label": "HDR label badge",
      "default": "HDR"
    },
    {
      "type": "text",
      "id": "sdr_label_prefix",
      "label": "SDR label prefix",
      "default": "Previous Version:"
    },
    {
      "type": "text",
      "id": "sdr_label_badge",
      "label": "SDR label badge",
      "default": "SDR"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product card",
      "limit": 4,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "image_picker",
          "id": "fallback_image",
          "label": "Fallback image (if no product)"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom title (no product selected)",
          "default": "Interactive Flat Panel"
        },
        {
          "type": "textarea",
          "id": "custom_description",
          "label": "Custom description (no product selected)",
          "default": "Brightlink 98\" 4K LG Interactive Display with Stand — Android 11.0 Smart OS"
        },
        {
          "type": "text",
          "id": "compare_price",
          "label": "Compare-at price (no product selected)",
          "default": "$8,997.00"
        },
        {
          "type": "text",
          "id": "sale_price",
          "label": "Sale price (no product selected)",
          "default": "$7,997.00"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HDR Video Wall",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
