          "settings": { "color_before_start": "#2d3436", "color_before_end": "#636e72", "color_after_start": "#00b894", "color_after_end": "#00cec9" }
        },
        {
          "type": "card",
          "settings": { "color_before_start": "#0c0c1d", "color_before_end": "#1a1a3e", "color_after_start": "#e17055", "color_after_end": "#fdcb6e" }
        },
        {
          "type": "card",
          "settings": { "color_before_start": "#2c3e50", "color_before_end": "#3498db", "color_after_start": "#e74c3c", "color_after_end": "#f39c12" }
        },
        {
