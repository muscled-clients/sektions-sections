                </svg>
              </button>
            </div>
            {% if section.settings.badge_text != blank %}
              <p class="new-featured-media-badge-{{ section.id }}">{{ section.settings.badge_text }}</p>
            {% endif %}
          </div>
          <div class="new-featured-media-bottom-{{ section.id }}">
            {% if section.settings.media_text != blank %}
              <div class="new-featured-media-text-{{ section.id }}">{{ section.settings.media_text }}</div>
            {% endif %}
          </div>
