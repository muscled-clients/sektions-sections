      </div>

      <div class="new-featured-slider-wrapper-{{ section.id }}">
        <div class="new-featured-slider-{{ section.id }} swiper" 
             data-gap="{{ section.settings.slider_gap_desktop }}" 
             data-gap-mobile="{{ section.settings.slider_gap_mobile }}" 
             data-view="{{ section.settings.slides_per_view_desktop }}" 
             data-view-mobile="{{ section.settings.slides_per_view_mobile }}" 
             style="opacity: 0;">
          <div class="swiper-wrapper">
            {% assign collection = collections[section.settings.collection] %}
            {% if collection != blank and collection.products.size > 0 %}
              {% for product in collection.products limit: section.settings.product_limit %}
                {% assign has_second_image = false %}
                {% if product.images[1] != blank %}
                  {% assign has_second_image = true %}
                {% endif %}
                <div class="new-featured-slide-{{ section.id }} swiper-slide{% if has_second_image %} has-second-image{% endif %}">
                  <a href="{{ product.url }}" class="new-featured-product-image-{{ section.id }}">
                    <div class="new-featured-image-{{ section.id }} new-featured-first-image-{{ section.id }}">    
                      {% if product.featured_image != blank %}
                        <img src="{{ product.featured_image | img_url: '1500x' }}" 
                             srcset="{{ product.featured_image | img_url: '375x' }} 375w, {{ product.featured_image | img_url: '550x' }} 550w, {{ product.featured_image | img_url: '750x' }} 750w, {{ product.featured_image | img_url: '1100x' }} 1100w, {{ product.featured_image | img_url: '1500x' }} 1500w" 
                             width="1500" height="1500" loading="lazy" alt="{{ product.featured_image.alt | escape }}">
                      {% else %}
                        {{ 'product-1' | placeholder_svg_tag }}
                      {% endif %}
                    </div>
                    {% if product.images[1] != blank %}
                      <div class="new-featured-image-{{ section.id }} new-featured-second-image-{{ section.id }}">                                       
                        <img src="{{ product.images[1] | img_url: '1500x' }}" 
                             srcset="{{ product.images[1] | img_url: '375x' }} 375w, {{ product.images[1] | img_url: '550x' }} 550w, {{ product.images[1] | img_url: '750x' }} 750w, {{ product.images[1] | img_url: '1100x' }} 1100w, {{ product.images[1] | img_url: '1500x' }} 1500w" 
                             width="1500" height="1500" loading="lazy" alt="{{ product.images[1].alt | escape }}">
                      </div>
                    {% endif %}
                  </a>
                  <div class="new-featured-content-{{ section.id }}">
                    <div>
                      <h3 class="new-featured-title-{{ section.id }}">{{ product.title }}</h3>
                      {% if section.settings.show_product_description and product.description != blank %}
                        <div class="new-featured-text-{{ section.id }}">
                          {{ product.description | strip_html | truncatewords: section.settings.description_words }}
                        </div>
                      {% endif %}
                      <div class="new-featured-price-{{ section.id }}">
                        {% if product.compare_at_price > product.price %}
                          <p class="new-featured-compare-price-{{ section.id }}">{{ product.compare_at_price | money }}</p>
                        {% endif %}
                        <p class="new-featured-regular-price-{{ section.id }}">
                          {{ product.price | money }}
                        </p>
                      </div>
                    </div>
                    {% if section.settings.button_text != blank %}
                      <a href="{{ product.url }}" class="new-featured-button-{{ section.id }}">
                        <span class="new-featured-button-inner-{{ section.id }}">
                          {{ section.settings.button_text }}
                          {% if section.settings.button_icon %}
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <path d="M1 7H13M13 7L7 1M13 7L7 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                          {% endif %}
                        </span>
                      </a>
                    {% endif %}
                  </div>
                </div>
              {% endfor %}
            {% else %}
              <div class="new-featured-slide-{{ section.id }} swiper-slide">
                <p style="text-align:center;">Please select a collection or add products to display.</p>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

<script>
  (function() {
    const sectionId = '{{ section.id }}';

    function initNewFeatured() {
      // Remove preview class
      const sliderEl = document.querySelector('.new-featured-slider-' + sectionId);
      if (sliderEl) sliderEl.classList.remove('preview');

      // Swiper
      if (sliderEl && document.querySelector('.new-featured-slider-wrapper-' + sectionId)) {
        new Swiper('.new-featured-slider-' + sectionId, {
          speed: 300,
          loop: true,
          navigation: {
            nextEl: '.new-featured-btn-next-' + sectionId,
            prevEl: '.new-featured-btn-prev-' + sectionId,
          },
          breakpoints: {
            320: {
              spaceBetween: parseInt(sliderEl.dataset.gapMobile) || {{ section.settings.slider_gap_mobile }},
              slidesPerView: parseFloat(sliderEl.dataset.viewMobile) || {{ section.settings.slides_per_view_mobile }},
            },
            768: {
              spaceBetween: parseInt(sliderEl.dataset.gap) || {{ section.settings.slider_gap_desktop }},
              slidesPerView: parseFloat(sliderEl.dataset.viewMobile) || {{ section.settings.slides_per_view_mobile }},
            },
            1024: {
              spaceBetween: parseInt(sliderEl.dataset.gap) || {{ section.settings.slider_gap_desktop }},
              slidesPerView: parseFloat(sliderEl.dataset.view) || {{ section.settings.slides_per_view_desktop }},
            }
          },
          on: {
            init: function() {
              this.el.style.opacity = '1';
            }
          }
        });
      }

      // Media controls (video)
      const mediaEl = document.querySelector('.new-featured-media-' + sectionId);
      if (mediaEl) {
        const video = mediaEl.querySelector('video');
        if (video) {
          const muteBtn = mediaEl.querySelector('.new-featured-media-mute-' + sectionId);
          const playBtn = mediaEl.querySelector('.new-featured-media-play-' + sectionId);

          if (muteBtn) {
            muteBtn.addEventListener('click', () => {
              const isMuted = muteBtn.classList.contains('active');
              video.muted = !isMuted;
              muteBtn.classList.toggle('active');
            });
          }

          if (playBtn) {
            playBtn.addEventListener('click', () => {
              const isPlaying = !playBtn.classList.contains('active');
              if (isPlaying) {
                video.pause();
              } else {
                video.play();
              }
              playBtn.classList.toggle('active');
            });
          }
        }
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initNewFeatured);
    } else {
      initNewFeatured();
    }

    if (Shopify.designMode) {
      document.addEventListener('shopify:section:unload', function(e) {
        if (e.detail.sectionId !== '{{ section.id }}') return;
        const video = document.querySelector('.new-featured-media-{{ section.id }} video');
        if (video) video.pause();
      });
      document.addEventListener('shopify:section:load', initNewFeatured);
    }
  })();
</script>

{% schema %}
{
  "name": "Featured Collection Video",
  "settings": [
    {
      "type": "header",
      "content": "General Settings"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border Width",
      "min": 0,
      "max": 5,
      "step": 1,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "border_radius_mobile",
      "label": "Border Radius (Mobile)",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "border_radius_desktop",
      "label": "Border Radius (Desktop)",
      "min": 0,
      "max": 50,
      "step": 2,
