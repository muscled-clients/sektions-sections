{{ 'https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@400;700&display=swap' | stylesheet_tag }}
{{ 'https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css' | stylesheet_tag }}

<style data-shopify="">
  {%- assign section_id = '#shopify-section-' | append: section.id -%}
  
  @font-face {
    font-family: "Josefin Sans";
    font-weight: 400;
    font-style: normal;
    font-display: swap;
    src: url("//section.store/cdn/fonts/josefin_sans/josefinsans_n4.70f7efd699799949e6d9f99bc20843a2c86a2e0f.woff2") format("woff2"),
         url("//section.store/cdn/fonts/josefin_sans/josefinsans_n4.35d308a1bdf56e5556bc2ac79702c721e4e2e983.woff") format("woff");
  }

  @font-face {
    font-family: "Josefin Sans";
    font-weight: 700;
    font-style: normal;
    font-display: swap;
    src: url("//section.store/cdn/fonts/josefin_sans/josefinsans_n7.ba55738510e1286140681c63c9f2580c9b25e81a.woff2") format("woff2"),
         url("//section.store/cdn/fonts/josefin_sans/josefinsans_n7.977a60ae09b63e1bdac0ea9dc1fabc974a8c1e03.woff") format("woff");
  }
  
  .section-{{ section.id }} {
    border-top: solid {{ section.settings.border_color }} 0px;
    border-bottom: solid {{ section.settings.border_color }} 0px;
    border-left: solid {{ section.settings.border_color }} 0px;
    border-right: solid {{ section.settings.border_color }} 0px;
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
    margin-left: {{ section.settings.margin_left_mobile }}rem;
    margin-right: {{ section.settings.margin_right_mobile }}rem;
    border-radius: {{ section.settings.border_radius_mobile }}px;
    overflow: hidden;
    position: relative;
  }
  
  .section-{{ section.id }}-settings {
    margin: 0 auto;
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    max-width: {{ section.settings.max_width }}px;  
            align-items: center;
        display: flex;
        justify-content: center;
        flex-direction: column;  
  }
  
  .feature-features-desktop-{{ section.id }} {
    display: none;
  }

  .feature-features-mobile-wrap-{{ section.id }} {
    display: grid !important;
  }

  .feature-features-mobile-{{ section.id }} {
    min-width: 0;
    width: 100%;
  }

  .feature-features-mobile-{{ section.id }} .feature-feature-{{ section.id }} {
    opacity: 0 !important;
    transition: all 0.25s ease 0s;
  }

   .feature-features-mobile-{{ section.id }} .feature-feature-{{ section.id }}.swiper-slide-active {
    opacity: 1 !important;
    transition: all 0.25s ease 0s;
  }

  .feature-start-dot-{{ section.id }} {
    display: block !important;
    width: 1px;
    margin-top: 55px;
  }

  .feature-body-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    position: relative;
    align-items: center;
    z-index: 2;
    margin-top: {{ section.settings.body_margin_top_mobile }}px;
  }

  .feature-features-{{ section.id }} {
    flex-direction: column;
  }

  .feature-feature-{{ section.id }} {
    cursor: pointer;
    display: flex !important;
    flex-direction: column !important;
    align-items: start;
  }
  
  .feature-title-{{ section.id }} {
    margin: 0;       
    text-transform: unset;
    margin-top: {{ section.settings.title_margin_top }}px;
    word-wrap: break-word;
    text-align: left;
    font-size: {{ section.settings.title_size_mobile }}px;
    font-weight: {{ section.settings.title_weight }};
    line-height: 130%;
    color: {{ section.settings.title_color }};
    width: {{ section.settings.title_width }}%;
    font-family: {{ section.settings.title_font }};
  }
  
  .feature-text-{{ section.id }} {
    transition: all 0.25s ease 0s;
    text-align: left;
    margin-top: {{ section.settings.text_margin_top }}px;    
    width: {{ section.settings.text_width }}%;
  }

  .feature-text-{{ section.id }} * {
    margin: 0;    
    text-transform: unset;
    word-wrap: break-word;
    font-size: {{ section.settings.text_size_mobile }}px;
    line-height: {{ section.settings.text_line_height }}%;
    color: {{ section.settings.text_color }};  
    font-family: {{ section.settings.text_font }};
    font-weight: {{ section.settings.text_weight }};
  }

  .feature-image-wrapper-{{ section.id }} {
    display: flex;
    align-items: center;
    flex-direction: column;
    position: relative;
  }

  .feature-image-{{ section.id }} {
    width: 100%;
    border: {{ section.settings.image_border_width }}px solid {{ section.settings.image_border_color }};
    border-radius: {{ section.settings.image_border_radius }}px;
    overflow: hidden;
    aspect-ratio: {{ section.settings.image_aspect_ratio }};
  }

  .feature-image-{{ section.id }} img,
  .feature-image-{{ section.id }} svg {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: 0;
  }

  .feature-image-{{ section.id }} svg {
    background-color: #AFAFAF;
  }

  .feature-dot-{{ section.id }} {
    display: block !important;
    position: absolute;
    width: 12px;
    height: 12px;
    border-radius: 100%;
    background-color: {{ section.settings.dot_color }};
    opacity: 0;
    transition: all 0.25s ease 0s;
  }

  .feature-dot-{{ section.id }}::after {
    content: "";
    display: block;
    position: absolute;
    left: 50%; 
    top: 50%;   
    -webkit-animation: pulseMobile-{{ section.id }} 1.25s ease-in-out infinite;
    animation: pulseMobile-{{ section.id }} 1.25s ease-in-out infinite;
    background-color: {{ section.settings.dot_color }};
    border-radius: 50%;
    box-sizing: border-box;
    transform: translate3d(-50%, -50%, 0);
    transition: opacity 0.25s linear;
    height: 10px;
    width: 10px;
    z-index: -1;
  }

  @keyframes pulseMobile-{{ section.id }} {
    0% {
      transform: translate3d(-50%, -50%, 0) scale(1);
      opacity: 1;
    }
    100% {
      transform: translate3d(-50%, -50%, 0) scale(2.5);
      opacity: 0;
    }
  }

  .feature-lines-svg-{{ section.id }} .feature-line-all {
      stroke-dasharray: 0; 
      stroke-dashoffset: 0;
      stroke: {{ section.settings.line_color }};
      transition: none;
  }

  .feature-lines-svg-{{ section.id }} path {
    stroke: {{ section.settings.line_color }};
  }

  .feature-line-all,
  .active-feature-line {
    stroke-dasharray: 6 4;
  }

  .feature-dot-{{ section.id }}.in-view {
    opacity: 1;
    transition: all 0.25s ease 0s;
  }

  .feature-dot-{{ section.id }}.active {
    opacity: 1;
    transition: all 0.25s ease 0s;
  }
   
  .feature-icon-{{ section.id }} {
    position: relative;
    z-index: 2;
    border: {{ section.settings.icon_border_width }}px solid {{ section.settings.icon_border_color }};
    border-radius: {{ section.settings.icon_border_radius }}px;
    overflow: hidden;
    width: {{ section.settings.icon_size_mobile }}px;
    height: {{ section.settings.icon_size_mobile }}px;
  }

  .feature-icon-{{ section.id }} img,
  .feature-icon-{{ section.id }} svg {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .feature-icon-{{ section.id }} svg {
    background: #AFAFAF;
  }
  
  .feature-buttons-{{ section.id }} {
    position: absolute;
    z-index: 2;
    gap: 10px;
    top: 0;
    right: 0;
    display: flex;
    justify-content: end;
  }

  .feature-btn-prev-{{ section.id }},
  .feature-btn-next-{{ section.id }} {
    display: flex;
    width: 30px;
    height: 30px;
    border: 0px;
    border: {{ section.settings.nav_button_border_width }}px solid {{ section.settings.nav_button_border_color }};
    border-radius: 50px;
    background: {{ section.settings.nav_button_bg_color }};
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease 0s;
    cursor: pointer;
    -webkit-appearance: none;
  }

  .feature-btn-prev-{{ section.id }} .animate-icon,
  .feature-btn-next-{{ section.id }} .animate-icon {
    pointer-events: none;
    place-items: center;
    display: grid;
    color: {{ section.settings.nav_button_icon_color }};
  }

  .feature-btn-prev-{{ section.id }} .animate-icon:before,
  .feature-btn-next-{{ section.id }} .animate-icon:before {
    content: "";
    grid-area: 1 / -1;
    transition: all .2s ease;
    width: 7px;
    height: 7px;
    transform: rotate(calc(1 * 45deg));
    box-sizing: border-box;
    border-style: solid;
    border: 0px;
    border-right: 2px solid currentColor;
    border-top: 2px solid currentColor;
    position: relative;
    left: -1px;
  }

  .feature-btn-prev-{{ section.id }} .animate-icon:before {
    left: unset;
    right: -1px;
    border-right: 0px;
    border-top: 0px;
    border-bottom: 2px solid currentColor;
    border-left: 2px solid currentColor;
  }

  .feature-btn-prev-{{ section.id }} .animate-icon:after,
  .feature-btn-next-{{ section.id }} .animate-icon:after {
    content: "";
    grid-area: 1 / -1;
    transition: all .2s ease;
    width: 6.7px;
    height: 1.6px;
    transform-origin: center;
    opacity: 0;
    background: currentColor;
    transform: scaleX(.5);
  }

  .feature-btn-prev-{{ section.id }} span,
  .feature-btn-next-{{ section.id }} span {
    color: {{ section.settings.nav_button_icon_color }};
  }

  .feature-btn-prev-{{ section.id }}.swiper-button-disabled,
  .feature-btn-next-{{ section.id }}.swiper-button-disabled {
    opacity: 0.5;
  }

  {% if section.settings.heading_text != blank %}
    .feature-heading-{{ section.id }} {
      margin-top: {{ section.settings.heading_margin_top_mobile }}px;
      text-align: {{ section.settings.heading_alignment_mobile }};
      position: relative;
      z-index: 2;
    }

    .feature-heading-{{ section.id }} * {          
      margin: 0;            
      font-size: {{ section.settings.heading_size_mobile }}px;
      color: {{ section.settings.heading_color }};
      line-height: 130%;
      text-transform: unset;
      text-decoration: none;
      word-break: break-word;
      font-weight: {{ section.settings.heading_weight }};
      font-family: {{ section.settings.heading_font }};
    }   
    
    .feature-heading-{{ section.id }} strong {
      color: {{ section.settings.heading_highlight_color }};
      font-weight: {{ section.settings.heading_weight }};
    }
  {% endif %}

  {% if section.settings.subheading_text != blank %}
    .feature-subheading-{{ section.id }} {
      margin-top: {{ section.settings.subheading_margin_top_mobile }}px;
      text-align: {{ section.settings.subheading_alignment_mobile }};
      position: relative;
      z-index: 2;
      max-width: 80%;
    }
  
    .feature-subheading-{{ section.id }} * {
      margin: 0;
      font-size: {{ section.settings.subheading_size_mobile }}px;
      color: {{ section.settings.subheading_color }};
      line-height: {{ section.settings.subheading_line_height }}%;
      text-transform: unset;
      font-family: {{ section.settings.subheading_font }};
      font-weight: {{ section.settings.subheading_weight }};
    }
  {% endif %}

  {% if section.settings.button_text != blank %}
    .feature-button-{{ section.id }} {
      display: flex;
      align-items: center;
      justify-content: center;
      max-width: fit-content;
      gap: 10px;
      width: 100%;
      margin: 0;         
      margin-top: {{ section.settings.button_margin_top_mobile }}px;
      font-size: {{ section.settings.button_text_size_mobile }}px;
      color: {{ section.settings.button_text_color }};
      line-height: 100%;
      text-align: center;
      text-transform: unset;
      text-decoration: none;
      padding: {{ section.settings.button_padding_vertical_mobile }}px {{ section.settings.button_padding_horizontal_mobile }}px;
      border-radius: {{ section.settings.button_border_radius }}px;
      transition: all 0.3s ease 0s;
      background-color: {{ section.settings.button_bg_color }};
      border: {{ section.settings.button_border_width }}px solid {{ section.settings.button_border_color }};
      cursor: pointer;
      font-weight: {{ section.settings.button_weight }};
      font-family: {{ section.settings.button_font }};
    }

    .feature-button-inner-{{ section.id }} {
      margin: 0px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      text-decoration: none;
    }

    .feature-button-{{ section.id }}:hover {
      color: {{ section.settings.button_hover_text_color }};
      background-color: {{ section.settings.button_hover_bg_color }};
      border: {{ section.settings.button_border_width }}px solid {{ section.settings.button_hover_border_color }};
      transition: all 0.3s ease 0s;
    }

    .feature-button-{{ section.id }} svg {
      width: 14px;
      height: 14px;
    }

    .feature-button-{{ section.id }} svg path {
      fill: {{ section.settings.button_text_color }};
      transition: all 0.25s ease 0s;
    }

    .feature-button-{{ section.id }}:hover svg path {
      fill: {{ section.settings.button_hover_text_color }};
      transition: all 0.25s ease 0s;
    }
  {% endif %}

  @media(min-width: 1024px) {
    .section-{{ section.id }} {
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
      margin-left: {{ section.settings.margin_left_desktop }}rem;
      margin-right: {{ section.settings.margin_right_desktop }}rem;
      border-radius: {{ section.settings.border_radius_desktop }}px;
      border-left: solid {{ section.settings.border_color }} 0px;
      border-right: solid {{ section.settings.border_color }} 0px;
    }
    
    .section-{{ section.id }}-settings {
      padding: 0 5rem;
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      padding-left: 5rem;
      padding-right: 5rem;
    }

    .feature-features-desktop-{{ section.id }} {
      display: flex;
    }

    .feature-features-mobile-wrap-{{ section.id }} {
      display: none !important;
    }  

    .feature-body-{{ section.id }} {
      grid-template-columns: 1fr 2fr 1fr;
      margin-top: {{ section.settings.body_margin_top_desktop }}px;
    }

    .feature-features-{{ section.id }} {
      gap: {{ section.settings.features_gap_desktop }}px;
    }

    .feature-feature-{{ section.id }} {
      align-items: {{ section.settings.feature_alignment_desktop }};
    }
    
    .feature-title-{{ section.id }} {     
      width: {{ section.settings.title_width_desktop }}%;
      margin-top: {{ section.settings.title_margin_top_desktop }}px;
      text-align: {{ section.settings.title_alignment_desktop }};
      font-size: {{ section.settings.title_size_desktop }}px;
    }

    .feature-text-{{ section.id }} {
      width: {{ section.settings.text_width_desktop }}%;
      text-align: {{ section.settings.text_alignment_desktop }};
      margin-top: {{ section.settings.text_margin_top_desktop }}px;    
    }

    .feature-text-{{ section.id }} * {
      font-size: {{ section.settings.text_size_desktop }}px;
    }

    .feature-image-{{ section.id }} {
      width: 100%;
      aspect-ratio: {{ section.settings.image_aspect_ratio_desktop }};
    }
    
    .feature-icon-{{ section.id }} {
      width: {{ section.settings.icon_size_desktop }}px;
      height: {{ section.settings.icon_size_desktop }}px;
    }

    .feature-buttons-{{ section.id }} {
      display: none;
    }

    {% if section.settings.heading_text != blank %}
      .feature-heading-{{ section.id }} {
        margin-top: {{ section.settings.heading_margin_top_desktop }}px;
        text-align: {{ section.settings.heading_alignment_desktop }};
      }
    
      .feature-heading-{{ section.id }} * {
        font-size: {{ section.settings.heading_size_desktop }}px;
      }
    {% endif %}

    {% if section.settings.subheading_text != blank %}
      .feature-subheading-{{ section.id }} {
        margin-top: {{ section.settings.subheading_margin_top_desktop }}px;
        text-align: {{ section.settings.subheading_alignment_desktop }};
        max-width: {{ section.settings.subheading_width_desktop }}%;
        margin-top: 20px;
        display:flex;
        justify-content: center;
      }
    
      .feature-subheading-{{ section.id }} * {
        font-size: {{ section.settings.subheading_size_desktop }}px;
        max-width:80%;
      }
    {% endif %}

    {% if section.settings.button_text != blank %}
      .feature-button-{{ section.id }} {
        margin-top: {{ section.settings.button_margin_top_desktop }}px;
        padding: {{ section.settings.button_padding_vertical_desktop }}px {{ section.settings.button_padding_horizontal_desktop }}px;
        font-size: {{ section.settings.button_text_size_desktop }}px;
      }
    {% endif %}
  }
</style>

<div class="section-{{ section.id }} feature-{{ section.id }}" style="background-color:{{ section.settings.background_color }};">
  <div class="section-{{ section.id }}-settings">
    
    {% if section.settings.heading_text != blank %}
      <div class="feature-heading-{{ section.id }}">
        {{ section.settings.heading_text }}
      </div>
    {% endif %}
    
    {% if section.settings.subheading_text != blank %}
      <div class="feature-subheading-{{ section.id }}">
        {{ section.settings.subheading_text }}
      </div>
    {% endif %}
    
    <div class="feature-body-{{ section.id }}">
      
      {% comment %} Left Column Features (Desktop) {% endcomment %}
      <div class="feature-features-{{ section.id }} feature-features-desktop-{{ section.id }}">
        {% for block in section.blocks %}
          {% if block.type == 'feature' and block.settings.position == 'left' %}
            <div class="feature-feature-{{ section.id }} in-view" id="feature-{{ block.id }}" {{ block.shopify_attributes }}>             
              <div class="feature-start-dot-{{ section.id }}" style="margin-left: auto;"></div>
                      
              <p class="feature-title-{{ section.id }}">{{ block.settings.title }}</p>              
              
              {% if block.settings.text != blank %}
                <div class="feature-text-{{ section.id }}">{{ block.settings.text }}</div>
              {% endif %}
            </div> 
          {% endif %}
        {% endfor %}
      </div>
      
      {% comment %} Mobile Slider {% endcomment %}
      <div class="feature-features-mobile-wrap-{{ section.id }}">
        <div class="feature-features-mobile-{{ section.id }} swiper">
          <div class="feature-buttons-{{ section.id }}">
            <button class="feature-btn-prev-{{ section.id }}">
              <span class="animate-icon"></span>
            </button>
            <button class="feature-btn-next-{{ section.id }}">
              <span class="animate-icon"></span>
            </button>   
          </div>
          <div class="swiper-wrapper">
            {% for block in section.blocks %}
              {% if block.type == 'feature' %}
                <div class="feature-feature-{{ section.id }} swiper-slide" id="feature-{{ block.id }}" {{ block.shopify_attributes }}>
                  <div class="feature-start-dot-{{ section.id }}"></div>
                          
                  <p class="feature-title-{{ section.id }}">{{ block.settings.title }}</p>              
                  
                  {% if block.settings.text != blank %}
                    <div class="feature-text-{{ section.id }}">{{ block.settings.text }}</div>
                  {% endif %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
      
      {% comment %} Center Image with Dots {% endcomment %}
      <div class="feature-image-wrapper-{{ section.id }}">
        <div class="feature-image-{{ section.id }}"> 
          {% if section.settings.image != blank %}
            <img src="{{ section.settings.image | img_url: '1500x' }}" alt="" loading="lazy" width="1500" height="1500">
          {% else %}
            {{ 'image' | placeholder_svg_tag }}
          {% endif %}
        </div>
        
        {% for block in section.blocks %}
          {% if block.type == 'feature' %}
            <div class="feature-dot-{{ section.id }} feature-dot-{{ block.id }}" 
                 data-id="feature-{{ block.id }}"
                 style="left: {{ block.settings.dot_x }}%; top: {{ block.settings.dot_y }}%; transform: translate(-{{ block.settings.dot_x }}%, -{{ block.settings.dot_y }}%);"></div>
          {% endif %}
        {% endfor %}
        
        <svg class="feature-lines-svg-{{ section.id }}" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; overflow: visible;" stroke-width="{{ section.settings.line_width }}"></svg>
      </div>
      
      {% comment %} Right Column Features (Desktop) {% endcomment %}
      <div class="feature-features-{{ section.id }} feature-features-desktop-{{ section.id }}">
        {% for block in section.blocks %}
          {% if block.type == 'feature' and block.settings.position == 'right' %}
            <div class="feature-feature-{{ section.id }} second in-view" id="feature-{{ block.id }}" {{ block.shopify_attributes }}>         
              <div class="feature-start-dot-{{ section.id }}" style="margin-right: auto;"></div>
                      
              <p class="feature-title-{{ section.id }}">{{ block.settings.title }}</p>              
              
              {% if block.settings.text != blank %}
                <div class="feature-text-{{ section.id }}">{{ block.settings.text }}</div>
              {% endif %}
            </div> 
          {% endif %}
        {% endfor %}
      </div>
    </div>

    {% if section.settings.button_text != blank %}
      <a href="{{ section.settings.button_url }}" class="feature-button-{{ section.id }}">
        <p class="feature-button-inner-{{ section.id }}">
          {{ section.settings.button_text }}
          {% if section.settings.show_arrow %}
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 7H13M13 7L7 1M13 7L7 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          {% endif %}
        </p>
      </a>     
    {% endif %}
    
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>
<script src="https://cdn.jsdelivr.net/npm/vanilla-lazyload@19.1.3/dist/lazyload.min.js" defer></script>

<script>
  (function() {
    function initFeatureSection() {
      const sectionId = '{{ section.id }}';
      const sectionEl = document.querySelector(`.section-${sectionId}`);
      if (!sectionEl) return;
      
      let lazyLoadInstance = new LazyLoad();
      window.addEventListener(
        "LazyLoad::Initialized",
        function (event) {
          window.lazyLoadInstance = event.detail.instance;
        },
        false
      );
      
      const featureItems = sectionEl.querySelectorAll(`.feature-features-mobile-wrap-${sectionId} .feature-feature-${sectionId}`);
      const dots = sectionEl.querySelectorAll(`.feature-dot-${sectionId}`);
      const allFeatureItems = sectionEl.querySelectorAll(`.feature-features-desktop-${sectionId} .feature-feature-${sectionId}`);
      const svgContainer = sectionEl.querySelector(`.feature-lines-svg-${sectionId}`);
      const isMobile = window.matchMedia('(max-width: 1024px)').matches;
      
      let desktopFeatures = Array.from(allFeatureItems);
      let linesDrawnForDesktop = false;

      function setActiveFeature(activeElement) {
        featureItems.forEach(item => item.classList.remove('active'));
        dots.forEach(dot => dot.classList.remove('active'));

        if (activeElement) {
          activeElement.classList.add('active');
          const featureId = activeElement.id;
          const activeDot = sectionEl.querySelector(`.feature-dot-${sectionId}[data-id="${featureId}"]`);
          if (activeDot) {
            activeDot.classList.add('active');
          }
        }
        
        drawActiveFeatureLine();
      }

      function resetLinesAndClasses() {
        if (svgContainer) svgContainer.innerHTML = '';
        if (!isMobile) {
          allFeatureItems.forEach(item => item.classList.remove('active', 'in-view'));
        }      
        dots.forEach(dot => dot.classList.remove('active', 'in-view'));
        linesDrawnForDesktop = false;
      }

      function drawActiveFeatureLine() {
        if (svgContainer) {
          svgContainer.innerHTML = '';
        } else {
          return;
        }

        const activeFeature = sectionEl.querySelector(`.feature-feature-${sectionId}.active`);
        const activeDot = sectionEl.querySelector(`.feature-dot-${sectionId}.active`);

        if (activeFeature && activeDot) {
          const startDotElement = activeFeature.querySelector(`.feature-start-dot-${sectionId}`);
          if (!startDotElement) return;

          const startRect = startDotElement.getBoundingClientRect();
          const endRect = activeDot.getBoundingClientRect();
          const svgRect = svgContainer.getBoundingClientRect();

          const startX = startRect.left + startRect.width / 2 - svgRect.left;
          const startY = startRect.top + startRect.height / 2 - svgRect.top;
          const endX = endRect.left + endRect.width / 2 - svgRect.left;
          const endY = endRect.top + endRect.height / 2 - svgRect.top;

          const isSecondColumn = activeFeature.classList.contains('second');
          const isMobileView = window.matchMedia('(max-width: 1024px)').matches;

          let pathD;
          
          if (isMobileView) {
              const middleX = svgRect.width - 20;
              pathD = `M ${startX} ${startY} H ${middleX} V ${endY} H ${endX}`;
          } else {
              const midPointX = endX;
              if (!isSecondColumn) {
                pathD = `M ${startX} ${startY} H ${midPointX} V ${endY}`;
              } else {
                pathD = `M ${startX} ${startY} H ${midPointX} V ${endY}`;
              }
          }

          const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
          path.setAttribute("d", pathD);
          path.setAttribute("stroke", "{{ section.settings.line_color }}");
          path.setAttribute("stroke-width", "{{ section.settings.line_width }}");
          path.setAttribute("fill", "none");
          path.setAttribute("class", "active-feature-line");
          svgContainer.appendChild(path);

          const pathLength = path.getTotalLength();
          const duration = 1000;
          let startTime = null;

          function animatePath(timestamp) {
            if (!startTime) {
              startTime = timestamp;
            }

            const elapsed = timestamp - startTime;
            const progress = Math.min(elapsed / duration, 1);
            const animatedLength = pathLength * progress;

            path.style.strokeDasharray = `${animatedLength} ${pathLength}`;

            if (progress < 1) {
              requestAnimationFrame(animatePath);
            }
          }

          requestAnimationFrame(animatePath);
        }
      }

      function drawAllLines() {
        resetLinesAndClasses();

        if (linesDrawnForDesktop || !svgContainer) return;

        const svgRect = svgContainer.getBoundingClientRect();

        if (!isMobile) {
          allFeatureItems.forEach((featureItem) => {
            const featureId = featureItem.id;
            const startDotElement = featureItem.querySelector(`.feature-start-dot-${sectionId}`);
            const endDot = sectionEl.querySelector(`.feature-dot-${sectionId}[data-id="${featureId}"]`);

            if (!startDotElement || !endDot) return;

            featureItem.classList.add('in-view');
            endDot.classList.add('in-view');

            const startRect = startDotElement.getBoundingClientRect();
            const endRect = endDot.getBoundingClientRect();

            const startX = startRect.left + startRect.width / 2 - svgRect.left;
            const startY = startRect.top + startRect.height / 2 - svgRect.top;
            const endX = endRect.left + endRect.width / 2 - svgRect.left;
            const endY = endRect.top + endRect.height / 2 - svgRect.top;

            const midPointX = endX; 
            const pathD = `M ${startX} ${startY} H ${midPointX} V ${endY}`;

            const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
            path.setAttribute("d", pathD);
            path.setAttribute("stroke", "{{ section.settings.line_color }}");
            path.setAttribute("stroke-width", "{{ section.settings.line_width }}");
            path.setAttribute("fill", "none");
            path.setAttribute("class", "feature-line-all"); 
            svgContainer.appendChild(path);

            const pathLength = path.getTotalLength();
            path.style.strokeDasharray = pathLength;
            path.style.strokeDashoffset = pathLength;
            
            setTimeout(() => {
              path.style.transition = `stroke-dashoffset 1000ms ease-out`;
              path.style.strokeDashoffset = '0';
            }, 50);
          });
        }

        linesDrawnForDesktop = true; 
      }

      function updateFeatureState(isSectionVisible) {
        if (!isSectionVisible) {
          resetLinesAndClasses();
          return;
        }
        
        if (!linesDrawnForDesktop) {
          drawAllLines();
          if (desktopFeatures.length > 0) {
            desktopFeatures[0].classList.add('active'); 
            const firstDot = sectionEl.querySelector(`.feature-dot-${sectionId}[data-id="${desktopFeatures[0].id}"]`);
            if (firstDot) firstDot.classList.add('active');
          }
        }    
      }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          updateFeatureState(entry.isIntersecting);
        });
      }, {
        root: null,
        rootMargin: '0px',
        threshold: 0.1 
      });

      observer.observe(sectionEl);

      desktopFeatures.forEach((featureItem) => {
        featureItem.addEventListener('click', () => {
          desktopFeatures.forEach(item => item.classList.remove('active'));
          dots.forEach(dot => dot.classList.remove('active'));

          featureItem.classList.add('active');
          const activeDot = sectionEl.querySelector(`.feature-dot-${sectionId}[data-id="${featureItem.id}"]`);
          if (activeDot) {
            activeDot.classList.add('active');
          }
        });
      });

      // Initialize mobile slider
      if (featureItems.length > 0) {
        const slider = new Swiper(`.feature-features-mobile-${sectionId}`, {
          speed: 500,
          slidesPerView: 1,
          effect: "fade",
          centeredSlides: true,
          loop: true,
          navigation: {
            nextEl: `.feature-btn-next-${sectionId}`,
            prevEl: `.feature-btn-prev-${sectionId}`,
          },
          on: {
            slideChange: function () {
              setActiveFeature(this.slides[this.activeIndex]);
            },
          },
        });

        if (slider.slides.length > 0) {
          setActiveFeature(slider.slides[0]);
        }
      } else if (desktopFeatures.length > 0) {
        setActiveFeature(desktopFeatures[0]);
      }

      // Handle resize
      let resizeTimer;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => { 
          const newIsMobile = window.matchMedia('(max-width: 1024px)').matches;
          
          // Reset dots
          dots.forEach(dot => {
            dot.classList.remove('active');
            dot.classList.remove('in-view');
          });
          
          if (newIsMobile) {
            const mobileSliderEl = document.querySelector(`.feature-features-mobile-${sectionId}`);
            if (mobileSliderEl && mobileSliderEl.swiper) {
              setActiveFeature(mobileSliderEl.swiper.slides[mobileSliderEl.swiper.activeIndex]);
            }
          } else {
            if (desktopFeatures.length > 0) {
              setActiveFeature(desktopFeatures[0]);
            }
            linesDrawnForDesktop = false;
            updateFeatureState(true);
          }
        }, 250);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initFeatureSection);
    } else {
      initFeatureSection();
    }

    {% if request.design_mode %}
      document.addEventListener('shopify:section:load', function(event) {
        if (event.detail.sectionId === '{{ section.id }}') {
          setTimeout(initFeatureSection, 100);
        }
      });
    {% endif %}
  })();
</script>

