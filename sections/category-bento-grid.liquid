{% comment %}
  Category Bento Grid
  Bento-style category layout: 1 large left card + 2 small top-right + 1 wide bottom-right
  Block order determines position: 1=large left, 2=small top-left, 3=small top-right, 4=wide bottom
{% endcomment %}

{%- style -%}
  .cbg--{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<section class="cbg cbg--{{ section.id }}">
  <div class="cbg__inner">

    {%- comment -%} Section heading {%- endcomment -%}
    <div class="cbg__header">
      {%- if section.settings.subheading != blank -%}
        <p class="cbg__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="cbg__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
    </div>

    {%- comment -%} Bento grid {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="cbg__grid">

        {%- comment -%} Block 1 — large left card {%- endcomment -%}
        {%- assign block_large = section.blocks[0] -%}
        {%- if block_large -%}
          <div class="cbg__card cbg__card--large" {{ block_large.shopify_attributes }}>
            <div class="cbg__card-content cbg__card-content--center">
              {%- if block_large.settings.title != blank -%}
                <h3 class="cbg__card-title cbg__card-title--lg">{{ block_large.settings.title | escape }}</h3>
              {%- endif -%}
              {%- if block_large.settings.description != blank -%}
                <p class="cbg__card-desc">{{ block_large.settings.description | escape }}</p>
              {%- endif -%}
              {%- if block_large.settings.button_label != blank -%}
                <a
                  href="{{ block_large.settings.button_url | default: '#' }}"
                  class="cbg__btn"
                  {% if block_large.settings.button_url == blank %}aria-disabled="true"{% endif %}
                >
                  {{- block_large.settings.button_label | escape -}}
                </a>
              {%- endif -%}
            </div>
            {%- if block_large.settings.image -%}
              {%- assign _alt_large = block_large.settings.title | escape -%}
              <div class="cbg__card-img-wrap cbg__card-img-wrap--large">
                {{
                  block_large.settings.image
                  | image_url: width: 960
                  | image_tag: loading: 'lazy', alt: _alt_large, class: 'cbg__card-img'
                }}
              </div>
            {%- else -%}
              <div class="cbg__card-img-wrap cbg__card-img-wrap--large cbg__card-img-wrap--placeholder">
                {{ 'collection-1' | placeholder_svg_tag: 'cbg__card-img' }}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- comment -%} Right column: two small cards + one wide card {%- endcomment -%}
        <div class="cbg__right-col">

          {%- comment -%} Top row: blocks 2 & 3 {%- endcomment -%}
          <div class="cbg__top-row">
            {%- for i in (1..2) -%}
              {%- assign block_small = section.blocks[i] -%}
              {%- if block_small -%}
                <div class="cbg__card cbg__card--small" {{ block_small.shopify_attributes }}>
                  <div class="cbg__card-content cbg__card-content--center">
                    {%- if block_small.settings.title != blank -%}
                      <h3 class="cbg__card-title cbg__card-title--sm">{{ block_small.settings.title | escape }}</h3>
                    {%- endif -%}
                    {%- if block_small.settings.description != blank -%}
                      <p class="cbg__card-desc cbg__card-desc--sm">{{ block_small.settings.description | escape }}</p>
                    {%- endif -%}
                    {%- if block_small.settings.button_label != blank -%}
                      <a
                        href="{{ block_small.settings.button_url | default: '#' }}"
                        class="cbg__btn"
                        {% if block_small.settings.button_url == blank %}aria-disabled="true"{% endif %}
                      >
                        {{- block_small.settings.button_label | escape -}}
                      </a>
                    {%- endif -%}
                  </div>
                  {%- if block_small.settings.image -%}
                    {%- assign _alt_small = block_small.settings.title | escape -%}
                    <div class="cbg__card-img-wrap cbg__card-img-wrap--small">
                      {{
                        block_small.settings.image
                        | image_url: width: 320
                        | image_tag: loading: 'lazy', alt: _alt_small, class: 'cbg__card-img cbg__card-img--contain'
                      }}
                    </div>
                  {%- else -%}
                    <div class="cbg__card-img-wrap cbg__card-img-wrap--small cbg__card-img-wrap--placeholder">
                      {{ 'collection-2' | placeholder_svg_tag: 'cbg__card-img' }}
                    </div>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>

          {%- comment -%} Block 4 — wide bottom card {%- endcomment -%}
          {%- assign block_wide = section.blocks[3] -%}
          {%- if block_wide -%}
            <div class="cbg__card cbg__card--wide" {{ block_wide.shopify_attributes }}>
              <div class="cbg__card-content cbg__card-content--center">
                {%- if block_wide.settings.title != blank -%}
                  <h3 class="cbg__card-title cbg__card-title--sm">{{ block_wide.settings.title | escape }}</h3>
                {%- endif -%}
                {%- if block_wide.settings.description != blank -%}
                  <p class="cbg__card-desc cbg__card-desc--sm">{{ block_wide.settings.description | escape }}</p>
                {%- endif -%}
                {%- if block_wide.settings.button_label != blank -%}
                  <a
                    href="{{ block_wide.settings.button_url | default: '#' }}"
                    class="cbg__btn"
                    {% if block_wide.settings.button_url == blank %}aria-disabled="true"{% endif %}
                  >
                    {{- block_wide.settings.button_label | escape -}}
                  </a>
                {%- endif -%}
              </div>
              {%- if block_wide.settings.image -%}
                {%- assign _alt_wide = block_wide.settings.title | escape -%}
                <div class="cbg__card-img-wrap cbg__card-img-wrap--wide">
                  {{
                    block_wide.settings.image
                    | image_url: width: 600
                    | image_tag: loading: 'lazy', alt: _alt_wide, class: 'cbg__card-img cbg__card-img--cover'
                  }}
                </div>
              {%- else -%}
                <div class="cbg__card-img-wrap cbg__card-img-wrap--wide cbg__card-img-wrap--placeholder">
                  {{ 'collection-3' | placeholder_svg_tag: 'cbg__card-img' }}
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}

        </div>{%- comment -%} /.cbg__right-col {%- endcomment -%}
      </div>
    {%- endif -%}

  </div>
</section>

<style>
/* ── Root ──────────────────────────────────────────────────────────────────── */
.cbg {
  background: #060c18;
  font-family: 'Inter', sans-serif;
  color: #fff;
}

/* ── Inner ──────────────────────────────────────────────────────────────────── */
.cbg__inner {
  max-width: 1440px;
  margin: 0 auto;
  padding-left: 80px;
  padding-right: 80px;
  display: flex;
  flex-direction: column;
  gap: 40px;
  align-items: center;
}

/* ── Heading ───────────────────────────────────────────────────────────────── */
.cbg__header {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.cbg__subheading {
  margin: 0;
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #d4af37;
}
.cbg__heading {
  margin: 0;
  font-size: 48px;
  font-weight: 700;
  letter-spacing: -2px;
  color: #fff;
  line-height: 1.1;
}

/* ── Grid ──────────────────────────────────────────────────────────────────── */
.cbg__grid {
  width: 100%;
  display: flex;
  gap: 16px;
  align-items: stretch;
}

.cbg__right-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16px;
  min-width: 0;
}

.cbg__top-row {
  display: flex;
  gap: 16px;
  flex: 1;
}

/* ── Card base ─────────────────────────────────────────────────────────────── */
.cbg__card {
  background: rgba(10, 14, 26, 0.6);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 12px;
  box-shadow: 0 0 40px 0 rgba(10, 132, 255, 0.15);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: box-shadow 0.25s ease, border-color 0.25s ease;
}
.cbg__card:hover {
  box-shadow: 0 0 60px 0 rgba(10, 132, 255, 0.28);
  border-color: rgba(10, 132, 255, 0.3);
}

/* Large card */
.cbg__card--large {
  width: 632px;
  flex-shrink: 0;
  padding: 80px 40px 0;
  gap: 40px;
}

/* Small cards */
.cbg__card--small {
  flex: 1;
  padding: 28px 20px;
  gap: 20px;
  min-width: 0;
}

/* Wide bottom card */
.cbg__card--wide {
  width: 100%;
  height: 308px;
  flex-direction: row;
  justify-content: space-between;
  padding: 0 40px;
  gap: 24px;
}

/* ── Card content ──────────────────────────────────────────────────────────── */
.cbg__card-content {
  display: flex;
  flex-direction: column;
  gap: 16px;
  flex-shrink: 0;
}
.cbg__card-content--center {
  align-items: center;
  text-align: center;
}
.cbg__card--wide .cbg__card-content {
  gap: 20px;
  width: 250px;
}

/* Titles */
.cbg__card-title {
  margin: 0;
  font-weight: 600;
  color: #fff;
  text-shadow: 0 4px 4px rgba(0, 0, 0, 0.25);
  line-height: 1.25;
}
.cbg__card-title--lg {
  font-size: 32px;
}
.cbg__card-title--sm {
  font-size: 24px;
  white-space: nowrap;
}

/* Descriptions */
.cbg__card-desc {
  margin: 0;
  font-size: 16px;
  font-weight: 400;
  color: #a0aec0;
  line-height: 1.5;
}
.cbg__card-desc--sm {
  font-size: 14px;
}

/* Button */
.cbg__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12px 24px;
  border-radius: 8px;
  background: rgba(10, 132, 255, 0.1);
  border: 1px solid rgba(10, 132, 255, 0.3);
  color: #0a84ff;
  font-size: 14px;
  font-weight: 600;
  text-decoration: none;
  letter-spacing: 0.03em;
  white-space: nowrap;
  transition: background 0.2s ease, border-color 0.2s ease;
}
.cbg__btn:hover {
  background: rgba(10, 132, 255, 0.2);
  border-color: rgba(10, 132, 255, 0.6);
}
.cbg__btn[aria-disabled="true"] {
  pointer-events: none;
  opacity: 0.5;
}

/* ── Images ────────────────────────────────────────────────────────────────── */
.cbg__card-img-wrap {
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

/* Large: bottom image overflow effect */
.cbg__card-img-wrap--large {
  width: 472px;
  height: 326px;
  overflow: hidden;
  flex-shrink: 0;
}
.cbg__card-img-wrap--large .cbg__card-img {
  width: 110%;
  height: 100%;
  object-fit: cover;
  margin-left: -5%;
  display: block;
}

/* Small: contained product image */
.cbg__card-img-wrap--small {
  width: 160px;
  height: 104px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cbg__card-img--contain {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
}

/* Wide: side image */
.cbg__card-img-wrap--wide {
  width: 294px;
  height: 188px;
  overflow: hidden;
  flex-shrink: 0;
  border-radius: 4px;
}
.cbg__card-img--cover {
  width: 110%;
  height: 115%;
  object-fit: cover;
  margin-left: -5%;
  margin-top: -6%;
  display: block;
}

/* Placeholder */
.cbg__card-img-wrap--placeholder {
  background: #0d1526;
}
.cbg__card-img-wrap--placeholder svg {
  width: 100%;
  height: 100%;
  opacity: 0.3;
}

/* ── Responsive ────────────────────────────────────────────────────────────── */
@media screen and (max-width: 1100px) {
  .cbg__inner { padding-left: 40px; padding-right: 40px; }
  .cbg__heading { font-size: 36px; }
  .cbg__grid { flex-direction: column; }
  .cbg__card--large {
    width: 100%;
    flex-direction: row;
    justify-content: space-between;
    padding: 40px;
    gap: 24px;
    height: auto;
  }
  .cbg__card--large .cbg__card-content { align-items: flex-start; text-align: left; }
  .cbg__card-img-wrap--large { width: 300px; height: 200px; }
}

@media screen and (max-width: 749px) {
  .cbg__inner { padding-left: 20px; padding-right: 20px; gap: 24px; }
  .cbg__heading { font-size: 28px; letter-spacing: -1px; }
  .cbg__grid { gap: 12px; }
  .cbg__top-row { flex-direction: column; }
  .cbg__card--large {
    flex-direction: column;
    align-items: center;
    padding: 40px 20px 0;
    text-align: center;
  }
  .cbg__card--large .cbg__card-content { align-items: center; text-align: center; }
  .cbg__card-img-wrap--large { width: 100%; }
  .cbg__card--wide {
    flex-direction: column;
    height: auto;
    padding: 32px 20px;
    gap: 20px;
    align-items: center;
  }
  .cbg__card--wide .cbg__card-content { width: auto; }
  .cbg__card-title--sm { white-space: normal; }
}
</style>

{% schema %}
{
  "name": "Category Bento Grid",
  "tag": "section",
  "class": "category-bento-grid-section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Categories"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop Across Categories"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "category_card",
      "name": "Category card",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "LCD Video Walls"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Lorem ipsum dolor sit amet"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "SHOP NOW"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Bento Grid",
      "blocks": [
        {
          "type": "category_card",
          "settings": {
            "title": "LCD Video Walls",
            "description": "Lorem ipsum dolor sit amet",
            "button_label": "SHOP NOW"
          }
        },
        {
          "type": "category_card",
          "settings": {
            "title": "HDMI & HDBaseT",
            "description": "Lorem ipsum dolor sit amet",
            "button_label": "SHOP NOW"
          }
        },
        {
          "type": "category_card",
          "settings": {
            "title": "Matrix Switchers",
            "description": "Lorem ipsum dolor sit amet",
            "button_label": "SHOP NOW"
          }
        },
        {
          "type": "category_card",
          "settings": {
            "title": "LED Video Walls",
            "description": "Lorem ipsum dolor sit amet, consectetur adipiscing elit",
            "button_label": "SHOP NOW"
          }
        }
      ]
    }
  ]
}
{% endschema %}
