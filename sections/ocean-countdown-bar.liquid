{% comment %}
  Ocean Countdown Bar
  Slim announcement bar with countdown timer — Kind Laundry "Ocean Breeze Price Drop"
{% endcomment %}

<div class="ocb ocb--{{ section.id }}" id="ocb-{{ section.id }}">
  <div class="ocb__inner">

    {%- comment -%} Message + icon {%- endcomment -%}
    <div class="ocb__message">
      {%- if section.settings.message != blank -%}
        {%- if section.settings.link != blank -%}
          <a href="{{ section.settings.link }}" class="ocb__message-link">{{ section.settings.message | escape }}</a>
        {%- else -%}
          <span>{{ section.settings.message | escape }}</span>
        {%- endif -%}
      {%- endif -%}

      {%- comment -%} Wave icon SVG {%- endcomment -%}
      <span class="ocb__icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="20" viewBox="0 0 35 20" fill="none">
          <path d="M1 14.5C3.5 14.5 5.5 12 8 12C10.5 12 12 14.5 14.5 14.5C17 14.5 19 12 21.5 12C24 12 25.5 14.5 28 14.5C30.5 14.5 32.5 12 35 12" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M1 18C3.5 18 5.5 15.5 8 15.5C10.5 15.5 12 18 14.5 18C17 18 19 15.5 21.5 15.5C24 15.5 25.5 18 28 18C30.5 18 32.5 15.5 35 15.5" stroke="white" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
          <path d="M17.5 1L14 6H21L17.5 1Z" fill="white" opacity="0.9"/>
          <path d="M14 6H21V10C21 10 19.5 11.5 17.5 11.5C15.5 11.5 14 10 14 10V6Z" fill="white" opacity="0.7"/>
          <line x1="17.5" y1="10" x2="17.5" y2="12" stroke="white" stroke-width="1.2"/>
        </svg>
      </span>
    </div>

    {%- comment -%} Countdown timer {%- endcomment -%}
    <div class="ocb__timer" data-ocb-timer data-end="{{ section.settings.end_date }}T{{ section.settings.end_time }}:00">
      <div class="ocb__unit">
        <span class="ocb__num" data-ocb-days>00</span>
        <span class="ocb__label">{{ section.settings.label_days | default: 'days' }}</span>
      </div>
      <div class="ocb__unit">
        <span class="ocb__num" data-ocb-hours>00</span>
        <span class="ocb__label">{{ section.settings.label_hours | default: 'hrs' }}</span>
      </div>
      <div class="ocb__unit">
        <span class="ocb__num" data-ocb-mins>00</span>
        <span class="ocb__label">{{ section.settings.label_mins | default: 'min' }}</span>
      </div>
      <div class="ocb__unit">
        <span class="ocb__num" data-ocb-secs>00</span>
        <span class="ocb__label">{{ section.settings.label_secs | default: 'sec' }}</span>
      </div>
    </div>

  </div>
</div>

<style>
.ocb--{{ section.id }} {
  background-color: {{ section.settings.bg_color }};
  width: 100%;
}

.ocb__inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20px;
  padding: 14px 20px;
  flex-wrap: wrap;
}

.ocb__message {
  display: flex;
  align-items: center;
  gap: 10px;
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  font-weight: 600;
  color: {{ section.settings.text_color }};
  white-space: nowrap;
}
.ocb__message-link {
  color: inherit;
  text-decoration: none;
}
.ocb__message-link:hover {
  text-decoration: underline;
}

.ocb__icon {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.ocb__timer {
  display: flex;
  align-items: center;
  gap: 12px;
}

.ocb__unit {
  display: flex;
  flex-direction: column;
  align-items: center;
  line-height: 1;
}

.ocb__num {
  font-family: 'Inter', sans-serif;
  font-size: 20px;
  font-weight: 700;
  color: {{ section.settings.text_color }};
  letter-spacing: 0.02em;
  min-width: 2ch;
  text-align: center;
}

.ocb__label {
  font-family: 'Inter', sans-serif;
  font-size: 10px;
  font-weight: 400;
  color: {{ section.settings.text_color }};
  opacity: 0.75;
  text-align: center;
  margin-top: 2px;
  letter-spacing: 0.04em;
}

@media screen and (max-width: 749px) {
  .ocb__inner {
    gap: 12px;
    padding: 12px 16px;
  }
  .ocb__message {
    font-size: 12px;
  }
  .ocb__num {
    font-size: 16px;
  }
}
</style>

<script>
(function () {
  const bar = document.getElementById('ocb-{{ section.id }}');
  if (!bar) return;

  const timer = bar.querySelector('[data-ocb-timer]');
  if (!timer) return;

  const endAttr = timer.getAttribute('data-end');
  if (!endAttr || endAttr.trim() === 'T:00' || endAttr.trim() === '') return;

  const endTime = new Date(endAttr).getTime();
  if (isNaN(endTime)) return;

  const daysEl  = timer.querySelector('[data-ocb-days]');
  const hoursEl = timer.querySelector('[data-ocb-hours]');
  const minsEl  = timer.querySelector('[data-ocb-mins]');
  const secsEl  = timer.querySelector('[data-ocb-secs]');

  function pad(n) { return String(n).padStart(2, '0'); }

  function tick() {
    const diff = endTime - Date.now();
    if (diff <= 0) {
      daysEl.textContent  = '00';
      hoursEl.textContent = '00';
      minsEl.textContent  = '00';
      secsEl.textContent  = '00';
      clearInterval(interval);
      return;
    }
    const days  = Math.floor(diff / 86400000);
    const hours = Math.floor((diff % 86400000) / 3600000);
    const mins  = Math.floor((diff % 3600000)  / 60000);
    const secs  = Math.floor((diff % 60000)    / 1000);

    daysEl.textContent  = pad(days);
    hoursEl.textContent = pad(hours);
    minsEl.textContent  = pad(mins);
    secsEl.textContent  = pad(secs);
  }

  tick();
  const interval = setInterval(tick, 1000);

  document.addEventListener('shopify:section:unload', function (e) {
    if (e.detail && e.detail.sectionId === '{{ section.id }}') {
      clearInterval(interval);
    }
  });
})();
</script>

{% schema %}
{
  "name": "Ocean Countdown Bar",
  "tag": "section",
  "class": "ocean-countdown-bar-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "message",
      "label": "Message",
      "default": "Ocean Breeze Price Drop. Limited Time Only!"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Message link (optional)"
    },
    {
      "type": "header",
      "content": "Countdown"
    },
    {
      "type": "text",
      "id": "end_date",
      "label": "End date (YYYY-MM-DD)",
      "default": "2025-12-31",
      "info": "Format: 2025-12-31"
    },
    {
      "type": "text",
      "id": "end_time",
      "label": "End time (HH:MM, 24-hour)",
      "default": "23:59",
      "info": "Format: 23:59"
    },
    {
      "type": "text",
      "id": "label_days",
      "label": "Days label",
      "default": "days"
    },
    {
      "type": "text",
      "id": "label_hours",
      "label": "Hours label",
      "default": "hrs"
    },
    {
      "type": "text",
      "id": "label_mins",
      "label": "Minutes label",
      "default": "min"
    },
    {
      "type": "text",
      "id": "label_secs",
      "label": "Seconds label",
      "default": "sec"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#235146"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Ocean Countdown Bar",
      "category": "Announcement"
    }
  ]
}
{% endschema %}
