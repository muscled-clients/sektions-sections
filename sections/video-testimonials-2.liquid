{% style %}
  .video-testimonials--round {
  background-color: var(--vt-bg-color, #ffffff);
  color: var(--vt-text-color, #1a1a1a);
  padding-top: var(--vt-padding-top, 36px);
  padding-bottom: var(--vt-padding-bottom, 36px);
  overflow: hidden;
}

.video-testimonials--round .video-testimonials__container {
  max-width: 100%;
}

/* Header */
.video-testimonials--round .video-testimonials__header {
  text-align: center;
  margin-bottom: 2rem;
  padding: 0 1.5rem;
}

.video-testimonials--round .video-testimonials__subheading {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--vt-subheading-color, #666);
  margin: 0 0 0.5rem;
}

.video-testimonials--round .video-testimonials__heading {
  font-size: 26px;
  font-weight: 700;
  line-height: 1.3;
  margin: 0 0 0.75rem;
  color: var(--vt-text-color, #1a1a1a);
}

.video-testimonials--round .video-testimonials__description {
  font-size: 14px;
  line-height: 1.5;
  color: var(--vt-subheading-color, #666);
  margin: 0 auto;
  max-width: 500px;
  font-style: italic;
}

/* Slider wrapper */
.video-testimonials--round .video-testimonials__slider-wrapper {
  position: relative;
  margin-left: -1.5rem;
  margin-right: -1.5rem;
  padding-left: 1.5rem;
  padding-right: 1.5rem;
  margin-top: 32px;
}

/* Swiper */
.video-testimonials--round .video-testimonials__swiper {
  overflow: visible !important;
}

.video-testimonials--round .video-testimonials__swiper .swiper-wrapper {
  align-items: stretch !important;
}

.video-testimonials--round .video-testimonials__swiper .swiper-slide {
  height: auto;
  transition: transform 0.6s ease;
}

/* Card — circular */
.video-testimonials--round .video-testimonials__card {
  position: relative;
  border-radius: 999px;
  overflow: hidden;
  cursor: pointer;
  background: #000;
  aspect-ratio: 9.6 / 12;
}

.video-testimonials--round .video-testimonials__media {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.video-testimonials--round .video-testimonials__video,
.video-testimonials--round .video-testimonials__iframe {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  border: none;
}

.video-testimonials--round .video-testimonials__poster {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: opacity 0.4s ease;
  z-index: 1;
}

/* Play button — circular with border */
.video-testimonials--round .video-testimonials__play-btn {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 60px;
  height: 60px;
  border-radius: 100px;
  background: rgba(255, 255, 255, 0.2);
  border: 1px solid #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  z-index: 3;
  transition: opacity 0.3s ease, transform 0.3s ease;
  padding: 0;
}

.video-testimonials--round .video-testimonials__play-btn:hover {
  transform: translate(-50%, -50%) scale(1.1);
  background: rgba(255, 255, 255, 0.35);
}

/* Gradient overlay */
.video-testimonials--round .video-testimonials__gradient {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, #000000 100%);
  z-index: 2;
  pointer-events: none;
}

/* Content overlay */
.video-testimonials--round .video-testimonials__content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 36px 20px;
  z-index: 3;
}

.video-testimonials--round .video-testimonials__name {
  font-size: 16px;
  font-weight: 700;
  color: #fff;
  margin: 0 0 4px;
  line-height: 1.3;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

.video-testimonials--round .video-testimonials__product {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.9);
  margin: 0 0 6px;
  line-height: 1.5;
  text-align: center;
}

.video-testimonials--round .video-testimonials__verified {
  display: inline-block;
  vertical-align: middle;
  flex-shrink: 0;
}

.video-testimonials--round .video-testimonials__stars {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  margin-top: 12px;
}

/* Navigation buttons */
.video-testimonials--round .video-testimonials__nav {
  display: none;
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 50px;
  height: 50px;
  border-radius: 100px;
  background: var(--vt-btn-bg, #953034);
  color: var(--vt-btn-icon, #ffffff);
  border: none;
  cursor: pointer;
  align-items: center;
  justify-content: center;
  z-index: 10;
  transition: all 0.3s ease;
}

.video-testimonials--round .video-testimonials__nav:hover {
  transform: translateY(-50%) scale(0.9);
}

.video-testimonials--round .video-testimonials__nav--prev {
  left: 5%;
}

.video-testimonials--round .video-testimonials__nav--next {
  right: 5%;
}

/* Tablet */
@media (min-width: 768px) {
  .video-testimonials--round .video-testimonials__heading {
    font-size: 36px;
  }

  .video-testimonials--round .video-testimonials__name {
    font-size: 18px;
  }

  .video-testimonials--round .video-testimonials__product {
    font-size: 14px;
  }
}

/* Desktop */
@media (min-width: 1024px) {
  .video-testimonials--round .video-testimonials__heading {
    font-size: 52px;
  }

  .video-testimonials--round .video-testimonials__name {
    font-size: 20px;
  }

  .video-testimonials--round .video-testimonials__play-btn {
    width: 64px;
    height: 64px;
  }

  .video-testimonials--round .video-testimonials__slider-wrapper {
    margin-left: auto;
    margin-right: auto;
    padding-left: 0;
    padding-right: 0;
    margin-top: 48px;
  }

  .video-testimonials--round .video-testimonials__swiper {
    -webkit-mask-image: linear-gradient(to right, rgba(0,0,0,0) 2%, rgba(0,0,0,1) 10%, rgba(0,0,0,1) 90%, rgba(0,0,0,0) 98%);
    mask-image: linear-gradient(to right, rgba(0,0,0,0) 2%, rgba(0,0,0,1) 10%, rgba(0,0,0,1) 90%, rgba(0,0,0,0) 98%);
  }

  .video-testimonials--round .video-testimonials__nav {
    display: flex;
  }

  .video-testimonials--round .video-testimonials__content {
    padding: 36px 24px;
  }

  .video-testimonials--round .video-testimonials__header {
    max-width: 80%;
    margin-left: auto;
    margin-right: auto;
  }
}

{% endstyle %}

{{ 'video-testimonials-round.css' | asset_url | stylesheet_tag }}

<div
  class="video-testimonials--round section-{{ section.id }}"
  style="
    --vt-bg-color: {{ section.settings.background_color }};
    --vt-text-color: {{ section.settings.text_color }};
    --vt-subheading-color: {{ section.settings.subheading_color }};
    --vt-btn-bg: {{ section.settings.nav_button_color }};
    --vt-btn-icon: {{ section.settings.nav_icon_color }};
    --vt-padding-top: {{ section.settings.padding_top }}px;
    --vt-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="video-testimonials__container">
    {%- if section.settings.subheading != blank or section.settings.heading != blank or section.settings.description != blank -%}
      <div class="video-testimonials__header">
        {%- if section.settings.subheading != blank -%}
          <p class="video-testimonials__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="video-testimonials__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="video-testimonials__description">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="video-testimonials__slider-wrapper">
      <div class="swiper video-testimonials__swiper" id="vt-swiper-{{ section.id }}">
        <div class="swiper-wrapper">
          {%- assign render_count = 2 -%}
          {%- if section.blocks.size >= 10 -%}
            {%- assign render_count = 1 -%}
          {%- endif -%}
          {%- for r in (1..render_count) -%}
            {%- for block in section.blocks -%}
              <div class="swiper-slide video-testimonials__slide" {% if r == 1 %}{{ block.shopify_attributes }}{% endif %}>
                <div class="video-testimonials__card">
                  <div class="video-testimonials__media">
                    {%- if block.settings.video_url != blank -%}
                      {%- assign video_url = block.settings.video_url -%}
                      {%- if video_url contains 'youtube.com' or video_url contains 'youtu.be' -%}
                        {%- if video_url contains 'youtu.be' -%}
                          {%- assign yt_id = video_url | split: 'youtu.be/' | last | split: '?' | first -%}
                        {%- else -%}
                          {%- assign yt_id = video_url | split: 'v=' | last | split: '&' | first -%}
                        {%- endif -%}
                        <iframe
                          class="video-testimonials__iframe"
                          src="https://www.youtube.com/embed/{{ yt_id }}?autoplay=0&mute=1&loop=1&playlist={{ yt_id }}&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1"
                          allow="autoplay; encrypted-media"
                          allowfullscreen
                          loading="lazy"
                        ></iframe>
                      {%- elsif video_url contains 'vimeo.com' -%}
                        {%- assign vimeo_id = video_url | split: 'vimeo.com/' | last | split: '?' | first | split: '/' | first -%}
                        <iframe
                          class="video-testimonials__iframe"
                          src="https://player.vimeo.com/video/{{ vimeo_id }}?autoplay=0&muted=1&loop=1&background=1&playsinline=1"
                          allow="autoplay; encrypted-media"
                          allowfullscreen
                          loading="lazy"
                        ></iframe>
                      {%- else -%}
                        <video
                          class="video-testimonials__video"
                          src="{{ video_url }}"
                          muted
                          loop
                          playsinline
                          preload="none"
                        ></video>
                      {%- endif -%}
                    {%- elsif block.settings.video != blank -%}
                      <video
                        class="video-testimonials__video"
                        muted
                        loop
                        playsinline
                        preload="none"
                      >
                        {%- for source in block.settings.video.sources -%}
                          <source src="{{ source.url }}" type="{{ source.mime_type }}">
                        {%- endfor -%}
                      </video>
                    {%- endif -%}

                    {%- if block.settings.poster_image != blank -%}
                      <img
                        class="video-testimonials__poster"
                        src="{{ block.settings.poster_image | image_url: width: 600 }}"
                        alt="{{ block.settings.customer_name | escape }}"
                        width="600"
                        height="750"
                        loading="lazy"
                      >
                    {%- endif -%}

                    <button class="video-testimonials__play-btn" aria-label="Play video">
                      <svg width="24" height="24" viewBox="0 0 61 60" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M21.7461 23.4817V36.5201C21.7461 39.1905 24.6062 40.8663 26.8889 39.5311L32.4615 36.2749L38.034 33.005C40.3168 31.6699 40.3168 28.3319 38.034 26.9967L32.4615 23.7269L26.8889 20.4707C24.6062 19.1356 21.7461 20.7977 21.7461 23.4817Z" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </button>

                    <div class="video-testimonials__gradient"></div>
                  </div>

                  <div class="video-testimonials__content">
                    {%- if block.settings.customer_name != blank -%}
                      <p class="video-testimonials__name">
                        {{- block.settings.customer_name -}}
                        {%- if block.settings.show_verified -%}
                          <svg class="video-testimonials__verified" width="16" height="16" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12.4333 3.31047C13.2813 2.23047 14.8893 2.23047 15.7373 3.31047L16.8773 4.76247C17.3453 5.35847 18.0573 5.71447 18.8173 5.73847L20.6693 5.79447C22.0173 5.83847 23.0853 6.90647 23.1293 8.25447L23.1853 10.1065C23.2093 10.8665 23.5653 11.5785 24.1613 12.0465L25.6133 13.1865C26.6933 14.0345 26.6933 15.6425 25.6133 16.4905L24.1613 17.6305C23.5653 18.0985 23.2093 18.8105 23.1853 19.5705L23.1293 21.4225C23.0853 22.7705 22.0173 23.8385 20.6693 23.8825L18.8173 23.9385C18.0573 23.9625 17.3453 24.3185 16.8773 24.9145L15.7373 26.3665C14.8893 27.4465 13.2813 27.4465 12.4333 26.3665L11.2933 24.9145C10.8253 24.3185 10.1133 23.9625 9.35328 23.9385L7.50128 23.8825C6.15328 23.8385 5.08528 22.7705 5.04128 21.4225L4.98528 19.5705C4.96128 18.8105 4.60528 18.0985 4.00928 17.6305L2.55728 16.4905C1.47728 15.6425 1.47728 14.0345 2.55728 13.1865L4.00928 12.0465C4.60528 11.5785 4.96128 10.8665 4.98528 10.1065L5.04128 8.25447C5.08528 6.90647 6.15328 5.83847 7.50128 5.79447L9.35328 5.73847C10.1133 5.71447 10.8253 5.35847 11.2933 4.76247L12.4333 3.31047Z" fill="#4c8ae7" stroke="#4c8ae7" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M9.82031 13.8467L12.4792 16.5166L17.8081 11.1768" stroke="#ffffff" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                        {%- endif -%}
                      </p>
                    {%- endif -%}
                    {%- if block.settings.product_name != blank -%}
                      <p class="video-testimonials__product">{{ block.settings.product_name }}</p>
                    {%- endif -%}
                    {%- if block.settings.show_stars -%}
                      <div class="video-testimonials__stars">
                        {%- for i in (1..5) -%}
                          {%- if i <= block.settings.star_rating -%}
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="#FFD700"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                          {%- else -%}
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#FFD700" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                          {%- endif -%}
                        {%- endfor -%}
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              </div>
            {%- endfor -%}
          {%- endfor -%}
        </div>
      </div>

      <button class="video-testimonials__nav video-testimonials__nav--prev" aria-label="Previous slide">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button class="video-testimonials__nav video-testimonials__nav--next" aria-label="Next slide">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

<script>
  (function () {
    var sectionId = '{{ section.id }}';

    function initSection() {
      var swiperEl = document.getElementById('vt-swiper-' + sectionId);
      if (!swiperEl) return;

      var wrapper = swiperEl.closest('.video-testimonials__slider-wrapper');

      function initSwiper() {
        if (typeof Swiper === 'undefined') {
          setTimeout(initSwiper, 100);
          return;
        }

        var swiper = new Swiper('#vt-swiper-' + sectionId, {
          effect: 'coverflow',
          centeredSlides: true,
          speed: 300,
          loop: true,
          watchSlidesProgress: true,
          navigation: {
            nextEl: wrapper.querySelector('.video-testimonials__nav--next'),
            prevEl: wrapper.querySelector('.video-testimonials__nav--prev'),
          },
          breakpoints: {
            320: {
              slidesPerView: 1.2,
              coverflowEffect: { rotate: 0, stretch: 0, depth: 160, modifier: 1, slideShadows: false },
            },
            768: {
              slidesPerView: 1.2,
              coverflowEffect: { rotate: 0, stretch: 0, depth: 160, modifier: 1, slideShadows: false },
            },
            1024: {
              slidesPerView: 3,
              coverflowEffect: { rotate: 0, stretch: 0, depth: 400, modifier: 1, slideShadows: false },
            },
            1200: {
              slidesPerView: 3,
              coverflowEffect: { rotate: 0, stretch: 0, depth: 400, modifier: 1, slideShadows: false },
            },
          },
          on: {
            setTranslate: function () {
              this.slides.forEach(function (slide) {
                var p = Math.abs(slide.progress);
                slide.style.visibility = p > 2.5 ? 'hidden' : 'visible';
              });
            },
          },
        });
      }

      function pauseAllVideos(container) {
        container.querySelectorAll('video').forEach(function (v) { v.pause(); });
      }

      swiperEl.addEventListener('click', function (e) {
        var card = e.target.closest('.video-testimonials__card');
        if (!card) return;

        var video = card.querySelector('video');
        var poster = card.querySelector('.video-testimonials__poster');
        var playBtn = card.querySelector('.video-testimonials__play-btn');

        if (video) {
          if (video.paused) {
            pauseAllVideos(swiperEl);
            video.play();
            if (poster) poster.style.opacity = '0';
            if (playBtn) playBtn.style.opacity = '0';
          } else {
            video.pause();
            if (playBtn) playBtn.style.opacity = '1';
          }
        }

        var iframe = card.querySelector('iframe');
        if (iframe && iframe.src) {
          if (poster) poster.style.opacity = '0';
          if (playBtn) playBtn.style.opacity = '0';
          if (iframe.src.includes('youtube')) {
            iframe.contentWindow.postMessage('{"event":"command","func":"playVideo","args":""}', '*');
          }
        }
      });

      initSwiper();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initSection);
    } else {
      initSection();
    }

    document.addEventListener('shopify:section:load', function (e) {
      if (e.detail.sectionId === sectionId) initSection();
    });
  })();
</script>

{% schema %}
{
  "name": "Video Testimonials 2",
  "tag": "section",
  "class": "video-testimonials-section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "What our customers say"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why people love our brand"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Don't just take our word for it, see what our customers are saying"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#953034"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#953034"
    },
    {
      "type": "color",
      "id": "nav_button_color",
      "label": "Navigation button color",
      "default": "#953034"
    },
    {
      "type": "color",
      "id": "nav_icon_color",
      "label": "Navigation icon color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "video_card",
      "name": "Video Card",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "info": "Upload a Shopify-hosted video"
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL",
          "info": "YouTube or Vimeo URL (used if no Shopify video is uploaded)"
        },
        {
          "type": "image_picker",
          "id": "poster_image",
          "label": "Poster image",
          "info": "Shown before the video plays"
        },
        {
          "type": "text",
          "id": "customer_name",
          "label": "Customer name",
          "default": "Jane Doe"
        },
        {
          "type": "text",
          "id": "product_name",
          "label": "Product name",
          "default": "Product Name"
        },
        {
          "type": "checkbox",
          "id": "show_verified",
          "label": "Show verified badge",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_stars",
          "label": "Show star rating",
